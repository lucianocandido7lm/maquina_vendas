.tl-sim-actions-bar .tl-imoveis-btn[data-busy="true"] {
  opacity: 1;
}

.tl-sim-empty {
  display: grid;
  place-items: center;
  min-height: 84px;
  padding: 14px;
  border-radius: 18px;
  border: 1px dashed rgba(18, 24, 38, 0.18);
  background: rgba(255, 255, 255, 0.76);
  color: rgba(42, 50, 66, 0.66);
  text-align: center;
}

@media (max-width: 1240px) {
  .tl-sim-shell__head,
  .tl-sim-stage,
  .tl-sim-grid-mid {
    grid-template-columns: 1fr;
  }

  .tl-sim-grid-mid {
    align-items: start;
  }

  .tl-sim-sugestoes {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .tl-sim-card--imovel,
  .tl-sim-card--proposta {
    min-height: auto;
  }

  .tl-sim-showcase__hero {
    grid-template-columns: 1fr;
  }

  .tl-sim-map-modal__body {
    grid-template-columns: 1fr;
  }

  .tl-sim-map-modal__frame {
    min-height: 420px;
  }

  .tl-sim-reserva-panel__metrics {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 900px) {
  .tl-sim-shell {
    padding: 18px;
  }

  .tl-sim-vitrine__toolbar {
    grid-template-columns: 1fr;
  }

  .tl-sim-sugestoes {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .tl-sim-client-card {
    grid-template-columns: 1fr;
  }

  .tl-sim-client-card__actions {
    width: 100%;
  }

  .tl-sim-client-card__actions .tl-imoveis-btn {
    width: 100%;
  }

  .tl-sim-client-hub__selector,
  .tl-sim-client-hub__details,
  .tl-sim-composition {
    padding: 12px;
  }

  .tl-sim-complementos-grid {
    grid-template-columns: 1fr;
  }

  .tl-sim-sugestoes {
    grid-auto-rows: auto;
    max-height: none;
    overflow: visible;
    padding-right: 0;
  }

  .tl-sim-sugestao-card {
    height: auto;
  }

  .tl-sim-showcase__metrics,
  .tl-sim-reserva-panel__metrics,
  .tl-sim-seat__stats,
  .tl-sim-hero-kpis {
    grid-template-columns: 1fr;
  }

  .tl-sim-seat__reservas-grid {
    grid-template-columns: 1fr;
  }

  .tl-sim-sugestao-card__media {
    grid-template-columns: 1fr;
  }

  .tl-sim-sugestao-card__image,
  .tl-sim-sugestao-card__placeholder {
    width: 100%;
    height: 180px;
  }

  .tl-sim-actions-bar {
    justify-content: stretch;
  }

  .tl-sim-actions-bar .tl-imoveis-btn {
    width: 100%;
  }

  .tl-sim-seat__identity {
    flex-direction: column;
    align-items: flex-start;
  }

  .tl-sim-map-modal__dialog {
    max-height: calc(100vh - 18px);
    overflow: auto;
    padding: 14px;
  }

  .tl-sim-map-modal__head {
    flex-direction: column;
  }

  .tl-sim-map-modal__head h3 {
    font-size: 1.54rem;
  }

  .tl-sim-map-modal__frame {
    min-height: 340px;
  }

  .tl-sim-map-modal__aside {
    padding: 14px;
  }
}

