.tl-sim-page .tl-main {
  gap: 24px;
  padding-bottom: 84px;
}

.tl-sim-shell {
  position: relative;
  display: grid;
  gap: 16px;
  padding: 22px;
  border-radius: 30px;
  background:
    linear-gradient(145deg, rgba(255, 255, 255, 0.54), rgba(255, 255, 255, 0.18)),
    radial-gradient(circle at top right, rgba(0, 179, 222, 0.14), transparent 42%);
  box-shadow: var(--ops-shadow-soft);
}

.tl-sim-shell__head {
  display: grid;
  grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.85fr);
  gap: 18px;
  align-items: start;
}

.tl-sim-shell__head h2 {
  margin: 8px 0 10px;
  font-size: clamp(1.7rem, 2.3vw, 2.45rem);
  line-height: 1.02;
  letter-spacing: -0.03em;
}

.tl-sim-shell__head p {
  margin: 0;
  max-width: 72ch;
  color: rgba(42, 50, 66, 0.76);
  font-size: 0.96rem;
}

.tl-sim-hero-kpis {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
  align-self: stretch;
}

.tl-sim-hero-kpi {
  display: grid;
  gap: 6px;
  padding: 16px 18px;
  border-radius: 22px;
  border: 1px solid rgba(255, 255, 255, 0.44);
  background:
    linear-gradient(145deg, rgba(255, 255, 255, 0.82), rgba(255, 255, 255, 0.56)),
    radial-gradient(circle at top left, rgba(0, 179, 222, 0.12), transparent 62%);
  box-shadow: 0 18px 42px -32px rgba(18, 28, 44, 0.26);
}

.tl-sim-hero-kpi span {
  font-size: 0.74rem;
  text-transform: uppercase;
  letter-spacing: 0.22em;
  color: rgba(42, 50, 66, 0.62);
  font-weight: 700;
}

.tl-sim-hero-kpi strong {
  font-size: 1.12rem;
  color: rgba(18, 24, 38, 0.92);
}

.tl-sim-stage,
.tl-sim-grid-mid {
  display: grid;
  gap: 16px;
  align-items: start;
}

.tl-sim-stage {
  grid-template-columns: 1fr;
}

.tl-sim-grid-mid {
  grid-template-columns: minmax(0, 1.08fr) minmax(0, 1fr);
  align-items: stretch;
}

.tl-sim-card {
  display: grid;
  gap: 14px;
  padding: 16px;
  border-radius: 22px;
  border: 1px solid rgba(18, 24, 38, 0.08);
  background:
    linear-gradient(145deg, rgba(255, 255, 255, 0.9), rgba(255, 255, 255, 0.72)),
    radial-gradient(circle at top left, rgba(0, 179, 222, 0.1), transparent 54%);
  box-shadow: 0 22px 44px -34px rgba(18, 28, 44, 0.26);
  align-content: start;
  transition: border-color 0.22s ease, box-shadow 0.22s ease, transform 0.22s ease;
}

.tl-sim-card.is-attention {
  border-color: rgba(15, 123, 255, 0.34);
  box-shadow: 0 24px 54px -32px rgba(15, 123, 255, 0.28);
  transform: translateY(-2px);
}

.tl-sim-card__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14px;
  min-width: 0;
  flex-wrap: wrap;
}

.tl-sim-card__head > div:first-child {
  min-width: 0;
  flex: 1 1 240px;
}

.tl-sim-card__head .tl-sim-chip,
.tl-sim-card__head .tl-imoveis-btn {
  max-width: 100%;
}

.tl-sim-card__head .tl-sim-chip {
  overflow: hidden;
  text-overflow: ellipsis;
}

.tl-sim-card__head h3 {
  margin: 3px 0 0;
  font-size: 1.12rem;
  line-height: 1.12;
}

.tl-sim-card__subcopy {
  margin: 8px 0 0;
  color: rgba(42, 50, 66, 0.68);
  font-size: 0.9rem;
  line-height: 1.4;
}

.tl-sim-card__head--cliente-hub {
  align-items: flex-start;
}

.tl-sim-client-hub__head-actions {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: flex-end;
  gap: 10px;
}

.tl-sim-card--cliente-hub {
  gap: 16px;
}

.tl-sim-client-hub {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14px;
  align-items: start;
}

.tl-sim-client-hub__selector,
.tl-sim-client-hub__details {
  display: grid;
  gap: 12px;
  min-width: 0;
  padding: 14px;
  border-radius: 20px;
  border: 1px solid rgba(18, 24, 38, 0.06);
  background: rgba(255, 255, 255, 0.46);
}

.tl-sim-client-hub__selector {
  gap: 10px;
}

.tl-sim-kicker {
  display: inline-flex;
  font-size: 0.73rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: #0f7bff;
  font-weight: 800;
}

.tl-sim-chip {
  display: inline-flex;
  align-items: center;
  min-height: 34px;
  border-radius: 999px;
  padding: 0 12px;
  background: rgba(12, 22, 38, 0.08);
  color: rgba(42, 50, 66, 0.72);
  font-size: 0.8rem;
  font-weight: 700;
  white-space: nowrap;
}

.tl-sim-clientes-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 10px;
  max-height: 190px;
  overflow-y: auto;
  padding-right: 6px;
  align-content: start;
  scrollbar-width: thin;
  scrollbar-color: rgba(15, 123, 255, 0.52) rgba(18, 24, 38, 0.08);
}

.tl-sim-clientes-grid::-webkit-scrollbar {
  width: 9px;
}

.tl-sim-clientes-grid::-webkit-scrollbar-track {
  border-radius: 999px;
  background: rgba(18, 24, 38, 0.08);
}

.tl-sim-clientes-grid::-webkit-scrollbar-thumb {
  border-radius: 999px;
  background: linear-gradient(180deg, rgba(0, 179, 222, 0.78), rgba(15, 123, 255, 0.88));
}

.tl-sim-client-card {
  position: relative;
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  align-items: center;
  gap: 14px;
  padding: 14px 16px;
  border-radius: 20px;
  border: 1px solid rgba(18, 24, 38, 0.08);
  background:
    linear-gradient(150deg, rgba(255, 255, 255, 0.96), rgba(255, 255, 255, 0.78)),
    radial-gradient(circle at top right, rgba(0, 179, 222, 0.08), transparent 44%);
  overflow: hidden;
  box-shadow: 0 20px 36px -30px rgba(18, 28, 44, 0.24);
  transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
}

.tl-sim-client-card::before {
  content: "";
  position: absolute;
  inset: 0 auto auto 0;
  width: 100%;
  height: 4px;
  background: linear-gradient(90deg, rgba(0, 179, 222, 0.84), rgba(15, 123, 255, 0.88));
}

.tl-sim-client-card:hover {
  transform: translateY(-3px);
  border-color: rgba(0, 179, 222, 0.2);
  box-shadow: 0 26px 40px -30px rgba(9, 23, 46, 0.3);
}

.tl-sim-client-card.is-active {
  border-color: rgba(15, 123, 255, 0.3);
  box-shadow: 0 26px 48px -32px rgba(15, 123, 255, 0.3);
}

.tl-sim-client-card__top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.tl-sim-client-card__main,
.tl-sim-client-card__person-body {
  display: grid;
  gap: 6px;
  min-width: 0;
}

.tl-sim-client-card__person {
  display: flex;
  align-items: center;
  gap: 10px;
  min-width: 0;
}

.tl-sim-client-card__avatar {
  width: 44px;
  height: 44px;
  min-width: 44px;
  border-radius: 16px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-weight: 800;
  font-size: 0.92rem;
  background: linear-gradient(135deg, #00b3de, #0f7bff);
  box-shadow: 0 16px 26px -20px rgba(15, 123, 255, 0.86);
}

.tl-sim-client-card__title {
  margin: 0;
  font-size: 1rem;
  font-weight: 800;
  line-height: 1.08;
}

.tl-sim-client-card__sub {
  color: rgba(42, 50, 66, 0.7);
  font-size: 0.82rem;
  font-weight: 600;
  line-height: 1.35;
  overflow-wrap: anywhere;
}

.tl-sim-client-card__actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  min-width: 148px;
}

.tl-sim-client-card__actions .tl-imoveis-btn {
  min-width: 132px;
  justify-content: center;
}

.tl-sim-client-card__pill,
.tl-sim-seat__meta span,
.tl-sim-seat__tags span {
  display: inline-flex;
  align-items: center;
  min-height: 30px;
  padding: 0 10px;
  border-radius: 999px;
  background: rgba(248, 250, 252, 0.9);
  border: 1px solid rgba(18, 24, 38, 0.06);
  color: rgba(42, 50, 66, 0.76);
  font-size: 0.8rem;
  font-weight: 700;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
}

.tl-sim-selected {
  min-height: 0;
}

.tl-sim-seat {
  display: grid;
  gap: 10px;
}

.tl-sim-seat__card,
.tl-sim-seat__stats {
  display: grid;
  gap: 10px;
  padding: 16px;
  border-radius: 20px;
  border: 1px solid rgba(18, 24, 38, 0.07);
  background:
    linear-gradient(145deg, rgba(255, 255, 255, 0.94), rgba(255, 255, 255, 0.72)),
    radial-gradient(circle at top left, rgba(0, 179, 222, 0.08), transparent 50%);
}

.tl-sim-seat__card--summary {
  gap: 14px;
}

.tl-sim-seat__identity {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  min-width: 0;
}

.tl-sim-seat__identity-copy {
  display: grid;
  gap: 6px;
  min-width: 0;
}

.tl-sim-seat__avatar {
  width: 56px;
  height: 56px;
  min-width: 56px;
  border-radius: 18px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-weight: 800;
  font-size: 1rem;
  background: linear-gradient(135deg, #00b3de, #0f7bff);
  box-shadow: 0 18px 28px -22px rgba(15, 123, 255, 0.78);
}

.tl-sim-seat__eyebrow {
  font-size: 0.72rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: rgba(42, 50, 66, 0.56);
  font-weight: 800;
}

.tl-sim-seat__title {
  margin: 0;
  font-size: 1.18rem;
  font-weight: 900;
  line-height: 1.05;
}

.tl-sim-seat__line {
  margin: 2px 0 0;
  color: rgba(42, 50, 66, 0.72);
  font-size: 0.9rem;
  font-weight: 600;
  line-height: 1.45;
  overflow-wrap: anywhere;
}

.tl-sim-seat__meta,
.tl-sim-seat__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  min-width: 0;
}

.tl-sim-seat__stats {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.tl-sim-seat__empty {
  display: grid;
  place-items: center;
  min-height: 92px;
  padding: 16px;
  border-radius: 18px;
  border: 1px dashed rgba(18, 24, 38, 0.18);
  background: rgba(255, 255, 255, 0.74);
  color: rgba(42, 50, 66, 0.62);
  text-align: center;
}

.tl-sim-seat__card--reservas {
  gap: 12px;
}

.tl-sim-seat__reservas-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 10px;
}

.tl-sim-seat__reserva-card {
  display: grid;
  gap: 10px;
  padding: 14px;
  border-radius: 18px;
  border: 1px solid rgba(18, 24, 38, 0.06);
  background:
    linear-gradient(145deg, rgba(255, 255, 255, 0.94), rgba(255, 255, 255, 0.72)),
    radial-gradient(circle at top right, rgba(0, 179, 222, 0.08), transparent 48%);
}

.tl-sim-seat__reserva-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 10px;
}

.tl-sim-seat__reserva-head h5 {
  margin: 4px 0 0;
  font-size: 0.98rem;
  line-height: 1.12;
}

.tl-sim-seat__reserva-card p {
  margin: 0;
  color: rgba(42, 50, 66, 0.7);
  font-size: 0.84rem;
  line-height: 1.42;
}

.tl-sim-seat__reserva-note {
  color: rgba(42, 50, 66, 0.68);
  font-size: 0.78rem;
  line-height: 1.4;
}

.tl-sim-seat__reserva-card .tl-sim-item__actions {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(148px, 1fr));
  gap: 8px;
}

.tl-sim-seat__reserva-card .tl-sim-item__actions .tl-imoveis-btn {
  width: 100%;
  justify-content: center;
}

.tl-sim-complementos-strip {
  display: grid;
  gap: 12px;
}

.tl-sim-composition {
  display: grid;
  gap: 12px;
  padding: 14px;
  border-radius: 20px;
  border: 1px solid rgba(18, 24, 38, 0.06);
  background: rgba(255, 255, 255, 0.54);
}

.tl-sim-composition__head {
  display: grid;
  gap: 10px;
}

.tl-sim-complementos-summary {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.tl-sim-complementos-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
  gap: 10px;
}

@media (max-width: 1460px) {
  .tl-sim-client-hub__head-actions {
    justify-content: flex-start;
  }

  .tl-sim-client-hub__head-actions .tl-imoveis-btn {
    min-width: min(100%, 220px);
  }
}

.tl-sim-complemento-pill {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  min-height: 36px;
  padding: 0 12px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.86);
  border: 1px solid rgba(18, 24, 38, 0.08);
  color: rgba(18, 24, 38, 0.82);
  font-size: 0.82rem;
  font-weight: 700;
}

.tl-sim-complemento-pill small {
  color: rgba(42, 50, 66, 0.62);
  font-weight: 600;
}

.tl-sim-ajuste {
  display: grid;
  gap: 10px;
  align-content: start;
  height: 100%;
  padding: 14px;
  border-radius: 18px;
  border: 1px solid rgba(18, 24, 38, 0.08);
  background:
    linear-gradient(145deg, rgba(255, 255, 255, 0.9), rgba(255, 255, 255, 0.76)),
    radial-gradient(circle at top left, rgba(0, 179, 222, 0.06), transparent 60%);
}

.tl-sim-ajuste__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  flex-wrap: wrap;
}

.tl-sim-ajuste strong {
  color: rgba(18, 24, 38, 0.94);
  font-size: 1.02rem;
  line-height: 1.2;
}

.tl-sim-ajuste p {
  margin: 0;
  color: rgba(42, 50, 66, 0.78);
  font-size: 0.92rem;
  line-height: 1.42;
}

.tl-sim-vitrine__toolbar {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(240px, 320px);
  gap: 12px;
  align-items: center;
}

.tl-sim-mode-switch {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.tl-sim-mode-switch button {
  border: 0;
  min-height: 40px;
  padding: 0 14px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.76);
  color: rgba(42, 50, 66, 0.74);
  font-weight: 700;
  cursor: pointer;
  box-shadow: inset 0 0 0 1px rgba(18, 24, 38, 0.08);
  transition: transform 0.2s ease, background 0.2s ease, color 0.2s ease, box-shadow 0.2s ease;
}

.tl-sim-mode-switch button:hover {
  transform: translateY(-1px);
}

.tl-sim-mode-switch button.is-active {
  background: linear-gradient(135deg, #00b3de, #0f7bff);
  color: #fff;
  box-shadow: 0 16px 26px -22px rgba(15, 123, 255, 0.86);
}

.tl-sim-vitrine__summary {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  align-items: center;
  color: rgba(42, 50, 66, 0.68);
  font-size: 0.9rem;
}

.tl-sim-vitrine__summary strong {
  color: rgba(18, 24, 38, 0.92);
}

.tl-sim-advanced {
  border-radius: 20px;
  border: 1px solid rgba(18, 24, 38, 0.08);
  background: rgba(248, 250, 252, 0.7);
  overflow: hidden;
}

.tl-sim-advanced summary {
  list-style: none;
  cursor: pointer;
  padding: 14px 16px;
  font-weight: 700;
  color: rgba(18, 24, 38, 0.82);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.tl-sim-advanced summary::-webkit-details-marker {
  display: none;
}

.tl-sim-advanced summary::after {
  content: "";
  width: 8px;
  height: 8px;
  border-right: 2px solid rgba(18, 24, 38, 0.52);
  border-bottom: 2px solid rgba(18, 24, 38, 0.52);
  transform: rotate(45deg);
  transition: transform 0.2s ease;
}

.tl-sim-advanced[open] summary::after {
  transform: rotate(225deg);
}

.tl-sim-advanced .tl-sim-grid-fields {
  padding: 0 16px 16px;
}

.tl-sim-grid-fields {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 12px;
}

.tl-sim-grid-fields--proposal {
  grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
}

.tl-sim-grid-fields--parametros {
  grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
}

.tl-sim-field--full {
  grid-column: 1 / -1;
}

.tl-sim-sugestoes {
  --sim-sugestao-card-height: 252px;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  grid-auto-rows: var(--sim-sugestao-card-height);
  gap: 12px;
  max-height: calc((var(--sim-sugestao-card-height) * 2) + 12px);
  overflow-y: auto;
  padding-right: 6px;
  align-content: start;
}

.tl-sim-sugestao-card {
  position: relative;
  display: grid;
  grid-template-rows: auto auto auto auto;
  gap: 6px;
  padding: 10px;
  border-radius: 24px;
  border: 1px solid rgba(18, 24, 38, 0.08);
  background:
    linear-gradient(145deg, rgba(255, 255, 255, 0.96), rgba(255, 255, 255, 0.74)),
    radial-gradient(circle at top right, rgba(0, 179, 222, 0.12), transparent 48%);
  overflow: hidden;
  box-shadow: 0 22px 36px -30px rgba(18, 28, 44, 0.24);
  align-content: start;
  height: var(--sim-sugestao-card-height);
}

.tl-sim-sugestao-card.is-selected {
  border-color: rgba(16, 185, 129, 0.72);
  background:
    linear-gradient(145deg, rgba(255, 255, 255, 0.98), rgba(241, 253, 247, 0.86)),
    radial-gradient(circle at top right, rgba(16, 185, 129, 0.18), transparent 50%);
  box-shadow:
    0 28px 52px -34px rgba(5, 150, 105, 0.52),
    inset 0 0 0 1px rgba(16, 185, 129, 0.22);
}

.tl-sim-sugestao-card.is-selected .tl-sim-sugestao-card__actions .tl-imoveis-btn:first-child {
  border-color: rgba(5, 150, 105, 0.9);
  background: linear-gradient(135deg, #10b981, #059669);
  color: #fff;
  box-shadow: 0 12px 24px -16px rgba(5, 150, 105, 0.95);
}

.tl-sim-sugestao-card__media {
  display: grid;
  grid-template-columns: 68px minmax(0, 1fr);
  gap: 8px;
  align-items: start;
}

.tl-sim-sugestao-card__image {
  width: 68px;
  height: 68px;
  border-radius: 14px;
  object-fit: cover;
  border: 1px solid rgba(18, 24, 38, 0.1);
  background: rgba(255, 255, 255, 0.7);
}

.tl-sim-sugestao-card__placeholder {
  width: 68px;
  height: 68px;
  border-radius: 14px;
  display: grid;
  place-items: center;
  text-align: center;
  padding: 6px;
  border: 1px dashed rgba(18, 24, 38, 0.16);
  background: rgba(248, 250, 252, 0.84);
  color: rgba(42, 50, 66, 0.6);
  font-size: 0.68rem;
  font-weight: 700;
}

.tl-sim-sugestao-card__body {
  display: grid;
  gap: 3px;
  align-content: start;
  min-width: 0;
}

.tl-sim-sugestao-card__title {
  margin: 0;
  font-size: 0.88rem;
  font-weight: 900;
  line-height: 1.06;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.tl-sim-sugestao-card__subtitle {
  color: rgba(42, 50, 66, 0.68);
  font-size: 0.74rem;
  font-weight: 600;
  line-height: 1.16;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  white-space: normal;
  overflow: hidden;
  overflow-wrap: anywhere;
}

.tl-sim-sugestao-card__summary {
  margin: 0;
  color: rgba(42, 50, 66, 0.72);
  font-size: 0.72rem;
  line-height: 1.16;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  white-space: normal;
  overflow: hidden;
  overflow-wrap: anywhere;
}

.tl-sim-badge-row,
.tl-sim-facts,
.tl-sim-metrics {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
}

.tl-sim-fact,
.tl-sim-metric {
  display: inline-flex;
  align-items: center;
  min-height: 24px;
  padding: 0 7px;
  border-radius: 999px;
  background: rgba(12, 22, 38, 0.06);
