        "key": chave,
        "nome": nome,
        "nivel": nivel,
        "pessoas": pessoas,
        "tempo_casa_meses": round(tempo_medio, 1) if tempo_medio is not None else None,
        "tempo_casa_label": _tempo_casa_label_dashboard_gc(tempo_medio),
