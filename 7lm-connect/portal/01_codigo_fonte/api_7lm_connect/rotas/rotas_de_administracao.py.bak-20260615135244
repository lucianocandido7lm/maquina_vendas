                for mes_ref in metricas_corretor:
                    denominadores_por_mes.setdefault(mes_ref, 1.0)
            metricas_corretor_consolidado = metricas_por_corretor_consolidado.get(chave_metricas) or {}
            if metricas_corretor_consolidado:
