    conexao,
    identificador_usuario: str,
    nomes_permissao: tuple[str, ...],
) -> bool:
    linha = await conexao.fetchrow(
        """
        select bool_or(
            coalesce(
                sevenlm_connect.fn_usuario_tem_permissao($1::uuid, permissao.nome_permissao),
