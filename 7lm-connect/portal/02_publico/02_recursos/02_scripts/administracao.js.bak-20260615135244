  function renderEquipeFocosPlanejados(rows = []) {
    const focos = normalizarFocoPlanejado(rows);
    const list = focos.length ? focos : [{ foco: "", quantidade: "" }];
    return list.map(renderEquipeFocoPlanejadoRow).join("");
  }

  function readEquipeFocoPlanejado() {
    return [...document.querySelectorAll("[data-equipe-foco-row]")].map((row) => {
      const foco = (row.querySelector("[data-equipe-foco-nome]")?.value || "").trim();
      const quantidade = parseNonNegativeInteger(row.querySelector("[data-equipe-foco-quantidade]")?.value);
      return foco ? { foco, quantidade } : null;
    }).filter(Boolean);
  }

  function syncEquipePlanejamentoResumo(scope = document) {
    const wrapper = scope.querySelector("[data-equipe-planejamento-resumo]");
    if (!wrapper) return;
    const hc = parseNonNegativeInteger(scope.querySelector("#modalEquipeHcPlanejado")?.value);
    const focos = readEquipeFocoPlanejado();
    const total = totalFocoPlanejado(focos);
    const restante = Math.max(0, hc - total);
    wrapper.classList.toggle("is-over", total > hc && hc > 0);
    wrapper.textContent = hc
      ? `${total} de ${hc} alocados nos focos${total > hc ? " - ajuste a distribuição" : restante ? ` - ${restante} restante(s)` : " - completo"}`
      : (focos.length ? `${focos.length} foco(s) cadastrado(s) sem HC planejado` : `${total} alocado(s) nos focos`);
  }

  function toggleEquipePlanejamentoFields(scope = document) {
    scope.querySelectorAll("[data-equipe-planejamento]").forEach((node) => {
      node.hidden = false;
