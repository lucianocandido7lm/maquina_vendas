  async function searchUsers(allowEmpty = false) {
    const query = (el.inputBuscaUsuario?.value || "").trim();

    if (!query && !allowEmpty) {
      renderEmpty(
        el.caixaResultadosBusca,
        "⌨️",
        "Digite um critério",
        "Informe nome, e-mail, matrícula ou identificador para iniciar a busca."
      );
      return;
    }

    const url = query
      ? `${ENDPOINT_BUSCA_USUARIOS}?q=${encodeURIComponent(query)}`
      : ENDPOINT_BUSCA_USUARIOS;

    const res = await apiFetch(url, { method: "GET" });

    if (handleAuthOrPermission(res, "Não foi possível validar sua sessão para consultar usuários.")) {
      renderEmpty(
        el.caixaResultadosBusca,
        "🔒",
        res.unauthorized ? "Sessão expirada" : "Sem permissão",
        res.unauthorized
          ? "Sua sessão precisa ser renovada para continuar."
          : "Você não possui permissão para consultar usuários na Administração."
      );
      return;
    }

    if (!res.ok) {
      console.warn("[ADMIN] busca de usuários falhou:", res.status, res.payload);
      renderEmpty(
        el.caixaResultadosBusca,
        "🧩",
        "Busca indisponível",
        "A busca não respondeu pela API. Verifique rota, proxy e console."
      );
      return;
    }

    const items = res.payload?.items || res.payload?.usuarios || res.payload?.data || [];
    state.searchResults = Array.isArray(items) ? items : [];
    renderSearchResults(state.searchResults);
  }

  async function loadUserDetail(key) {
    const url = replacePathParam(ENDPOINT_USUARIO_DETALHE, "chave", key);
    const res = await apiFetch(url, { method: "GET" });

    if (handleAuthOrPermission(res, "Não foi possível validar sua sessão para carregar o detalhe do usuário.")) {
      return;
    }

    if (!res.ok) {
      console.warn("[ADMIN] detalhe do usuário falhou:", res.status, res.payload, url);
      alert(extractErrorMessage(res.payload, "Não foi possível carregar o detalhe do usuário."));
      return;
    }

    state.selectedLookupKey = key;
    const detail = res.payload?.data || res.payload || {};
    if (detail["usuário"] && !detail.usuario) {
      detail.usuario = detail["usuário"];
    }
    state.selectedUser = detail;

    renderSelectedUser();

    if (Array.isArray(state.searchResults) && state.searchResults.length) {
      renderSearchResults(state.searchResults);
    }
