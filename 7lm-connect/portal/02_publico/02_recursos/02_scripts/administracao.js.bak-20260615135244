    const res = await apiFetch(url, { method: "POST" });

    if (handleAuthOrPermission(res, "Não foi possível validar sua sessão para resetar o MFA.")) {
      return;
    }

    if (!res.ok) {
      alert(extractErrorMessage(res.payload, "Não foi possível resetar o MFA."));
      return;
    }

    await reloadSelectedUserAndAudit();
  }

  async function executeUserAction(endpointTemplate, confirmText, successFallback) {
    if (!requireManagePermission()) return;
    if (!requireProvisionedUser()) return;
    if (confirmText && !confirm(confirmText)) return;

    const key = getSelectedUserKey();
    const url = replacePathParam(endpointTemplate, "chave", key);

    const res = await apiFetch(url, { method: "POST" });

    if (handleAuthOrPermission(res, "Não foi possível validar sua sessão para esta operação.")) {
      return;
    }

    if (!res.ok) {
      alert(extractErrorMessage(res.payload, successFallback));
      return;
    }

    await reloadSelectedUserAndAudit();
  }

