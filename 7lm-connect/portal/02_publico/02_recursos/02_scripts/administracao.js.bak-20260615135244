    ];

    el.painelIndicadoresAlvo.innerHTML = chips.map((chip) => {
      const klass = chip.kind === "success"
        ? "tl-pill-success"
        : chip.kind === "danger"
          ? "tl-pill-danger"
          : "tl-pill-neutral";

      return `<span class="${klass}">${escapeHtml(chip.label)}</span>`;
