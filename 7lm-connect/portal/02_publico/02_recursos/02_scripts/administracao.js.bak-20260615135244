  function renderInlineFilter(label, attrs = {}, extraClass = "") {
    const text = String(label || "").trim();
    if (!text) return "-";
    const attrText = Object.entries(attrs)
      .filter(([, value]) => value !== undefined && value !== null && String(value).trim())
      .map(([key, value]) => `${key}="${escapeHtml(value)}"`)
      .join(" ");
    return `<button type="button" class="tl-inline-filter ${extraClass}" ${attrText}>${escapeHtml(formatarTextoVisivel(text))}</button>`;
  }

  const FUNCIONARIO_HIERARQUIA_EQUIPE_NIVEIS = [
    ["Gerente de Vendas", "gerente_vendas"],
    ["Gerente Comercial", "gerente_comercial"],
    ["Gerente Regional", "gerente_regional"],
    ["Head Comercial", "head_comercial"],
    ["Diretor Comercial", "diretor_comercial"]
  ];

  function uniqueFuncionarioTextValues(values = []) {
    const seen = new Set();
    return values.map((value) => String(value || "").trim()).filter((value) => {
      if (!value) return false;
      const key = normalizeOptionText(value);
      if (seen.has(key)) return false;
      seen.add(key);
      return true;
    });
  }

  function getFuncionarioEquipeDireta(item = {}, dataReferencia = "") {
    const equipeAtual = item.imobiliaria || item.equipe_vigencia_nome || item.equipe || "";
    return getEquipeFuncionarioByIdOrName(
      item.identificador_equipe_vigencia || equipeAtual,
      dataReferencia || item.data_inicio_vigencia || item.equipe_data_inicio_vigencia || todayIsoDate()
    );
  }

  function getFuncionarioEquipesComoLider(item = {}, dataReferencia = "") {
    const nomeKey = normalizeOptionText(getFuncionarioNomeCadastro(item));
    if (!nomeKey) return [];

    const data = dataReferencia || item.data_inicio_vigencia || item.equipe_data_inicio_vigencia || todayIsoDate();
    const matches = [];
    getEquipesFuncionariosCatalogo().map(normalizarEquipeFuncionario).forEach((equipe) => {
      FUNCIONARIO_HIERARQUIA_EQUIPE_NIVEIS.forEach(([label, field], index) => {
        if (normalizeOptionText(equipe[field]) !== nomeKey) return;
        matches.push({ equipe, label, field, index });
      });
    });

    const vigentes = matches.filter(({ equipe }) => isEquipeVigenteNaData(equipe, data));
    return vigentes.length ? vigentes : matches;
  }

  function getFuncionarioNivelNaEquipe(item = {}, equipes = []) {
    const nomeKey = normalizeOptionText(getFuncionarioNomeCadastro(item));
    if (!nomeKey) return -1;
    const indices = [];
    equipes.forEach((equipe) => {
      const normalizada = normalizarEquipeFuncionario(equipe);
      FUNCIONARIO_HIERARQUIA_EQUIPE_NIVEIS.forEach(([, field], index) => {
        if (normalizeOptionText(normalizada[field]) === nomeKey) indices.push(index);
      });
    });
    return indices.length ? Math.min(...indices) : -1;
  }

  function getFuncionarioEquipeHierarquia(item = {}) {
    const dataReferencia = item.data_inicio_vigencia || item.equipe_data_inicio_vigencia || todayIsoDate();
    const equipeDireta = getFuncionarioEquipeDireta(item, dataReferencia);
    const liderancas = equipeDireta ? [] : getFuncionarioEquipesComoLider(item, dataReferencia);
    const equipes = equipeDireta ? [equipeDireta] : liderancas.map(({ equipe }) => equipe);
    const nivelPessoa = getFuncionarioNivelNaEquipe(item, equipes);

    if (!equipes.length) {
      const equipe = normalizarEquipeFuncionario(item);
      return FUNCIONARIO_HIERARQUIA_EQUIPE_NIVEIS
        .map(([label, field]) => ({
          label,
          value: String(equipe[field] || "").trim()
        }))
        .filter((nivel) => nivel.value);
    }

    return FUNCIONARIO_HIERARQUIA_EQUIPE_NIVEIS
      .map(([label, field], index) => {
        if (nivelPessoa >= 0 && index <= nivelPessoa) return null;
        const values = uniqueFuncionarioTextValues(equipes.map((equipe) => normalizarEquipeFuncionario(equipe)[field]));
        return values.length ? { label, values, value: values.join(", ") } : null;
      })
      .filter(Boolean)
      .filter((nivel) => nivel.value);
  }

  function renderFuncionarioHierarquiaNivel(nivel, extraClass = "") {
    const values = Array.isArray(nivel?.values) && nivel.values.length ? nivel.values : [nivel?.value || ""];
    const valueHtml = uniqueFuncionarioTextValues(values).map((value) => {
      const isVago = normalizeOptionText(value) === "vago";
      const valueDisplay = formatarTextoVisivel(value);
      return isVago
        ? escapeHtml(valueDisplay)
        : renderInlineFilter(valueDisplay, {
          "data-funcionario-filter": "gestor",
          "data-funcionario-filter-value": value,
          title: `Filtrar Pessoas Por ${formatarTextoVisivel(nivel.label)}: ${valueDisplay}`
        }, extraClass);
    }).join(", ");
    if (!valueHtml) return "";
    return `${escapeHtml(nivel.label)}: ${valueHtml}`;
  }

  function renderFuncionarioLiderancaLinks(item = {}) {
    const niveis = getFuncionarioEquipeHierarquia(item);
    const principal = niveis[0];
    const secundarios = niveis.slice(1);
    const titulo = niveis.map((nivel) => `${nivel.label}: ${nivel.value}`).join(" • ");

    return {
      principal: principal ? renderFuncionarioHierarquiaNivel(principal) : "-",
      secundario: secundarios.length
        ? secundarios.map((nivel) => renderFuncionarioHierarquiaNivel(nivel, "tl-inline-filter--secondary")).join(" • ")
        : "-",
      title: titulo || "-"
    };
  }

  function getFuncionarioRegiaoFuncao(item = {}) {
    const equipeAtual = item.imobiliaria || item.equipe_vigencia_nome || item.equipe || "";
    const equipeDetalhe = getEquipeFuncionarioByIdOrName(
      item.identificador_equipe_vigencia || equipeAtual,
      todayIsoDate()
    );
    const equipe = normalizarEquipeFuncionario(equipeDetalhe || item);
    const regiao = equipe.regiao || item.regiao || item.regional || item.equipe_vigencia_regiao || "";
    const funcao = item.cargo || item.funcao || item.funcao_cargo || "";

    return {
      regiao: regiao || "-",
      funcao: funcao || "-"
    };
  }

  function applyFuncionarioInlineFilter(filter, value) {
    const valor = String(value || "").trim();
    if (!valor) return;

    if (filter === "equipe") {
      if (el.selectFuncionarioImobiliaria && isFuncionarioImobiliariaPermitida(valor)) {
        el.selectFuncionarioImobiliaria.value = valor;
