  function renderFuncionariosSummary(items) {
    if (!el.resumoFuncionarios) return;
    const lista = Array.isArray(items) ? items : [];
    const total = lista.length;
    const ativos = lista.filter((item) => funcionarioCadastroStatus(item, getQuadroItemByFuncionarioId(item.identificador_funcionario)) === "ATIVO").length;
