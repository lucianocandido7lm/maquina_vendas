  async function safeJson(response) {
    try {
      const contentType = (response.headers.get("content-type") || "").toLowerCase();
      const text = await response.text().catch(() => "");

      if (!text) return {};

      if (contentType.includes("application/json")) {
        try {
          return JSON.parse(text);
        } catch {
          return {
            detail: "Resposta JSON inválida recebida da API.",
            raw_text: text
          };
        }
      }

      return {
        detail: text.length > 300 ? `${text.slice(0, 300)}...` : text,
        raw_text: text,
        content_type: contentType
      };
    } catch {
      return {};
    }
  }

  async function apiFetch(url, options = {}) {
    const token = getAccessToken();
    const method = String(options.method || "GET").toUpperCase();
    const candidates = buildApiCandidates(url);

    const headers = {
      "Accept": "application/json",
      ...(options.body ? { "Content-Type": "application/json" } : {}),
      ...(options.headers || {})
    };

    if (token) {
      headers.Authorization = `Bearer ${token}`;
    }

    let lastResult = null;

    for (let i = 0; i < candidates.length; i++) {
      const finalUrl = candidates[i];

      try {
        console.log("[ADMIN API] ->", method, finalUrl, {
          tentativa: i + 1,
          total_tentativas: candidates.length,
          api_base_url: API_BASE_URL
        });

        const response = await fetch(finalUrl, {
          cache: "no-store",
          credentials: getFetchCredentials(finalUrl),
          ...options,
          headers
        });

        const payload = await safeJson(response);

        const result = {
          ok: response.ok,
          status: response.status,
          payload,
          unauthorized: response.status === 401,
          forbidden: response.status === 403,
          network_error: false,
          final_url: finalUrl
        };

        console.log("[ADMIN API] <-", response.status, finalUrl, payload);

        lastResult = result;

        if (response.status === 404 && i < candidates.length - 1) {
          console.warn("[ADMIN API] 404, tentando próxima rota candidata:", finalUrl);
          continue;
        }

        return result;
      } catch (error) {
        console.error("[ADMIN API] ERRO DE REDE:", finalUrl, error);

        lastResult = {
          ok: false,
          status: 0,
          payload: {
            detail: "Falha de rede, CORS, proxy ou endpoint indisponível."
          },
          unauthorized: false,
          forbidden: false,
          network_error: true,
          final_url: finalUrl
        };

        if (i < candidates.length - 1) {
          console.warn("[ADMIN API] tentando fallback após erro de rede...");
          continue;
        }

        return lastResult;
      }
    }

    return lastResult || {
      ok: false,
      status: 0,
      payload: {
        detail: "Nenhuma rota candidata pôde ser utilizada."
      },
      unauthorized: false,
      forbidden: false,
      network_error: true
    };
  }

  function extractErrorMessage(payload, fallback = "Não foi possível concluir a operação.") {
    return (
      payload?.mensagem ||
      payload?.detail ||
      payload?.erro ||
      payload?.error ||
      fallback
    );
  }

  function escapeHtml(value) {
    return String(value ?? "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#039;");
  }

  function replacePathParam(url, key, value) {
    return url.replace(`{${key}}`, encodeURIComponent(String(value)));
  }

  function escapeCssSelectorValue(value) {
    const text = String(value || "");
    if (window.CSS?.escape) {
      return window.CSS.escape(text);
    }
    return text.replace(/["\\]/g, "\\$&");
  }

  function normalizeOptionText(value) {
    return String(value || "")
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "")
      .trim()
      .toLowerCase();
  }

  function sortOptionValues(values) {
    return uniqueStrings((values || [])
      .map((value) => String(value || "").trim())
      .filter(Boolean))
      .sort((a, b) => a.localeCompare(b, "pt-BR", { sensitivity: "base" }));
  }

  function appendSelectedOption(values, selected) {
    const selectedText = String(selected || "").trim();
    const list = Array.isArray(values) ? [...values] : [];
    if (selectedText && !list.some((value) => normalizeOptionText(value) === normalizeOptionText(selectedText))) {
      list.push(selectedText);
    }
    return sortOptionValues(list);
  }

  function renderSelectOptions(values, selected = "", emptyLabel = "Selecione") {
    const selectedText = String(selected || "").trim();
    const options = appendSelectedOption(values, selectedText);
    return [
      `<option value="">${escapeHtml(emptyLabel)}</option>`,
      ...options.map((value) => {
        const isSelected = normalizeOptionText(value) === normalizeOptionText(selectedText);
        return `<option value="${escapeHtml(value)}" ${isSelected ? "selected" : ""}>${escapeHtml(value)}</option>`;
      })
    ].join("");
  }

  function isUuidLike(value) {
    return /^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/i.test(String(value || ""));
  }

  function parseNonNegativeInteger(value) {
    if (value === null || value === undefined || value === "") return 0;
    const number = Number.parseInt(String(value).replace(/[^\d-]/g, ""), 10);
    return Number.isFinite(number) && number > 0 ? number : 0;
  }

  function normalizarFocoPlanejado(value = []) {
    let source = value;
    if (typeof source === "string") {
      try {
        source = JSON.parse(source);
      } catch {
        source = [];
      }
    }
    if (!Array.isArray(source)) return [];
    return source.map((item) => {
      const foco = String(item?.foco || item?.nivel || item?.nome || item?.regiao || "").trim();
      const quantidade = parseNonNegativeInteger(item?.quantidade ?? item?.hc ?? item?.vagas);
      return foco ? { foco, quantidade } : null;
    }).filter(Boolean);
  }

  function totalFocoPlanejado(rows = []) {
    return normalizarFocoPlanejado(rows).reduce((sum, row) => sum + parseNonNegativeInteger(row.quantidade), 0);
  }

  function normalizarEquipeFuncionario(item = {}) {
    const equipe = item.equipe || item.imobiliaria || item.equipe_vigencia_nome || "";
    return {
      ...item,
      identificador_equipe_vigencia: item.identificador_equipe_vigencia || item.id || "",
      equipe,
      regiao: item.regiao || item.regional || item.equipe_vigencia_regiao || "",
      gerente_vendas: item.gerente_vendas || item.gestor || item.equipe_gerente_vendas || "",
      gerente_comercial: item.gerente_comercial || item.coordenador || item.equipe_gerente_comercial || "",
      gerente_regional: item.gerente_regional || item.gerente || item.equipe_gerente_regional || "",
      head_comercial: item.head_comercial || item.equipe_head_comercial || "",
      diretor_comercial: item.diretor_comercial || item.diretor || item.equipe_diretor_comercial || "",
      data_inicio_vigencia: item.data_inicio_vigencia || item.equipe_data_inicio_vigencia || "",
      data_fim_vigencia: item.data_fim_vigencia || item.equipe_data_fim_vigencia || "",
      status_equipe: item.status_equipe || item.equipe_status || "ATIVO",
      ativo: item.ativo !== false,
      hc_planejado: parseNonNegativeInteger(item.hc_planejado ?? item.equipe_hc_planejado ?? 0),
      foco_planejado: normalizarFocoPlanejado(item.foco_planejado || item.equipe_foco_planejado || [])
    };
  }

  function equipeFuncionarioStatusKey(item = {}) {
    const equipe = normalizarEquipeFuncionario(item);
    if (equipe.ativo === false) return "INATIVO";
    const status = String(equipe.status_equipe || "").trim().toUpperCase();
    if (status === "PLANEJADA" || status === "PLANEJADO" || status === "PLANEJAMENTO") return "PLANEJADA";
    if (status === "INATIVO" || status === "INATIVA" || status === "ENCERRADO" || status === "ENCERRADA") return "INATIVO";
    return "ATIVO";
  }

  function isEquipePlanejada(item = {}) {
    return equipeFuncionarioStatusKey(item) === "PLANEJADA";
  }

  function equipeFuncionarioStatusLabel(item = {}) {
    const status = equipeFuncionarioStatusKey(item);
    if (status === "PLANEJADA") return "Planejada";
    return status === "ATIVO" ? "Ativo" : "Inativo";
  }

  function equipeFuncionarioStatusChipClass(item = {}) {
    const status = equipeFuncionarioStatusKey(item);
    if (status === "PLANEJADA") return "is-warn";
    return status === "ATIVO" ? "is-ok" : "is-neutral";
  }

  function renderEquipeFocoPlanejadoRow(item = {}, index = 0) {
    const foco = item.foco || "";
    const quantidade = parseNonNegativeInteger(item.quantidade);
    const quantidadeValue = foco || quantidade ? quantidade : "";
    return `
      <div class="tl-equipe-plan-row" data-equipe-foco-row>
        <div class="tl-form-group">
          <label>Foco</label>
          <input type="text" value="${escapeHtml(foco)}" placeholder="Selecione o foco" list="modalEquipeFocoPlanejadoOptions" data-equipe-foco-nome />
        </div>
        <div class="tl-form-group">
          <label>Corretores</label>
          <input type="number" min="0" step="1" value="${quantidadeValue}" placeholder="0" data-equipe-foco-quantidade />
        </div>
        <button type="button" class="tl-equipe-plan-row__remove" data-remove-equipe-foco="${index}" aria-label="Remover foco planejado">Remover</button>
      </div>
    `;
