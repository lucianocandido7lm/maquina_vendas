  function getFuncionarioCargoRegraEquipe(value) {
    const cargo = normalizeOptionText(value);
    if (!cargo) return "";
    if (cargo.includes("diretor")) return "DIRETOR_COMERCIAL";
    if (cargo.includes("head")) return "HEAD_COMERCIAL";
    if (cargo.includes("corretor")) return "CORRETOR";
    if (cargo.includes("coordenador")) return "COORDENADOR";
    if (cargo.includes("gerente regional")) return "GERENTE_REGIONAL";
    if (cargo.includes("gerente")) return "GERENTE";
    return "";
  }

  function isFuncionarioEquipeObrigatoriaPorCargo(cargo, status) {
    if (normalizeFuncionarioCadastroStatus(status) === "AFASTADO") return false;
    return ["CORRETOR", "COORDENADOR"].includes(getFuncionarioCargoRegraEquipe(cargo));
  }

  function applyFuncionarioCargoLiderancaAutofill(container = document) {
    const scope = container || document;
    if (normalizeFuncionarioCadastroStatus(scope.querySelector("#modalFuncionarioAtivo")?.value || "ATIVO") === "AFASTADO") return;

    const regra = getFuncionarioCargoRegraEquipe(scope.querySelector("#modalFuncionarioCargo")?.value || "");
    const nome = (scope.querySelector("#modalFuncionarioNome")?.value || "").trim();
    if (!nome) return;

    const email = (scope.querySelector("#modalFuncionarioEmail")?.value || "").trim();
    const documento = (scope.querySelector("#modalFuncionarioDocumento")?.value || "").replace(/\D/g, "");
    const destinoPorRegra = {
      GERENTE: ["#modalFuncionarioGestor", "#modalFuncionarioGestorEmail", "#modalFuncionarioGestorDocumento"],
      COORDENADOR: ["#modalFuncionarioCoordenador", "#modalFuncionarioCoordenadorEmail", "#modalFuncionarioCoordenadorDocumento"],
      GERENTE_REGIONAL: ["#modalFuncionarioGerente", "#modalFuncionarioGerenteEmail", "#modalFuncionarioGerenteDocumento"]
    };
    const destino = destinoPorRegra[regra];
    if (!destino) return;

    setInputValueAndNotify(scope.querySelector(destino[0]), nome);
    setInputValueAndNotify(scope.querySelector(destino[1]), email);
