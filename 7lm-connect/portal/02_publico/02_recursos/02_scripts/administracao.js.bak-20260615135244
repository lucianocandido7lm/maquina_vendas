  async function saveModal() {
    if (!state.modalMode) {
      closeModal();
      return;
    }

    if (!requireManagePermission()) return;

    if (state.modalMode === "profile") {
      const key = getSelectedUserKey();
      const perfilId = document.getElementById("modalPerfilSelecionado")?.value;
      const observacao = document.getElementById("modalObservacaoPerfil")?.value || "";

      let url = replacePathParam(ENDPOINT_USUARIO_PERFIS, "chave", key);

      const res = await apiFetch(url, {
        method: "POST",
        body: JSON.stringify({
          identificador_perfil: Number(perfilId),
          observacao
        })
      });

      if (handleAuthOrPermission(res, "Não foi possível validar sua sessão para atribuir o perfil.")) {
        return;
      }

      if (!res.ok) {
        alert(extractErrorMessage(res.payload, "Não foi possível atribuir o perfil."));
        return;
      }

      closeModal();
      await reloadSelectedUserAndAudit();
      return;
    }

    if (state.modalMode === "permission") {
      const key = getSelectedUserKey();
      const permissaoId = document.getElementById("modalPermissaoSelecionada")?.value;
      const indicadorPermitido = document.getElementById("modalPermissaoTipo")?.value === "true";
      const origemRegraInput = document.getElementById("modalPermissaoOrigem")?.value || "Manual";
      const origemRegra = String(origemRegraInput).trim().toUpperCase() === "MANUAL" ? "MANUAL" : origemRegraInput;
      const observacao = document.getElementById("modalObservacaoPermissao")?.value || "";

      let url = replacePathParam(ENDPOINT_USUARIO_PERMISSOES, "chave", key);

      const res = await apiFetch(url, {
        method: "POST",
        body: JSON.stringify({
          identificador_permissao: Number(permissaoId),
          indicador_permitido: indicadorPermitido,
          origem_regra: origemRegra,
          observacao
        })
      });

      if (handleAuthOrPermission(res, "Não foi possível validar sua sessão para salvar a permissão.")) {
        return;
      }

      if (!res.ok) {
        alert(extractErrorMessage(res.payload, "Não foi possível salvar a permissão direta."));
        return;
      }

      closeModal();
      await reloadSelectedUserAndAudit();
      return;
    }

    if (state.modalMode === "sector") {
      const setor = document.getElementById("modalSetorSelecionado")?.value;
      const perfilId = document.getElementById("modalSetorPerfilSelecionado")?.value;
      const observacao = document.getElementById("modalObservacaoSetor")?.value || "";

      let url = replacePathParam(ENDPOINT_SETOR_PERFIS, "codigo_setor", setor);

      const res = await apiFetch(url, {
        method: "POST",
        body: JSON.stringify({
          identificador_perfil: Number(perfilId),
          observacao
        })
      });

      if (handleAuthOrPermission(res, "Não foi possível validar sua sessão para atribuir o perfil ao setor.")) {
        return;
      }

      if (!res.ok) {
        alert(extractErrorMessage(res.payload, "Não foi possível atribuir o perfil ao setor."));
        return;
      }

      closeModal();
      await reloadSelectedUserAndAudit();
      return;
    }

    if (state.modalMode === "operational-dashboard") {
      const key = getSelectedUserKey();
      const dashboardId = document.getElementById("modalDashboardOperacionalSelecionado")?.value;
      const observacao = document.getElementById("modalObservacaoDashboardOperacional")?.value || "";

      if (!dashboardId) {
        alert("Selecione um recurso legado para continuar.");
        return;
      }

      let url = replacePathParam(ENDPOINT_USUARIO_DASHBOARDS_OPERACIONAIS, "chave", key);

      const res = await apiFetch(url, {
        method: "POST",
        body: JSON.stringify({
          identificador_dashboard: dashboardId,
          observacao
        })
      });

      if (handleAuthOrPermission(res, "Não foi possível validar sua sessão para liberar o recurso legado.")) {
        return;
      }

      if (!res.ok) {
        alert(extractErrorMessage(res.payload, "Não foi possível liberar o recurso legado."));
        return;
      }

      closeModal();
      await reloadSelectedUserAndAudit();
      return;
    }

    if (state.modalMode === "manual-user-create") {
      const matricula = (document.getElementById("modalExternoMatricula")?.value || "").trim();
      const nomeCompleto = (document.getElementById("modalExternoNome")?.value || "").trim();
      const email = (document.getElementById("modalExternoEmail")?.value || "").trim();
      const senha = (document.getElementById("modalExternoSenha")?.value || "").trim();
      const codigoSetor = (document.getElementById("modalExternoSetor")?.value || "").trim();
      const indicadorAtivo = document.getElementById("modalExternoAtivo")?.value === "true";
      const indicadorPrecisaTrocarSenha = document.getElementById("modalExternoTrocaSenha")?.value === "true";

      if (!nomeCompleto || !email || !senha) {
        alert("Preencha nome completo, e-mail e senha inicial.");
        return;
      }

      const res = await apiFetch(ENDPOINT_CRIAR_USUARIO, {
        method: "POST",
        body: JSON.stringify({
          nome_completo: nomeCompleto,
          correio_eletronico: email,
          senha,
          matricula: matricula || null,
          codigo_setor: codigoSetor || null,
          indicador_ativo: indicadorAtivo,
          indicador_precisa_trocar_senha: indicadorPrecisaTrocarSenha
        })
      });

      if (handleAuthOrPermission(res, "Não foi possível validar sua sessão para criar o usuário.")) {
        return;
      }

      if (!res.ok) {
        alert(extractErrorMessage(res.payload, "Não foi possível criar o usuário."));
        return;
      }

      closeModal();
      await searchUsers(true);
      const key = res.payload?.usuario?.identificador_usuario || matricula;
      await loadUserDetail(key);
      await loadAudit();
      return;
    }

    if (state.modalMode === "manual-user-edit") {
      const key = getSelectedUserKey();
      const nomeCompleto = (document.getElementById("modalProvisionNome")?.value || "").trim();
      const email = (document.getElementById("modalProvisionEmail")?.value || "").trim();
      const matricula = (document.getElementById("modalProvisionMatricula")?.value || "").trim();
      const codigoSetor = (document.getElementById("modalProvisionSetor")?.value || "").trim();
      const indicadorAtivo = document.getElementById("modalProvisionAtivo")?.value === "true";

      if (!key || !nomeCompleto || !email) {
        alert("Preencha nome completo e e-mail para salvar o usuário.");
        return;
      }

      let url = replacePathParam(ENDPOINT_ATUALIZAR_USUARIO, "chave", key);

      const res = await apiFetch(url, {
        method: "PUT",
        body: JSON.stringify({
          nome_completo: nomeCompleto,
          correio_eletronico: email,
          matricula,
          codigo_setor: codigoSetor || null,
          indicador_ativo: indicadorAtivo
        })
      });

      if (handleAuthOrPermission(res, "Não foi possível validar sua sessão para atualizar o usuário.")) {
        return;
      }

      if (!res.ok) {
        alert(extractErrorMessage(res.payload, "Não foi possível atualizar o usuário."));
        return;
      }

      closeModal();
      await searchUsers(true);
      const lookupKey = res.payload?.usuario?.identificador_usuario || key;
      await loadUserDetail(lookupKey);
      await loadAudit();
      return;
    }

    if (state.modalMode === "funcionario-equipe-create" || state.modalMode === "funcionario-equipe-edit") {
      const payload = readEquipeFuncionarioPayload();
      if (!payload.equipe) {
        alert("Preencha o nome da equipe.");
        return;
      }
      if (payload.status_equipe !== "PLANEJADA" && !payload.data_inicio_vigencia) {
        alert("Preencha a data de início para equipes ativas ou inativas.");
        return;
      }
      if (payload.data_inicio_vigencia && payload.data_fim_vigencia && payload.data_fim_vigencia < payload.data_inicio_vigencia) {
        alert("A data final não pode ser anterior à data de início.");
        return;
      }
      const totalPlanejado = totalFocoPlanejado(payload.foco_planejado);
      if (payload.hc_planejado && totalPlanejado > payload.hc_planejado) {
        alert("A soma dos focos planejados não pode ser maior que o HC planejado.");
        return;
      }
      if (
        state.modalMode === "funcionario-equipe-edit" &&
        state.modalPayload?.status_equipe === "PLANEJADA" &&
        payload.status_equipe === "ATIVO" &&
        !window.confirm("Esta equipe estava planejada. Confirma ativar a equipe? Verifique se as pessoas e os focos já estão corretos antes de continuar.")
      ) {
        return;
      }

      const id = state.modalPayload?.id || null;
      const url = id
        ? replacePathParam(ENDPOINT_FUNCIONARIO_EQUIPE_DETALHE, "identificador_equipe_vigencia", id)
        : ENDPOINT_FUNCIONARIO_EQUIPES;
      const res = await apiFetch(url, {
        method: id ? "PUT" : "POST",
        body: JSON.stringify(payload)
      });

      if (handleAuthOrPermission(res, "Não foi possível validar sua sessão para salvar a equipe.")) {
        return;
      }

      if (!res.ok) {
        alert(extractErrorMessage(res.payload, "Não foi possível salvar a equipe."));
        return;
      }

      closeModal();
      await loadEquipesFuncionarios();
      await loadFuncionarios();
      return;
    }

    if (state.modalMode === "funcionario-validacao") {
      if (!canValidateFuncionarios()) {
        alert("Sua sessão não possui permissão para gerenciar perfis de pessoas.");
        return;
      }

      const id = state.modalPayload?.id || null;
      if (!id) {
        alert("Não foi possível identificar a pessoa.");
        return;
      }

      const payload = readFuncionarioValidacaoPayload();
      let url = replacePathParam(ENDPOINT_FUNCIONARIO_VALIDAR, "identificador_funcionario", id);
      const res = await apiFetch(url, {
        method: "POST",
        body: JSON.stringify(payload)
      });

      if (handleAuthOrPermission(res, "Não foi possível validar sua sessão para atualizar a pessoa.")) {
        return;
      }

      if (!res.ok) {
        alert(extractErrorMessage(res.payload, "Não foi possível atualizar a pessoa."));
        return;
      }

      closeModal();
      const recarregamentos = [loadFuncionarios(), loadQuadroDiario()];
      if (!isFuncionariosMode()) recarregamentos.push(loadAudit());
      await Promise.all(recarregamentos);
      return;
    }

    if (state.modalMode === "funcionario-create" || state.modalMode === "funcionario-edit") {
      syncFuncionarioCadastroEquipeRules(el.modalBody || document);
      const payload = readFuncionarioModalPayload();
      const obrigatorios = [
        ["nome", "nome completo"],
        ["documento", "CPF"],
        ["tipo_vinculo", "vínculo"]
      ];
      if (isFuncionarioEquipeObrigatoriaPorCargo(payload.cargo, payload.status_operacional)) {
        obrigatorios.push(["imobiliaria", "equipe"]);
      }
      const faltando = obrigatorios
        .filter(([campo]) => !payload[campo])
        .map(([, rotulo]) => rotulo);

      if (faltando.length) {
        alert(`Preencha os campos obrigatórios: ${faltando.join(", ")}.`);
        return;
      }

      const cpfNumeros = String(payload.documento || "").replace(/\D/g, "");
      if (cpfNumeros.length !== 11) {
        alert("Informe um CPF válido com 11 dígitos.");
        return;
      }

      if (payload.tipo_vinculo === "PJ") {
        const cnpjNumeros = String(payload.cnpj || "").replace(/\D/g, "");
        if (cnpjNumeros.length !== 14) {
          alert("Informe um CNPJ válido com 14 dígitos para pessoa PJ.");
          return;
        }
        if (!payload.nome_empresa) {
          alert("Informe o nome da empresa para pessoa PJ.");
          return;
        }
      }

      if (payload.imobiliaria && !isFuncionarioImobiliariaPermitida(payload.imobiliaria)) {
        alert("Selecione uma equipe imobiliária válida.");
        return;
      }

      if (payload.ativo && payload.ativo_login && !payload.email) {
        alert("Informe um e-mail válido para liberar o login da pessoa.");
        return;
      }

      if (payload.email && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(payload.email)) {
        alert("Informe um e-mail válido para a pessoa.");
        return;
      }

      const id = state.modalPayload?.id || null;
      const url = id
        ? replacePathParam(ENDPOINT_FUNCIONARIO_DETALHE, "identificador_funcionario", id)
        : ENDPOINT_FUNCIONARIOS;

      const res = await apiFetch(url, {
        method: id ? "PUT" : "POST",
        body: JSON.stringify(payload)
      });

      if (handleAuthOrPermission(res, "Não foi possível validar sua sessão para salvar a pessoa.")) {
        return;
      }

      if (!res.ok) {
        alert(extractErrorMessage(res.payload, "Não foi possível salvar a pessoa."));
        return;
      }

      const statusDiaPayload = readFuncionarioStatusDiaPayload();
      if (statusDiaPayload) {
        const urlStatus = replacePathParam(
          ENDPOINT_QUADRO_DIARIO_ATUALIZAR,
          "identificador_status",
          statusDiaPayload.identificador_status
        );
        const resStatus = await apiFetch(urlStatus, {
          method: "PUT",
          body: JSON.stringify({
            status_operacional: statusDiaPayload.status_operacional,
            status_login: statusDiaPayload.status_login,
            observacao: statusDiaPayload.observacao
          })
        });

        if (handleAuthOrPermission(resStatus, "Não foi possível validar sua sessão para atualizar o status do dia.")) {
          return;
        }

        if (!resStatus.ok) {
          alert(extractErrorMessage(resStatus.payload, "Cadastro salvo, mas não foi possível atualizar o status do dia."));
          return;
        }
      }

      closeModal();
      const recarregamentos = [loadFuncionarios(), loadQuadroDiario()];
      if (!isFuncionariosMode()) recarregamentos.push(loadAudit());
      await Promise.all(recarregamentos);
      return;
    }

    if (state.modalMode === "funcionario-provision") {
      const id = state.modalPayload?.id || null;
      const perfil = isFuncionariosMode() ? "" : (document.getElementById("modalFuncionarioPerfil")?.value || "");
      const setor = isFuncionariosMode() ? "" : (document.getElementById("modalFuncionarioSetor")?.value || "");
      const ativo = document.getElementById("modalFuncionarioContaAtiva")?.value !== "false";
      const forcarTroca = document.getElementById("modalFuncionarioForcarTroca")?.value !== "false";

      if (!id) {
        alert("Selecione a pessoa para provisionar o acesso.");
        return;
      }

      let url = replacePathParam(ENDPOINT_FUNCIONARIO_PROVISIONAR, "identificador_funcionario", id);
      const res = await apiFetch(url, {
        method: "POST",
        body: JSON.stringify({
          identificador_perfil: perfil ? Number(perfil) : null,
          codigo_setor: setor || null,
          indicador_ativo: ativo,
          forcar_troca_na_proxima_entrada: forcarTroca
        })
      });

      if (handleAuthOrPermission(res, "Não foi possível validar sua sessão para provisionar o acesso.")) {
        return;
      }

      if (!res.ok) {
        alert(extractErrorMessage(res.payload, "Não foi possível provisionar o acesso."));
        return;
      }

      closeModal();
      const recarregamentos = [loadFuncionarios()];
      if (!isFuncionariosMode()) recarregamentos.push(searchUsers(true), loadAudit());
      await Promise.all(recarregamentos);
      return;
    }

    if (state.modalMode === "reset-password") {
      const key = getSelectedUserKey();
      const novaSenha = (document.getElementById("modalNovaSenha")?.value || "").trim();
      const confirmarSenha = (document.getElementById("modalConfirmarNovaSenha")?.value || "").trim();
      const forcarTroca = document.getElementById("modalForcarTrocaAoResetar")?.value === "true";

      if (!novaSenha) {
        alert("Informe a nova senha.");
        return;
      }

      if (novaSenha.length < 6) {
        alert("A nova senha precisa ter pelo menos 6 caracteres.");
        return;
      }

      if (novaSenha !== confirmarSenha) {
        alert("A confirmação da senha não confere.");
        return;
      }

      let url = replacePathParam(ENDPOINT_USUARIO_RESETAR_SENHA, "chave", key);

      const res = await apiFetch(url, {
        method: "POST",
        body: JSON.stringify({
          nova_senha: novaSenha,
          forcar_troca_na_proxima_entrada: forcarTroca
        })
      });

      if (handleAuthOrPermission(res, "Não foi possível validar sua sessão para resetar a senha.")) {
        return;
      }

      if (!res.ok) {
        alert(extractErrorMessage(res.payload, "Não foi possível resetar a senha."));
        return;
      }

      closeModal();
      await reloadSelectedUserAndAudit();
      return;
    }

    if (state.modalMode === "force-password") {
      const key = getSelectedUserKey();
      const indicador = document.getElementById("modalIndicadorForcarTroca")?.value === "true";

      let url = replacePathParam(ENDPOINT_USUARIO_FORCAR_TROCA_SENHA, "chave", key);

      const res = await apiFetch(url, {
        method: "POST",
        body: JSON.stringify({
          indicador_precisa_trocar_senha: indicador
        })
      });

      if (handleAuthOrPermission(res, "Não foi possível validar sua sessão para alterar a obrigatoriedade de troca de senha.")) {
        return;
      }

      if (!res.ok) {
        alert(extractErrorMessage(res.payload, "Não foi possível alterar a obrigatoriedade de troca de senha."));
        return;
      }

      closeModal();
      await reloadSelectedUserAndAudit();
    }
  }

  async function aplicarLiberacaoAcesso() {
    if (!requireManagePermission()) return;
    if (!requireProvisionedUser()) return;

    const key = getSelectedUserKey();
    const perfilSelecionado = document.getElementById("selectPerfilPrincipalUsuario")?.value || "";
    const contaAtiva = document.getElementById("selectStatusContaUsuario")?.value !== "false";
    const url = replacePathParam(ENDPOINT_USUARIO_PERFIL_PRINCIPAL, "chave", key);

    const res = await apiFetch(url, {
      method: "PUT",
      body: JSON.stringify({
        identificador_perfil: perfilSelecionado ? Number(perfilSelecionado) : null,
        limpar_regras_diretas: true,
        indicador_ativo: contaAtiva,
        forcar_troca_na_proxima_entrada: false
      })
    });

    if (handleAuthOrPermission(res, "Não foi possível validar sua sessão para salvar a liberação.")) {
      return;
    }

    if (!res.ok) {
      alert(extractErrorMessage(res.payload, "Não foi possível salvar a liberação de acesso."));
      return;
    }

    await reloadSelectedUserAndAudit();
  }

  async function resetarSenhaPadrao() {
