  async function loadCurrentUser() {
    const token = getAccessToken();

    if (!token) {
      setSessionStatus("Sem sessão");
      releasePageGate();
      renderNoAccessState(
        "Sessão ausente",
        "Nenhum token foi encontrado para validar sua sessão atual."
      );
      return false;
    }

    setSessionStatus("Validando...");
    fillUserFromCache();

    const res = await apiFetch(ENDPOINT_ME, { method: "GET" });

    if (res.unauthorized) {
      releasePageGate();
      renderNoAccessState(
        "Sessão expirada",
        "Sua sessão não pôde ser validada. Faça login novamente quando quiser continuar."
      );
      return false;
    }

    if (res.forbidden) {
      console.warn("[ADMIN] /me retornou 403. Sessão mantida, contexto validará permissão.");
      fillUserFromCache();
      setSessionStatus("Sessão ativa");
      return true;
    }

    if (!res.ok) {
      console.warn("[ADMIN] /me não respondeu OK:", res.status, res.payload);
      fillUserFromCache();
      setSessionStatus("Sessão ativa");
      return true;
    }

    const user =
      res.payload?.usuario ||
      res.payload?.user ||
      res.payload?.data ||
      res.payload;

    if (user && typeof user === "object" && Object.keys(user).length > 0) {
      state.currentUser = user;
      if (portalState?.cacheUser) {
        portalState.cacheUser(user);
      } else {
        try {
          writeSession(USER_KEY, JSON.stringify(user));
        } catch {}
      }
      fillCurrentUser(user);
    } else {
      fillUserFromCache();
    }

    setSessionStatus("Verificado");
    return true;
  }

  async function loadContext() {
    setAdminStatus("Validando...");

    const res = await apiFetch(ENDPOINT_CONTEXTO, { method: "GET" });

    if (res.unauthorized) {
      setAdminStatus("Sessão expirada");
      releasePageGate();
      renderNoAccessState(
        "Sessão expirada",
        "Sua sessão expirou ou o token atual não é mais válido."
      );
      return false;
    }

    if (res.forbidden) {
      setAdminStatus("Sem permissão");
      releasePageGate();
      renderNoAccessState(
        "Acesso negado",
        extractErrorMessage(res.payload, "Você não possui permissão para acessar Administração.")
      );
      return false;
    }

    if (!res.ok || !res.payload) {
      console.warn("[ADMIN] contexto indisponível:", res.status, res.payload);
      setAdminStatus("Indisponível");
      return true;
    }

    state.context = res.payload;

    const usuarioLogado =
      res.payload.usuario_logado ||
      res.payload.usuario ||
      null;

    if (usuarioLogado && typeof usuarioLogado === "object") {
      state.currentUser = usuarioLogado;
      if (portalState?.cacheUser) {
        portalState.cacheUser(usuarioLogado);
      } else {
        try {
          writeSession(USER_KEY, JSON.stringify(usuarioLogado));
        } catch {}
      }
      fillCurrentUser(usuarioLogado);
    }

    if (res.payload.allowed === false || res.payload.pode_acessar === false) {
      setAdminStatus("Sem permissão");
      releasePageGate();
      renderNoAccessState(
        "Acesso negado",
        "Você não possui permissão para acessar Administração."
      );
      return false;
    }

    setAdminStatus(res.payload.manage ? "Gerenciamento" : "Consulta");
    return true;
  }

