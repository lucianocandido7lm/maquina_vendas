    const usuario = detail.usuario;
    const origem = usuario.origem_cadastro || "N/D";
    const ativo = !!usuario.indicador_ativo;
    const mfa = !!usuario.indicador_mfa_habilitado;
    const trocaSenha = !!usuario.indicador_precisa_trocar_senha;

    const chips = [
      { label: `Origem: ${origem}`, kind: "neutral" },
      { label: `Conta: ${ativo ? "Ativa" : "Inativa"}`, kind: ativo ? "success" : "danger" },
