  function isEquipeFuncionarioPermitida(item = {}) {
    const equipe = normalizarEquipeFuncionario(item).equipe;
    if (!equipe) return false;
    const normalized = normalizeOptionText(equipe);
    return FUNCIONARIO_EQUIPES_PERMITIDAS.some((permitida) => normalizeOptionText(permitida) === normalized);
  }

  function getEquipesFuncionariosCatalogo() {
    const hasApiSource = Array.isArray(state.equipesFuncionarios) && state.equipesFuncionarios.length;
    const fonte = hasApiSource ? state.equipesFuncionarios : FUNCIONARIO_EQUIPES_PLANILHA_FALLBACK;
    const normalizadas = fonte.map(normalizarEquipeFuncionario).filter((item) => item.equipe);
    if (hasApiSource) return normalizadas;
    const lista = normalizadas.filter((item) => isEquipeFuncionarioPermitida(item));
    return lista.length ? lista : FUNCIONARIO_EQUIPES_PLANILHA_FALLBACK.map(normalizarEquipeFuncionario);
  }

  function isEquipeVigenteNaData(item = {}, dataReferencia = "") {
    const equipe = normalizarEquipeFuncionario(item);
    if (equipeFuncionarioStatusKey(equipe) !== "ATIVO") return false;
    const data = dataReferencia || todayIsoDate();
    const inicio = String(equipe.data_inicio_vigencia || "");
    const fim = String(equipe.data_fim_vigencia || "");
    if (!inicio) return false;
    if (inicio && inicio > data) return false;
    if (fim && fim < data) return false;
    return true;
  }

  function getEquipeFuncionarioByIdOrName(value, dataReferencia = "", options = {}) {
    const normalized = normalizeOptionText(value);
    const equipes = getEquipesFuncionariosCatalogo();
    if (!normalized) return null;
    const matches = equipes.filter((item) =>
      normalizeOptionText(item.identificador_equipe_vigencia) === normalized ||
      normalizeOptionText(item.equipe) === normalized
    );
    if (!matches.length) return null;
    const vigente = matches.find((item) => isEquipeVigenteNaData(item, dataReferencia));
    if (vigente) return vigente;
    return options.requireVigente ? null : matches[0];
  }

  function getEquipeOptions(dataReferencia = "") {
    const atual = dataReferencia || todayIsoDate();
    const nomes = getEquipesFuncionariosCatalogo()
      .filter((item) => isEquipeVigenteNaData(item, atual))
      .map((item) => item.equipe);
    return sortOptionValues(nomes.length ? nomes : FUNCIONARIO_IMOBILIARIAS_CADASTRO);
  }

  function isFuncionarioImobiliariaPermitida(value) {
