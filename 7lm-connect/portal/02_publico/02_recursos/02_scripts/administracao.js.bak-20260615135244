  async function loadQuadroDiario() {
    const data = el.inputDataQuadro?.value || todayIsoDate();
    const params = new URLSearchParams();
    params.set("data_status", data);

    const tipo = document.getElementById("selectFuncionarioTipo")?.value || "";
    const q = (el.inputFuncionarioBusca?.value || "").trim();
    if (tipo) params.set("tipo", tipo);
    if (q) params.set("q", q);

    const res = await apiFetch(`${ENDPOINT_QUADRO_DIARIO}?${params.toString()}`, { method: "GET" });

    if (handleAuthOrPermission(res, "Não foi possível validar sua sessão para consultar o quadro diário.")) {
      return;
    }

    if (!res.ok) {
      if (el.listaQuadroDiario) {
        renderEmpty(el.listaQuadroDiario, "D", "Quadro indisponível", extractErrorMessage(res.payload, "Não foi possível consultar o quadro diário."));
      }
      return;
    }

    state.quadroDiario = Array.isArray(res.payload?.items) ? res.payload.items : [];
    renderQuadroDiario(state.quadroDiario);
    if (isFuncionariosMode() && state.funcionarios.length) {
      renderFuncionarios(state.funcionarios);
    }
  }

  async function gerarQuadroDiarioAtual() {
    if (!requireManagePermission()) return;
    const data = el.inputDataQuadro?.value || todayIsoDate();
    const res = await apiFetch(ENDPOINT_QUADRO_DIARIO_GERAR, {
      method: "POST",
      body: JSON.stringify({ data_status: data })
    });

    if (handleAuthOrPermission(res, "Não foi possível validar sua sessão para gerar o quadro diário.")) {
      return;
    }

    if (!res.ok) {
      alert(extractErrorMessage(res.payload, "Não foi possível gerar o quadro diário."));
      return;
    }

    state.quadroDiario = Array.isArray(res.payload?.items) ? res.payload.items : [];
    renderQuadroDiario(state.quadroDiario);
    if (isFuncionariosMode() && state.funcionarios.length) {
      renderFuncionarios(state.funcionarios);
    }
    if (!isFuncionariosMode()) {
      await loadAudit();
    }
  }

  async function salvarLinhaQuadro(id) {
    if (!requireManagePermission()) return;
    const seletorId = escapeCssSelectorValue(id);
    const statusOperacional = document.querySelector(`[data-quadro-status="${seletorId}"]`)?.value || "ATIVO";
    const observacao = document.querySelector(`[data-quadro-observacao="${seletorId}"]`)?.value || "";
    let url = replacePathParam(ENDPOINT_QUADRO_DIARIO_ATUALIZAR, "identificador_status", id);

    const res = await apiFetch(url, {
      method: "PUT",
      body: JSON.stringify({
        status_operacional: statusOperacional,
        observacao
      })
    });

    if (handleAuthOrPermission(res, "Não foi possível validar sua sessão para atualizar o quadro diário.")) {
      return;
    }

    if (!res.ok) {
      alert(extractErrorMessage(res.payload, "Não foi possível atualizar a linha do quadro."));
      return;
    }

    await loadQuadroDiario();
    if (isFuncionariosMode() && state.funcionarios.length) {
      renderFuncionarios(state.funcionarios);
    }
  }

