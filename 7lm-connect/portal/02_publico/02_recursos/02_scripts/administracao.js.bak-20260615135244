  function renderQuadroSummary(items) {
    if (!el.resumoQuadroDiario) return;
    const lista = Array.isArray(items) ? items : [];
    const total = lista.length;
    const ativos = lista.filter((item) => normalizeFuncionarioCadastroStatus(item.status_operacional) === "ATIVO").length;
    const inativos = lista.filter((item) => normalizeFuncionarioCadastroStatus(item.status_operacional) === "INATIVO").length;
    const afastados = lista.filter((item) => normalizeFuncionarioCadastroStatus(item.status_operacional) === "AFASTADO").length;

    el.resumoQuadroDiario.innerHTML = `
      <span>Linhas do dia <strong>${total}</strong></span>
      <span>Ativos <strong>${ativos}</strong></span>
      <span>Inativos <strong>${inativos}</strong></span>
      <span>Afastados <strong>${afastados}</strong></span>
    `;
