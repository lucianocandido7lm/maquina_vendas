  async function loadAudit() {
    const res = await apiFetch(ENDPOINT_AUDITORIA, { method: "GET" });

    if (handleAuthOrPermission(res, "Não foi possível validar sua sessão para consultar a auditoria.")) {
      renderEmpty(
        el.listaAuditoria,
        "🔒",
        res.unauthorized ? "Sessão expirada" : "Sem permissão",
        res.unauthorized
          ? "Sua sessão precisa ser renovada para visualizar a auditoria."
          : "Você não possui permissão para visualizar a auditoria administrativa."
      );
      return;
    }

    if (!res.ok) {
      console.warn("[ADMIN] auditoria falhou:", res.status, res.payload);
      renderEmpty(
        el.listaAuditoria,
        "🧾",
        "Auditoria indisponível",
        "A auditoria não respondeu pela API. Verifique rota, proxy e console."
      );
