    const preserveExisting = options.preserveExisting === true;
    FUNCIONARIO_EQUIPE_CONTATO_LIDERANCA_MAP.forEach(({ emailSelector, documentoSelector, getNome }) => {
      const contato = getFuncionarioLiderancaContato(getNome(item));
