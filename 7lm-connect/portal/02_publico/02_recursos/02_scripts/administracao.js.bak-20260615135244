  function bindOperationalDashboardActions() {
    if (!el.listaDashboardsOperacionais) return;

    el.listaDashboardsOperacionais.querySelectorAll("[data-remove-operational-dashboard]").forEach((btn) => {
      btn.addEventListener("click", async () => {
        if (!requireManagePermission()) return;
        if (!requireProvisionedUser()) return;

        const dashboardId = btn.getAttribute("data-remove-operational-dashboard");
        if (!dashboardId) return;
        if (!confirm("Deseja remover este recurso legado do usuário selecionado?")) return;

        let url = replacePathParam(ENDPOINT_USUARIO_REMOVER_DASHBOARD_OPERACIONAL, "chave", getSelectedUserKey());
        url = replacePathParam(url, "identificador_dashboard", dashboardId);

        const res = await apiFetch(url, { method: "DELETE" });

        if (handleAuthOrPermission(res, "Não foi possível validar sua sessão para remover o recurso legado.")) {
          return;
        }

        if (!res.ok) {
          alert(extractErrorMessage(res.payload, "Não foi possível remover o recurso legado."));
          return;
        }

        await reloadSelectedUserAndAudit();
      });
    });
  }

