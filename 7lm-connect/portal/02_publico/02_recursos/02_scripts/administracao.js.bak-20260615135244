  async function resetarMfaUsuario() {
    if (!requireManagePermission()) return;
    if (!requireProvisionedUser()) return;
    if (!confirm("Deseja resetar o MFA deste usuário? No próximo acesso ele deverá configurar o autenticador novamente.")) return;

    const key = getSelectedUserKey();
