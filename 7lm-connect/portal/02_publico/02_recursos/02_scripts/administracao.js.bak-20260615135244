      item.gerente_comercial ? `Gerente Comercial: ${item.gerente_comercial}` : "",
      item.gerente_regional ? `Gerente Regional: ${item.gerente_regional}` : "",
      item.head_comercial ? `Head Comercial: ${item.head_comercial}` : "",
      item.diretor_comercial ? `Diretor Comercial: ${item.diretor_comercial}` : ""
    ].filter(Boolean).join(" • ") || "Equipe sem liderança cadastrada.";
  }

  function setInputValueAndNotify(input, value) {
    if (!input) return;
    input.value = value || "";
    input.dispatchEvent(new Event("input", { bubbles: true }));
    input.dispatchEvent(new Event("change", { bubbles: true }));
  }

  const FUNCIONARIO_EQUIPE_AUTOFILL_FIELDS = [
