    }

    const usuario = detail.usuario;
    const nome = usuario.nome_completo || "Sem nome";
    const matricula = usuario.matricula || "-";
    const email = usuario.correio_eletronico || "Não informado";
    const ultimoLogin = formatDateTime(usuario.data_hora_ultimo_login);
    const origem = usuario.origem_cadastro || "N/D";
    const iniciais = getInitials(nome);

    const provisionado = !!usuario.identificador_usuario;
