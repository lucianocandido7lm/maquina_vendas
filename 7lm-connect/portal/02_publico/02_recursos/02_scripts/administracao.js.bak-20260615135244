  function funcionarioLoginStatus(item, quadro = null) {
    const statusQuadro = String(quadro?.status_login || "").toUpperCase();
    if (item.ativo === false) return "BLOQUEADO";
    if (!item.email) return "SEM_EMAIL";
    if (statusQuadro && statusQuadro !== "LIBERADO") return statusQuadro;
    if (item.ativo_login === true || statusQuadro === "LIBERADO") return "LIBERADO";
    if (item.ativo_login === false) return "BLOQUEADO";
    return "PENDENTE";
  }

