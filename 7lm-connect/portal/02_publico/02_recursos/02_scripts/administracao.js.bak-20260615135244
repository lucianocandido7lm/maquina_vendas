  function switchFuncionariosTab(tab) {
    const nextTab = tab === "equipes" ? "equipes" : "colaboradores";
    state.funcionariosActiveTab = nextTab;
    el.funcionariosTabs?.forEach((button) => {
      const active = button.getAttribute("data-funcionarios-tab") === nextTab;
      button.classList.toggle("is-active", active);
      button.setAttribute("aria-selected", active ? "true" : "false");
    });
    el.funcionariosTabPanels?.forEach((panel) => {
      panel.hidden = panel.getAttribute("data-funcionarios-tab-panel") !== nextTab;
    });
    const novoFuncionarioHeader = el.btnNovoFuncionario?.closest(".tl-panel__header");
    if (novoFuncionarioHeader) novoFuncionarioHeader.hidden = nextTab !== "colaboradores";
    if (el.btnNovoFuncionario) el.btnNovoFuncionario.hidden = nextTab !== "colaboradores";
    if (nextTab === "equipes") {
      renderEquipesFuncionarios(state.equipesFuncionarios.length ? state.equipesFuncionarios : FUNCIONARIO_EQUIPES_PLANILHA_FALLBACK);
      loadEquipesFuncionarios();
    } else {
      renderFuncionarios(state.funcionarios);
    }
  }

  function bindEvents() {
    if (el.btnBuscarUsuario) {
      el.btnBuscarUsuario.addEventListener("click", () => searchUsers(false));
    }

    if (el.inputBuscaUsuario) {
      el.inputBuscaUsuario.addEventListener("keydown", (e) => {
        if (e.key === "Enter") {
          e.preventDefault();
