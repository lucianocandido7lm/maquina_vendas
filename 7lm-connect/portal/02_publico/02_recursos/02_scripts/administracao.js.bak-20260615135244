  function isFuncionarioCargoLideranca(item = {}, campo = "") {
    const cargo = normalizeOptionText(getFuncionarioCargoCadastro(item));
    if (!cargo) return false;
    if (campo === "gerente_vendas") return cargo.includes("gerente de vendas") || cargo === "gerente";
    if (campo === "gerente_comercial") return cargo.includes("gerente comercial") || cargo.includes("coordenador");
    if (campo === "gerente_regional") return cargo.includes("gerente regional");
    if (campo === "head_comercial") return cargo.includes("head");
    if (campo === "diretor_comercial") return cargo.includes("diretor");
    return false;
  }

