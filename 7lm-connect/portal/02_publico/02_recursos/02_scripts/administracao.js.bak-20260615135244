  function bindEquipePlanejamentoFields(scope = document) {
    scope.querySelector("#modalEquipeStatus")?.addEventListener("change", () => toggleEquipePlanejamentoFields(scope));
    scope.querySelector("#modalEquipeHcPlanejado")?.addEventListener("input", () => syncEquipePlanejamentoResumo(scope));
    scope.querySelector("#modalEquipeFocosPlanejados")?.addEventListener("input", () => syncEquipePlanejamentoResumo(scope));
    toggleEquipePlanejamentoFields(scope);
