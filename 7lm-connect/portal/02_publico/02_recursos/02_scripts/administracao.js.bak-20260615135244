  function bindProfileActions() {
    if (!el.listaPerfisUsuario) return;
    el.listaPerfisUsuario.querySelectorAll("[data-remove-profile]").forEach((btn) => {
      btn.addEventListener("click", async () => {
        if (!requireManagePermission()) return;

        const perfilId = btn.getAttribute("data-remove-profile");
        if (!perfilId || !requireProvisionedUser()) return;

        if (!confirm("Deseja remover este perfil do usuário selecionado?")) return;

        const key = getSelectedUserKey();
        let url = replacePathParam(ENDPOINT_USUARIO_REMOVER_PERFIL, "chave", key);
        url = replacePathParam(url, "identificador_perfil", perfilId);

        const res = await apiFetch(url, { method: "DELETE" });

        if (handleAuthOrPermission(res, "Não foi possível validar sua sessão para remover o perfil.")) {
          return;
        }

        if (!res.ok) {
          alert(extractErrorMessage(res.payload, "Não foi possível remover o perfil."));
          return;
        }

        await reloadSelectedUserAndAudit();
      });
    });
  }

