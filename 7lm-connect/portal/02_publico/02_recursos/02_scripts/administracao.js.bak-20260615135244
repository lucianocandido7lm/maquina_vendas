    "#modalFuncionarioGestorDocumento",
    "#modalFuncionarioCoordenadorEmail",
    "#modalFuncionarioCoordenadorDocumento",
    "#modalFuncionarioGerenteEmail",
    "#modalFuncionarioGerenteDocumento",
    "#modalFuncionarioDiretorEmail",
    "#modalFuncionarioDiretorDocumento"
  ];

  const FUNCIONARIO_EQUIPE_CONTATO_LIDERANCA_MAP = [
