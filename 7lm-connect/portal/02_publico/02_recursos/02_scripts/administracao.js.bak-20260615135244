        const key = card.getAttribute("data-user-key");
        if (!key) return;

        loadUserDetail(key);
      });
    }

    if (el.btnNovoUsuarioExterno) {
      el.btnNovoUsuarioExterno.addEventListener("click", () => {
        if (!requireManagePermission()) return;
        buildExternalUserModal();
      });
    }

    if (el.btnProvisionarQuadro) {
      el.btnProvisionarQuadro.addEventListener("click", () => {
        if (!requireManagePermission()) return;
        if (!requireProvisionedUser()) return;

        buildProvisionModal();
      });
    }

    if (el.btnAdicionarPerfil) {
      el.btnAdicionarPerfil.addEventListener("click", () => {
        if (!requireManagePermission()) return;
        if (!requireProvisionedUser()) return;
        buildProfileModal();
      });
    }

    if (el.btnAdicionarPermissao) {
      el.btnAdicionarPermissao.addEventListener("click", () => {
        if (!requireManagePermission()) return;
        if (!requireProvisionedUser()) return;
        buildPermissionModal();
      });
    }

    if (el.btnAdicionarDashboardOperacional) {
      el.btnAdicionarDashboardOperacional.addEventListener("click", () => {
        if (!requireManagePermission()) return;
        if (!requireProvisionedUser()) return;
        buildOperationalDashboardModal();
      });
    }

    if (el.btnGerenciarSetores) {
      el.btnGerenciarSetores.addEventListener("click", () => {
        if (!requireManagePermission()) return;
        if (!requireAnySelection()) return;
        buildSectorModal();
      });
    }

    if (el.btnAtualizarAuditoria) {
      el.btnAtualizarAuditoria.addEventListener("click", loadAudit);
    }

    if (el.btnFiltrarFuncionarios) {
      el.btnFiltrarFuncionarios.addEventListener("click", () => {
        loadFuncionarios();
        loadQuadroDiario();
      });
    }

    if (el.btnLimparFiltrosFuncionarios) {
      el.btnLimparFiltrosFuncionarios.addEventListener("click", () => {
        if (el.inputFuncionarioBusca) el.inputFuncionarioBusca.value = "";
        if (el.selectFuncionarioSetor) el.selectFuncionarioSetor.value = "";
        if (el.selectFuncionarioVinculo) el.selectFuncionarioVinculo.value = "";
        if (el.selectFuncionarioImobiliaria) el.selectFuncionarioImobiliaria.value = "";
        if (el.selectFuncionarioStatus) el.selectFuncionarioStatus.value = "";
        if (el.selectFuncionarioLogin) el.selectFuncionarioLogin.value = "";
        refreshCustomSelects(document);
        loadFuncionarios();
        loadQuadroDiario();
      });
    }

    el.funcionariosTabs?.forEach((button) => {
      button.addEventListener("click", () => {
        switchFuncionariosTab(button.getAttribute("data-funcionarios-tab"));
      });
    });

    if (el.btnFiltrarEquipes) {
      el.btnFiltrarEquipes.addEventListener("click", loadEquipesFuncionarios);
    }

    if (el.btnLimparFiltrosEquipes) {
      el.btnLimparFiltrosEquipes.addEventListener("click", () => {
        if (el.inputEquipeBusca) el.inputEquipeBusca.value = "";
        if (el.selectEquipeStatus) el.selectEquipeStatus.value = "";
        refreshCustomSelect(el.selectEquipeStatus);
        loadEquipesFuncionarios();
      });
    }

    if (el.inputEquipeBusca) {
      el.inputEquipeBusca.addEventListener("keydown", (e) => {
        if (e.key === "Enter") {
          e.preventDefault();
          loadEquipesFuncionarios();
        }
      });
    }

    if (el.selectEquipeStatus) {
      el.selectEquipeStatus.addEventListener("change", loadEquipesFuncionarios);
    }

    if (el.btnNovaEquipe) {
      el.btnNovaEquipe.addEventListener("click", () => {
        if (!requireManagePermission()) return;
        buildEquipeFuncionarioModal(null);
      });
    }

    if (el.listaEquipesFuncionarios) {
      el.listaEquipesFuncionarios.addEventListener("click", (event) => {
        const filtro = event.target.closest("[data-equipe-filter]");
        if (filtro) {
          event.preventDefault();
          event.stopPropagation();
          applyEquipeInlineFilter(filtro.getAttribute("data-equipe-filter-value") || "");
          return;
        }

        const editar = event.target.closest("[data-edit-equipe]");
        if (!editar) return;
        if (!requireManagePermission()) return;
        const equipe = getEquipeFuncionarioById(editar.getAttribute("data-edit-equipe"));
        if (equipe) buildEquipeFuncionarioModal(equipe);
      });
    }

    [el.selectFuncionarioSetor, el.selectFuncionarioVinculo, el.selectFuncionarioImobiliaria, el.selectFuncionarioStatus, el.selectFuncionarioLogin]
      .filter(Boolean)
      .forEach((select) => {
        select.addEventListener("change", () => {
          loadFuncionarios();
          loadQuadroDiario();
        });
      });

    if (el.resumoFuncionarios) {
      el.resumoFuncionarios.addEventListener("click", (event) => {
        const chip = event.target.closest("[data-funcionario-summary-filter]");
        if (!chip) return;
        applyFuncionarioSummaryFilter(
          chip.getAttribute("data-funcionario-summary-filter"),
          chip.getAttribute("data-funcionario-summary-value") || ""
        );
      });
    }

    if (el.inputFuncionarioBusca) {
      el.inputFuncionarioBusca.addEventListener("keydown", (e) => {
        if (e.key === "Enter") {
          e.preventDefault();
          loadFuncionarios();
          loadQuadroDiario();
        }
      });
    }

    if (el.btnNovoFuncionario) {
      el.btnNovoFuncionario.addEventListener("click", () => {
        if (!requireManagePermission()) return;
        buildFuncionarioModal(null);
      });
    }

    if (el.listaFuncionarios) {
      el.listaFuncionarios.addEventListener("click", (event) => {
        const filtro = event.target.closest("[data-funcionario-filter]");
        if (filtro) {
          event.preventDefault();
          event.stopPropagation();
          applyFuncionarioInlineFilter(
            filtro.getAttribute("data-funcionario-filter"),
            filtro.getAttribute("data-funcionario-filter-value") || ""
          );
          return;
        }

        const editar = event.target.closest("[data-edit-funcionario]");
        if (editar) {
          if (!requireManagePermission()) return;
          const funcionario = getFuncionarioById(editar.getAttribute("data-edit-funcionario"));
          if (funcionario) buildFuncionarioModal(funcionario);
          return;
        }

        const provisionar = event.target.closest("[data-provisionar-funcionario]");
        if (provisionar) {
          if (isFuncionariosMode()) return;
          if (!requireManagePermission()) return;
          const funcionario = getFuncionarioById(provisionar.getAttribute("data-provisionar-funcionario"));
          if (funcionario) buildProvisionFuncionarioModal(funcionario);
          return;
        }

        const linha = event.target.closest("[data-open-funcionario]");
        if (linha) {
          const funcionario = getFuncionarioById(linha.getAttribute("data-open-funcionario"));
          if (funcionario) buildFuncionarioModal(funcionario);
        }
      });
    }

    if (el.inputDataQuadro && !el.inputDataQuadro.value) {
      el.inputDataQuadro.value = todayIsoDate();
    }

    if (el.btnAtualizarQuadro) {
      el.btnAtualizarQuadro.addEventListener("click", loadQuadroDiario);
    }

    if (el.btnGerarQuadro) {
      el.btnGerarQuadro.addEventListener("click", gerarQuadroDiarioAtual);
    }

    if (el.listaQuadroDiario) {
      el.listaQuadroDiario.addEventListener("click", (event) => {
        const salvar = event.target.closest("[data-salvar-quadro]");
        if (!salvar) return;
        salvarLinhaQuadro(salvar.getAttribute("data-salvar-quadro"));
      });
    }

    if (el.btnFecharModal) el.btnFecharModal.addEventListener("click", closeModal);
    if (el.btnCancelarModal) el.btnCancelarModal.addEventListener("click", closeModal);
    if (el.btnSalvarModal) el.btnSalvarModal.addEventListener("click", saveModal);

    if (el.modalShell) {
      el.modalShell.addEventListener("click", (e) => {
        const target = e.target;
        const vacancyButton = target && target.closest ? target.closest("[data-set-leadership-vacant]") : null;
        if (vacancyButton) {
          const input = document.getElementById(vacancyButton.getAttribute("data-set-leadership-vacant"));
          if (input) {
            input.value = "Vago";
            input.dispatchEvent(new Event("input", { bubbles: true }));
            input.focus();
          }
          return;
        }
        const addEquipeFoco = target && target.closest ? target.closest("[data-add-equipe-foco]") : null;
        if (addEquipeFoco) {
          const container = document.getElementById("modalEquipeFocosPlanejados");
          if (container) {
            container.insertAdjacentHTML("beforeend", renderEquipeFocoPlanejadoRow({}, container.querySelectorAll("[data-equipe-foco-row]").length));
            syncEquipePlanejamentoResumo(el.modalBody || document);
          }
          return;
        }
        const removeEquipeFoco = target && target.closest ? target.closest("[data-remove-equipe-foco]") : null;
        if (removeEquipeFoco) {
          const row = removeEquipeFoco.closest("[data-equipe-foco-row]");
          if (row) row.remove();
          const container = document.getElementById("modalEquipeFocosPlanejados");
          if (container && !container.querySelector("[data-equipe-foco-row]")) {
            container.insertAdjacentHTML("beforeend", renderEquipeFocoPlanejadoRow({}, 0));
          }
          syncEquipePlanejamentoResumo(el.modalBody || document);
          return;
        }
        if (target && target.getAttribute && target.getAttribute("data-close-modal") === "true") {
          closeModal();
        }
      });
    }

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && el.modalShell && !el.modalShell.hidden) {
        closeModal();
      }
    });

    document.addEventListener("click", (event) => {
      if (!(event.target instanceof Element)) return;
      if (event.target.closest(".tl-clientes-select-wrap, .tl-admin-combo-wrap")) return;
      closeListControls();
    });

    bindSecurityActionButtons();
  }

  function applyInstitutionalAdminCopy() {
    const modoFuncionarios = isFuncionariosMode();

    try {
      document.title = modoFuncionarios ? "7LM | Cadastro" : "7LM | Acessos";
      document.body.dataset.adminPageMode = PAGE_MODE;
    } catch {}

    try {
      const overline = document.querySelector(".tl-topbar__titles .tl-overline");
      const title = document.querySelector(".tl-topbar__titles .tl-title");
      const subtitle = document.querySelector(".tl-topbar__titles .tl-subtitle");
      if (overline) {
        overline.textContent = modoFuncionarios ? "" : "Acessos • Liberação • Perfil";
        overline.hidden = modoFuncionarios;
      }
      if (title) title.textContent = modoFuncionarios ? "Cadastro" : "Acessos";
      if (subtitle) {
        subtitle.textContent = modoFuncionarios
          ? ""
          : "Selecione uma pessoa, aplique um perfil pronto e controle senha temporária sem regras soltas.";
        subtitle.hidden = modoFuncionarios;
      }
    } catch {}

    try {
      const topRow = document.querySelector(".tl-admin-top-row");
      const kpis = document.querySelector(".tl-kpis");
      const employeePanels = document.querySelectorAll(".tl-panel--funcionarios");
      const quadroPanel = document.querySelector(".tl-panel--quadro-diario");
      const accessPanels = document.querySelectorAll(".tl-panel--pesquisa, .tl-panel--colaborador, .tl-panel--acoes, .tl-panel--perfis");

      if (modoFuncionarios) {
        if (kpis) kpis.hidden = true;
        if (topRow) topRow.hidden = true;
        if (quadroPanel) quadroPanel.hidden = true;
        accessPanels.forEach((panel) => {
          panel.hidden = true;
        });
        employeePanels.forEach((panel) => {
          panel.hidden = false;
        });
      } else {
        if (kpis) kpis.hidden = true;
        if (quadroPanel) quadroPanel.hidden = true;
        employeePanels.forEach((panel) => {
          panel.hidden = true;
        });
      }
    } catch {}

    try {
      const searchPanel = el.caixaResultadosBusca?.closest(".tl-panel");
      const summaryPanel = el.painelResumoUsuario?.closest(".tl-panel");
      const securityPanel = el.painelSegurancaUsuario?.closest(".tl-panel");
      const profilesPanel = el.listaPerfisUsuario?.closest(".tl-panel");
      const permissionsPanel = el.listaPermissoesDiretas?.closest(".tl-panel");
      const effectivePanel = el.painelAcessoEfetivo?.closest(".tl-panel");
      const auditPanel = el.listaAuditoria?.closest(".tl-panel");

      if (searchPanel) {
        const eyebrow = searchPanel.querySelector(".tl-panel__eyebrow");
        const title = searchPanel.querySelector(".tl-panel__title");
        const badge = searchPanel.querySelector(".tl-badge");
        const hint = searchPanel.querySelector(".tl-search-hint");
        if (eyebrow) eyebrow.textContent = "Acessos • Identidade";
        if (title) title.textContent = "Pesquisar usuário";
        if (badge) badge.textContent = "7LM";
        if (hint) hint.textContent = "Busca por: nome • e-mail • matrícula • identificador";
      }

      if (summaryPanel) {
        const eyebrow = summaryPanel.querySelector(".tl-panel__eyebrow");
        const title = summaryPanel.querySelector(".tl-panel__title");
        if (eyebrow) eyebrow.textContent = "Usuário Selecionado";
        if (title) title.textContent = "Resumo do acesso";
      }

      if (securityPanel) {
        const eyebrow = securityPanel.querySelector(".tl-panel__eyebrow");
        const title = securityPanel.querySelector(".tl-panel__title");
        if (eyebrow) eyebrow.textContent = "Acesso ao Sistema";
        if (title) title.textContent = "Liberação por perfil";
      }

      if (profilesPanel) {
        const eyebrow = profilesPanel.querySelector(".tl-panel__eyebrow");
        const title = profilesPanel.querySelector(".tl-panel__title");
        if (eyebrow) eyebrow.textContent = "Perfis";
        if (title) title.textContent = "Perfis vinculados";
      }

      if (permissionsPanel) {
        const eyebrow = permissionsPanel.querySelector(".tl-panel__eyebrow");
        const title = permissionsPanel.querySelector(".tl-panel__title");
        if (eyebrow) eyebrow.textContent = "Permissões";
        if (title) title.textContent = "Regras diretas";
      }

      if (effectivePanel) {
        const eyebrow = effectivePanel.querySelector(".tl-panel__eyebrow");
        const title = effectivePanel.querySelector(".tl-panel__title");
        if (eyebrow) eyebrow.textContent = "Resultado Final";
        if (title) title.textContent = "Acesso efetivo";
      }

      if (auditPanel) {
        const eyebrow = auditPanel.querySelector(".tl-panel__eyebrow");
        const title = auditPanel.querySelector(".tl-panel__title");
        if (eyebrow) eyebrow.textContent = "Auditoria";
        if (title) title.textContent = "Eventos administrativos";
      }
    } catch {}

    try {
      if (el.btnNovoUsuarioExterno) el.btnNovoUsuarioExterno.textContent = "Novo usuário";
      if (el.btnProvisionarQuadro) {
        el.btnProvisionarQuadro.hidden = false;
        el.btnProvisionarQuadro.textContent = "Editar usuário";
      }
      if (modoFuncionarios) {
        const funcionariosPanel = el.listaFuncionarios?.closest(".tl-panel");
        if (funcionariosPanel) {
          const eyebrow = funcionariosPanel.querySelector(".tl-panel__eyebrow");
          const title = funcionariosPanel.querySelector(".tl-panel__title");
          if (eyebrow) eyebrow.remove();
          if (title) title.remove();
        }
        if (el.selectFuncionarioStatus) {
          el.selectFuncionarioStatus.innerHTML = `
            <option value="">Todos</option>
            <option value="ATIVO">Ativos</option>
            <option value="INATIVO">Inativos</option>
            <option value="AFASTADO">Afastados</option>
          `;
          refreshCustomSelect(el.selectFuncionarioStatus);
        }
        if (el.selectFuncionarioSetor) syncFuncionarioFilterOptions();
      }
      document.querySelector(".tl-colab-shell__quadro")?.setAttribute("hidden", "hidden");
      if (!modoFuncionarios) {
        el.listaPerfisUsuario?.closest(".tl-panel")?.setAttribute("hidden", "hidden");
        el.listaPermissoesDiretas?.closest(".tl-panel")?.setAttribute("hidden", "hidden");
        el.painelAcessoEfetivo?.closest(".tl-panel")?.setAttribute("hidden", "hidden");
        el.listaAuditoria?.closest(".tl-panel")?.setAttribute("hidden", "hidden");
      }
      el.listaSetoresPerfis?.closest(".tl-panel")?.setAttribute("hidden", "hidden");
      el.listaDashboardsOperacionais?.closest(".tl-panel")?.setAttribute("hidden", "hidden");
    } catch {}
  }

  async function boot() {
    closeModal();
    applyInstitutionalAdminCopy();
    enhanceFuncionarioListControls(document);
    observeFuncionarioListControls();
    initParticles();
    initTheme();
    bindLogout();
    bindEvents();
    setButtonsBySelection();

    fillUserFromCache();

    console.log("[ADMIN] API_BASE_URL =", API_BASE_URL);
    console.log("[ADMIN] PAGE_MODE =", PAGE_MODE);
    console.log("[ADMIN] ENDPOINT_ME =", ENDPOINT_ME);
    console.log("[ADMIN] ENDPOINT_CONTEXTO =", ENDPOINT_CONTEXTO);
    console.log("[ADMIN] ENDPOINT_BUSCA_USUARIOS =", ENDPOINT_BUSCA_USUARIOS);
    console.log("[ADMIN] ENDPOINT_USUARIO_DETALHE =", ENDPOINT_USUARIO_DETALHE);
    console.log("[ADMIN] ENDPOINT_AUDITORIA =", ENDPOINT_AUDITORIA);
    console.log("[ADMIN] ENDPOINT_FUNCIONARIOS =", ENDPOINT_FUNCIONARIOS);
    console.log("[ADMIN] ENDPOINT_FUNCIONARIO_EQUIPES =", ENDPOINT_FUNCIONARIO_EQUIPES);
    console.log("[ADMIN] ENDPOINT_QUADRO_DIARIO =", ENDPOINT_QUADRO_DIARIO);
    console.log("[ADMIN] ENDPOINT_SETORES =", ENDPOINT_SETORES);

    const okContext = await loadContext();
    if (!okContext) return;

    if (!isFuncionariosMode()) {
      renderUserSummary(null);
      renderQuadroAtual(null);
      renderSecurityPanel(null);
      renderProfiles(null);
      renderDirectPermissions(null);
      renderSectorProfiles(null);
      renderEffectiveAccess(null);
      renderOperationalDashboards(null);
    }

    releasePageGate();

    const carregamentos = isFuncionariosMode()
      ? [loadEquipesFuncionarios(), loadFuncionarios(), loadQuadroDiario()]
      : [loadAudit(), searchUsers(true)];

    await Promise.all(carregamentos);
  }

  document.addEventListener("DOMContentLoaded", boot);
})();
