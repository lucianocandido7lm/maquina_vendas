  function closeListControls(ignoreWrap = null) {
    document.querySelectorAll(".tl-clientes-select-wrap, .tl-admin-combo-wrap").forEach((wrap) => {
      if (ignoreWrap && wrap === ignoreWrap) return;
      wrap.classList.remove("is-open");
      wrap.classList.remove("is-drop-up");
      wrap.querySelector(".tl-clientes-select-options, .tl-admin-combo-options")?.classList.remove("is-open");
      const panel = wrap.querySelector(".tl-clientes-select-options, .tl-admin-combo-options");
      if (panel) {
        panel.style.maxHeight = "";
        panel.style.left = "";
        panel.style.top = "";
        panel.style.width = "";
        panel.style.minWidth = "";
      }
      wrap.querySelector(".tl-clientes-select-trigger")?.setAttribute("aria-expanded", "false");
      wrap.querySelector(".tl-admin-combo-input")?.setAttribute("aria-expanded", "false");
    });
  }

  function positionListPanel(wrap, panel) {
    if (!wrap || !panel) return;
    const control = wrap.querySelector(".tl-clientes-select-trigger, .tl-admin-combo-input") || wrap;
    const controlRect = control.getBoundingClientRect();
    const fixedOrigin = getFixedLayerOrigin(panel);
    const viewport = window.visualViewport || null;
    const viewportLeft = viewport?.offsetLeft || 0;
    const viewportTop = viewport?.offsetTop || 0;
    const viewportWidth = viewport?.width || window.innerWidth || document.documentElement.clientWidth;
    const viewportHeight = viewport?.height || window.innerHeight || document.documentElement.clientHeight;
    const topLimit = viewportTop + 12;
    const bottomLimit = viewportTop + viewportHeight - 12;
    const spaceBelow = Math.max(0, bottomLimit - controlRect.bottom);
    const spaceAbove = Math.max(0, controlRect.top - topLimit);
    const dropUp = spaceBelow < 210 && spaceAbove > spaceBelow;
    const available = Math.max(140, (dropUp ? spaceAbove : spaceBelow) - 12);
    const width = Math.min(
      Math.max(controlRect.width, 190),
      Math.max(190, viewportWidth - 24)
    );
    const left = Math.min(
      Math.max(viewportLeft + 12, controlRect.left),
      Math.max(viewportLeft + 12, viewportLeft + viewportWidth - width - 12)
    );
    const height = Math.min(276, available);
    const top = dropUp
      ? Math.max(viewportTop + 12, controlRect.top - height - 8)
      : Math.min(viewportTop + viewportHeight - height - 12, controlRect.bottom + 8);
    wrap.classList.toggle("is-drop-up", dropUp);
    panel.style.minWidth = `${Math.round(controlRect.width)}px`;
    panel.style.width = `${Math.round(width)}px`;
    panel.style.left = `${Math.round(left - fixedOrigin.left)}px`;
    panel.style.top = `${Math.round(top - fixedOrigin.top)}px`;
    panel.style.maxHeight = `${Math.round(height)}px`;
  }

  function getFixedLayerOrigin(element) {
    let parent = element?.parentElement || null;
    while (parent && parent !== document.body && parent !== document.documentElement) {
      const style = window.getComputedStyle(parent);
      const willChange = (style.willChange || "").toLowerCase();
      const contain = (style.contain || "").toLowerCase();
      const createsFixedLayer =
        style.transform !== "none" ||
        style.filter !== "none" ||
        style.backdropFilter !== "none" ||
        style.perspective !== "none" ||
        willChange.includes("transform") ||
        willChange.includes("filter") ||
        willChange.includes("perspective") ||
        /\b(layout|paint|strict|content)\b/.test(contain);
      if (createsFixedLayer) {
        const rect = parent.getBoundingClientRect();
        return { left: rect.left, top: rect.top };
      }
      parent = parent.parentElement;
    }
    return { left: 0, top: 0 };
  }

  function updateCustomSelect(select) {
    const ui = select?._adminSelectUi;
    if (!ui) return;

    const selected =
      select.options[select.selectedIndex] ||
      Array.from(select.options).find((option) => !option.disabled) ||
      null;
    ui.trigger.textContent = selected?.textContent?.trim() || "Selecione";
    ui.trigger.disabled = Boolean(select.disabled);
    ui.wrap.classList.toggle("is-disabled", Boolean(select.disabled));

    ui.options.querySelectorAll(".tl-clientes-select-option").forEach((button) => {
      const active = button.dataset.value === String(select.value ?? "");
      button.classList.toggle("is-selected", active);
      button.setAttribute("aria-selected", active ? "true" : "false");
    });
  }

  function refreshCustomSelect(select) {
    if (!select || select.dataset.adminCustomSelect !== "true") return;
    buildCustomSelectOptions(select);
    updateCustomSelect(select);
  }

  function refreshCustomSelects(container = document) {
    container.querySelectorAll("select[data-admin-custom-select='true']").forEach(refreshCustomSelect);
  }

  function buildCustomSelectOptions(select) {
    const ui = select?._adminSelectUi;
    if (!ui) return;
    ui.options.innerHTML = "";

    Array.from(select.options).forEach((option) => {
      const button = document.createElement("button");
      button.type = "button";
      button.className = "tl-clientes-select-option";
      button.dataset.value = option.value;
      button.setAttribute("role", "option");
      if (option.disabled) button.disabled = true;

      const label = document.createElement("span");
      label.className = "tl-clientes-select-option-label";
      label.textContent = option.textContent?.trim() || "";
      button.appendChild(label);

      const mark = document.createElement("span");
      mark.className = "tl-clientes-select-option-mark";
      mark.textContent = "Selecionado";
      button.appendChild(mark);

      button.addEventListener("click", () => {
        if (option.disabled || select.disabled) return;
        select.value = option.value;
        select.dispatchEvent(new Event("change", { bubbles: true }));
        closeListControls();
        ui.trigger.focus();
      });

      ui.options.appendChild(button);
    });
  }

  function transformCustomSelect(select) {
    if (!select || select.dataset.adminCustomSelect === "true") return;
    const parent = select.parentElement;
    if (!parent) return;

    const wrap = document.createElement("div");
    wrap.className = [
      "tl-clientes-select-wrap",
      "tl-admin-select-wrap",
      select.closest(".tl-access-toolbar") ? "tl-admin-select-wrap--filter" : "",
      select.closest(".tl-modal-body, .tl-form-grid") ? "tl-admin-select-wrap--modal" : "",
      select.classList.contains("tl-inline-select") ? "tl-admin-select-wrap--inline" : ""
    ].filter(Boolean).join(" ");
    parent.insertBefore(wrap, select);
    wrap.appendChild(select);

    select.classList.add("tl-clientes-select--native");
    select.dataset.adminCustomSelect = "true";

    const trigger = document.createElement("button");
    trigger.type = "button";
    trigger.className = "tl-clientes-select-trigger";
    trigger.setAttribute("aria-haspopup", "listbox");
    trigger.setAttribute("aria-expanded", "false");

    const options = document.createElement("div");
    options.className = "tl-clientes-select-options";
    options.setAttribute("role", "listbox");

    wrap.appendChild(trigger);
    wrap.appendChild(options);

    select._adminSelectUi = { wrap, trigger, options };
    buildCustomSelectOptions(select);
    updateCustomSelect(select);

    trigger.addEventListener("click", () => {
      if (select.disabled) return;
      const isOpen = options.classList.contains("is-open");
      closeListControls(isOpen ? null : wrap);
      if (!isOpen) {
        positionListPanel(wrap, options);
        wrap.classList.add("is-open");
        options.classList.add("is-open");
        trigger.setAttribute("aria-expanded", "true");
      }
    });

    trigger.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && options.classList.contains("is-open")) {
        closeListControls();
        event.stopPropagation();
      }
    });

    select.addEventListener("change", () => {
      updateCustomSelect(select);
    });
  }

  function observeFuncionarioListControls() {
    if (adminListControlObserver || !document.body) return;
    adminListControlObserver = new MutationObserver((mutations) => {
      const containers = new Set();
      mutations.forEach((mutation) => {
        mutation.addedNodes.forEach((node) => {
          if (!(node instanceof Element)) return;
          containers.add(node);
        });
      });
      containers.forEach((container) => enhanceFuncionarioListControls(container));
    });
    adminListControlObserver.observe(document.body, { childList: true, subtree: true });
  }

  function getComboOptions(input) {
    const listId = input?.dataset.comboList || input?.getAttribute("list") || "";
    const datalist = listId ? document.getElementById(listId) : null;
    const options = sortOptionValues(Array.from(datalist?.options || []).map((option) => option.value || option.textContent || ""));
    const vago = options.find((option) => normalizeOptionText(option) === "vago");
    return vago ? [vago, ...options.filter((option) => normalizeOptionText(option) !== "vago")] : options;
  }

  function buildComboOptions(input) {
    const ui = input?._adminComboUi;
    if (!ui) return;

    const query = normalizeOptionText(input.value);
    const allOptions = getComboOptions(input);
    const filtered = allOptions
      .filter((option) => !query || normalizeOptionText(option).includes(query))
      .slice(0, 80);

    ui.options.innerHTML = "";

    if (!filtered.length) {
      const empty = document.createElement("div");
      empty.className = "tl-admin-combo-empty";
      empty.textContent = "Nenhuma opção encontrada";
      ui.options.appendChild(empty);
      return;
    }

    filtered.forEach((option) => {
      const button = document.createElement("button");
      button.type = "button";
      button.className = "tl-admin-combo-option";
      button.textContent = option;
      button.dataset.value = option;
      button.setAttribute("role", "option");
      button.classList.toggle("is-selected", normalizeOptionText(option) === normalizeOptionText(input.value));

      button.addEventListener("mousedown", (event) => {
        event.preventDefault();
      });

      button.addEventListener("click", () => {
        input.value = option;
        input.dispatchEvent(new Event("input", { bubbles: true }));
        input.dispatchEvent(new Event("change", { bubbles: true }));
        closeListControls();
        input.focus();
      });

      ui.options.appendChild(button);
    });
  }

  function openCombo(input) {
    const ui = input?._adminComboUi;
    if (!ui) return;
    buildComboOptions(input);
    closeListControls(ui.wrap);
    positionListPanel(ui.wrap, ui.options);
    ui.wrap.classList.add("is-open");
    ui.options.classList.add("is-open");
    input.setAttribute("aria-expanded", "true");
  }

  function transformComboInput(input) {
    if (!input || input.dataset.adminCombo === "true") return;
    const listId = input.getAttribute("list");
    if (!listId) return;
    const parent = input.parentElement;
    if (!parent) return;

    const wrap = document.createElement("div");
    wrap.className = "tl-admin-combo-wrap";
    parent.insertBefore(wrap, input);
    wrap.appendChild(input);

    const options = document.createElement("div");
    options.className = "tl-admin-combo-options";
    options.setAttribute("role", "listbox");
    wrap.appendChild(options);

    input.dataset.comboList = listId;
    input.dataset.adminCombo = "true";
    input.classList.add("tl-admin-combo-input");
    input.setAttribute("autocomplete", "off");
    input.setAttribute("aria-haspopup", "listbox");
    input.setAttribute("aria-expanded", "false");
    input.removeAttribute("list");

    input._adminComboUi = { wrap, options };

    input.addEventListener("focus", () => openCombo(input));
    input.addEventListener("input", () => openCombo(input));
    input.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        closeListControls();
        event.stopPropagation();
        return;
      }
      if (event.key === "ArrowDown") {
        event.preventDefault();
        openCombo(input);
        options.querySelector(".tl-admin-combo-option")?.focus();
      }
    });

    options.addEventListener("keydown", (event) => {
      const current = document.activeElement;
      if (!(current instanceof HTMLElement)) return;
      if (event.key === "Escape") {
        closeListControls();
        event.stopPropagation();
        input.focus();
        return;
      }
      if (event.key === "ArrowDown" || event.key === "ArrowUp") {
        event.preventDefault();
        const buttons = Array.from(options.querySelectorAll(".tl-admin-combo-option"));
        const index = buttons.indexOf(current);
        const next = event.key === "ArrowDown"
          ? buttons[Math.min(index + 1, buttons.length - 1)]
          : buttons[Math.max(index - 1, 0)];
        next?.focus();
      }
    });
  }

  function enhanceFuncionarioListControls(container = document) {
    container.querySelectorAll("select").forEach(transformCustomSelect);
    container.querySelectorAll("input[list]").forEach(transformComboInput);
