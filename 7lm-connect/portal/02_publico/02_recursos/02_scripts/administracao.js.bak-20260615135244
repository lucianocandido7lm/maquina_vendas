  function getFuncionarioLiderancaContato(nome) {
    const nomeNormalizado = normalizeOptionText(nome);
    if (!nomeNormalizado) return { email: "", documento: "" };

    const funcionarios = Array.isArray(state.funcionarios) ? state.funcionarios : [];
    const match = funcionarios.find((funcionario) => {
      return [
        funcionario.nome,
        funcionario.nome_completo,
        funcionario.nome_preferido,
        funcionario.apelido
      ].some((valor) => normalizeOptionText(valor) === nomeNormalizado);
    });

    return {
      email: match?.email || match?.correio_eletronico || match?.email_corporativo || "",
      documento: match?.documento || match?.cpf || ""
    };
  }

  function clearFuncionarioEquipeContatoLideranca(container = document) {
    const scope = container || document;
    FUNCIONARIO_EQUIPE_CONTATO_LIDERANCA_FIELDS.forEach((selector) => {
      setInputValueAndNotify(scope.querySelector(selector), "");
    });
  }

  function applyFuncionarioEquipeContatoLideranca(container = document, equipe = null, options = {}) {
    const scope = container || document;
    const item = equipe ? normalizarEquipeFuncionario(equipe) : null;
    if (!item) {
      clearFuncionarioEquipeContatoLideranca(scope);
      return;
