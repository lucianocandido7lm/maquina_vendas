    ["#modalFuncionarioRegiao", (equipe) => equipe.regiao || ""],
    ["#modalFuncionarioFoco", (equipe) => equipe.regiao || ""],
    ["#modalFuncionarioGestor", (equipe) => equipe.gerente_vendas || ""],
    ["#modalFuncionarioCoordenador", (equipe) => equipe.gerente_comercial || ""],
    ["#modalFuncionarioGerente", (equipe) => equipe.gerente_regional || ""],
