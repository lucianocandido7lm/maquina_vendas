  async function loadFuncionarios() {
    if (!el.listaFuncionarios) return;

    const params = new URLSearchParams();
    const q = (el.inputFuncionarioBusca?.value || "").trim();
    const vinculo = el.selectFuncionarioVinculo?.value || "";
    const imobiliaria = el.selectFuncionarioImobiliaria?.value || "";
    const status = el.selectFuncionarioStatus?.value || "";
    const login = el.selectFuncionarioLogin?.value || "";

    if (q) params.set("q", q);
    if (vinculo) params.set("vinculo", vinculo);
    if (imobiliaria) params.set("imobiliaria", imobiliaria);
    if (status) params.set("status", status);
    if (login) params.set("login", login);
    params.set("limite", "1000");

    const url = `${ENDPOINT_FUNCIONARIOS}?${params.toString()}`;
    const requestId = ++state.funcionariosRequestId;
    const res = await apiFetch(url, { method: "GET" });

    if (requestId !== state.funcionariosRequestId) {
      return;
    }

    if (handleAuthOrPermission(res, "Não foi possível validar sua sessão para consultar pessoas.")) {
      return;
    }

    if (!res.ok) {
      renderEmpty(el.listaFuncionarios, "ID", "Pessoas indisponíveis", extractErrorMessage(res.payload, "Não foi possível consultar pessoas."));
      return;
    }

    state.funcionarios = Array.isArray(res.payload?.items) ? res.payload.items : [];
    syncFuncionarioFilterOptions();
    renderFuncionarios(state.funcionarios);
  }

