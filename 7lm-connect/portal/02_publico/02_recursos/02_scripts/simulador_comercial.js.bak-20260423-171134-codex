    }

    const parcelaCliente = normalizeClientInstallment();
    if (!parcelaCliente.valido) {
      el.sugestoesLista.innerHTML = `<div class="tl-sim-empty">Informe a parcela mensal do cliente entre ${escapeHtml(formatMoney(parcelaCliente.minimo))} e ${escapeHtml(formatMoney(parcelaCliente.maximo || 0))} para carregar a vitrine.</div>`;
      return;
    }

    if (!state.sugestoes.length) {
      el.sugestoesLista.innerHTML = '<div class="tl-sim-empty">Nenhuma sugestao foi carregada para esse perfil. Clique em "Atualizar sugestoes" para tentar novamente.</div>';
      return;
    }

    if (!visibleSuggestions.length) {
      el.sugestoesLista.innerHTML = '<div class="tl-sim-empty">Nenhum imovel encontrado nesse filtro. Limpe a busca ou troque o modo para ver outras opcoes.</div>';
