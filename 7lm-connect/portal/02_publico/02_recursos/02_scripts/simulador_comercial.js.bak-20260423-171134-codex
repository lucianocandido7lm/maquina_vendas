  function reservationSummary(reserva) {
    if (!reserva) return "";
    const partes = [];
    if (reserva.reservado_em) partes.push(`Reserva em ${formatDateTimeLabel(reserva.reservado_em)}`);
    if (parseMoney(reserva.negociacao?.entrada || 0) > 0) partes.push(`Entrada ${formatMoney(reserva.negociacao.entrada)}`);
    if (parseMoney(reserva.negociacao?.valor_total_operacao || 0) > 0) partes.push(`Operacao ${formatMoney(reserva.negociacao.valor_total_operacao)}`);
    return partes.join(" • ");
