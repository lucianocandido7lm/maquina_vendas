    if (!el.sugestoesLista) return;

    const visibleSuggestions = getVisibleSuggestions();
    renderSuggestionsSummary(visibleSuggestions);

    if (!state.clienteSelecionado) {
      el.sugestoesLista.innerHTML = '<div class="tl-sim-empty">Selecione um cliente para ver os imoveis sugeridos.</div>';
