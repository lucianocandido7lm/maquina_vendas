        <strong>Carregando...</strong>
        <span class="tl-sim-chip">buscando imoveis</span>
        <span class="tl-sim-chip">calculando perfil</span>
      `;
    }
    if (el.sugestoesLista) {
      el.sugestoesLista.innerHTML = `<div class="tl-sim-empty">${escapeHtml(message || "Carregando imoveis sugeridos...")}</div>`;
    }
  }

