  function editableSimulationFields() {
    return [
      [ids.parcelaBanco, "Informe a parcela mensal do cliente. Minimo de R$ 50,00 e maximo de 45% da renda."],
      [ids.subsidio, "Informe o valor de subsidio usado nesta proposta"],
      [ids.chequeMoradia, "Informe o valor de cheque moradia usado nesta proposta"],
