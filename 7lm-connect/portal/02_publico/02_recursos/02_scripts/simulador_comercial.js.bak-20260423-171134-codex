    const maiorObra = Math.max(...timeline.map((item) => item.percentualObra), 0);
    const mesPico = timeline.find((item) => item.totalCliente === maiorParcela) || timeline[0];
    const ultimoMes = timeline[timeline.length - 1];
    const width = 980;
