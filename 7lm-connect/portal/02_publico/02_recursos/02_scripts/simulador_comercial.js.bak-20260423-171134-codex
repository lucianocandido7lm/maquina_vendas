        <span><i class="is-parcela"></i>Pago acumulado 7LM</span>
      </div>
      <div class="tl-sim-chart__frame">
        <div class="tl-sim-chart__tooltip" hidden></div>
        <svg class="tl-sim-chart__svg" viewBox="0 0 ${width} ${height}" role="img" aria-label="Grafico mensal da capacidade do cliente, do saldo devedor e do pago acumulado da 7LM">
          <rect x="0" y="0" width="${width}" height="${height}" rx="24" class="tl-sim-chart__bg" />
          ${grid}
          <text x="${left}" y="32" class="tl-sim-chart__axis-title">Valores mensais</text>
          <rect x="${left}" y="${top}" width="${Math.max(24, right - left)}" height="${plotHeight}" rx="22" class="tl-sim-chart__focus-band"></rect>
          <path d="${smoothPath("capacidadeCliente")}" class="tl-sim-chart__line is-capacidade" />
          <path d="${smoothPath("proSolutoRestante")}" class="tl-sim-chart__line is-prosoluto" />
          <path d="${smoothPath("parcelaAcumulada")}" class="tl-sim-chart__line is-parcela" />
          <line x1="${xFor(defaultFocusIndex).toFixed(2)}" y1="${top}" x2="${xFor(defaultFocusIndex).toFixed(2)}" y2="${bottom}" class="tl-sim-chart__focus-line" />
          <circle class="tl-sim-chart__focus-point is-capacidade" r="6.5"></circle>
          <circle class="tl-sim-chart__focus-point is-prosoluto" r="6.5"></circle>
          <circle class="tl-sim-chart__focus-point is-parcela" r="6.5"></circle>
          ${labels}
          ${hotzones}
        </svg>
      </div>
      <p class="tl-sim-chart__note">A linha principal mostra a capacidade maxima do cliente. Passe o mouse ou toque em um mes para ver banco, 7LM e os percentuais do periodo na tooltip.</p>
    `;

    bindParcelasGraficoInteractions(
      timeline,
      { width, xFor, yValor },
      defaultFocusIndex,
    );
