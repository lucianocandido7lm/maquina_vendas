    if (el.btnFecharModal) el.btnFecharModal.addEventListener("click", closeModal);
    if (el.btnCancelarModal) el.btnCancelarModal.addEventListener("click", closeModal);
    if (el.btnSalvarModal) el.btnSalvarModal.addEventListener("click", saveModal);

    if (el.modalShell) {
      el.modalShell.addEventListener("click", (e) => {
        const target = e.target;
        if (target && target.getAttribute && target.getAttribute("data-close-modal") === "true") {
          closeModal();
