  function detectApiBaseUrl() {
    try {
      const { protocol, hostname, port, origin } = window.location;
      const isLocal = hostname === "127.0.0.1" || hostname === "localhost";

      if (isLocal && port === "3000") {
        return `${protocol}//${hostname}:8000`;
      }

      return origin;
    } catch {
      return "http://127.0.0.1:8000";
    }
  }

  const API_BASE_URL = meta("sevenlm-connect-api-base-url", detectApiBaseUrl());

  function isAbsoluteUrl(value) {
    return /^https?:\/\//i.test(String(value || ""));
  }

  function trimTrailingSlash(value) {
    return String(value || "").replace(/\/+$/, "");
  }

  function ensureLeadingSlash(value) {
    const text = String(value || "");
    return text.startsWith("/") ? text : `/${text}`;
  }

  function joinBaseAndPath(base, path) {
    return `${trimTrailingSlash(base)}${ensureLeadingSlash(path)}`;
  }

  function uniqueStrings(values) {
    return [...new Set((values || []).filter(Boolean))];
  }

  function buildApiCandidates(url) {
    if (isAbsoluteUrl(url)) {
      return [url];
    }

    const path = ensureLeadingSlash(url);
    const origin = trimTrailingSlash(window.location.origin);
    const apiBase = trimTrailingSlash(API_BASE_URL);

    const candidates = [];
    candidates.push(joinBaseAndPath(apiBase, path));

    if (apiBase !== origin) {
      candidates.push(joinBaseAndPath(origin, path));
    }

    return uniqueStrings(candidates);
  }

  function getFetchCredentials(finalUrl) {
    try {
