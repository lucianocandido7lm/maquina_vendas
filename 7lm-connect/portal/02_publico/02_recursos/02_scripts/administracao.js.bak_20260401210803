  async function loadCurrentUser() {
    const token = getAccessToken();

    if (!token) {
      setSessionStatus("Sem sessÃ£o");
      releasePageGate();
      renderNoAccessState(
        "SessÃ£o ausente",
        "Nenhum token foi encontrado para validar sua sessÃ£o atual."
      );
      return false;
    }

    setSessionStatus("Validando...");
    fillUserFromCache();

    const res = await apiFetch(ENDPOINT_ME, { method: "GET" });

    if (res.unauthorized) {
      releasePageGate();
      renderNoAccessState(
        "SessÃ£o expirada",
        "Sua sessÃ£o nÃ£o pÃ´de ser validada. FaÃ§a login novamente quando quiser continuar."
      );
      return false;
    }

    if (res.forbidden) {
      console.warn("[ADMIN] /me retornou 403. SessÃ£o mantida, contexto validarÃ¡ permissÃ£o.");
      fillUserFromCache();
      setSessionStatus("SessÃ£o ativa");
      return true;
    }

    if (!res.ok) {
      console.warn("[ADMIN] /me nÃ£o respondeu OK:", res.status, res.payload);
      fillUserFromCache();
      setSessionStatus("SessÃ£o ativa");
      return true;
    }

    const user =
      res.payload?.usuario ||
      res.payload?.user ||
      res.payload?.data ||
      res.payload;

    if (user && typeof user === "object" && Object.keys(user).length > 0) {
      state.currentUser = user;
      if (portalState?.cacheUser) {
        portalState.cacheUser(user);
      } else {
        try {
          writeSession(USER_KEY, JSON.stringify(user));
        } catch {}
      }
      fillCurrentUser(user);
    } else {
      fillUserFromCache();
    }

    setSessionStatus("Verificado");
    return true;
  }

  async function loadContext() {
    setAdminStatus("Validando...");

    const res = await apiFetch(ENDPOINT_CONTEXTO, { method: "GET" });

    if (res.unauthorized) {
      setAdminStatus("SessÃ£o expirada");
      releasePageGate();
      renderNoAccessState(
        "SessÃ£o expirada",
        "Sua sessÃ£o expirou ou o token atual nÃ£o Ã© mais vÃ¡lido."
      );
      return false;
    }

    if (res.forbidden) {
      setAdminStatus("Sem permissÃ£o");
      releasePageGate();
      renderNoAccessState(
        "Acesso negado",
        extractErrorMessage(res.payload, "VocÃª nÃ£o possui permissÃ£o para acessar AdministraÃ§Ã£o.")
      );
      return false;
    }

    if (!res.ok || !res.payload) {
      console.warn("[ADMIN] contexto indisponÃ­vel:", res.status, res.payload);
      setAdminStatus("IndisponÃ­vel");
      return true;
    }

    state.context = res.payload;

    const usuarioLogado =
      res.payload.usuario_logado ||
      res.payload.usuario ||
      null;

    if (usuarioLogado && typeof usuarioLogado === "object") {
      state.currentUser = usuarioLogado;
      if (portalState?.cacheUser) {
        portalState.cacheUser(usuarioLogado);
      } else {
        try {
          writeSession(USER_KEY, JSON.stringify(usuarioLogado));
        } catch {}
      }
      fillCurrentUser(usuarioLogado);
    }

    if (res.payload.allowed === false || res.payload.pode_acessar === false) {
      setAdminStatus("Sem permissÃ£o");
      releasePageGate();
      renderNoAccessState(
        "Acesso negado",
        "VocÃª nÃ£o possui permissÃ£o para acessar AdministraÃ§Ã£o."
      );
      return false;
    }

    setAdminStatus(res.payload.manage ? "Gerenciamento" : "Consulta");
    return true;
  }

