  function escapeHtml(v) {
    if (shared?.escapeHtml) return shared.escapeHtml(String(v ?? ""));
    return String(v ?? "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#39;");
  }

  function normalizarBusca(v) {
