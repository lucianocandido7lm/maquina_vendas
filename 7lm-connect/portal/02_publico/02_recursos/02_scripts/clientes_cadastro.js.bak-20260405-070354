  async function carregarComposicaoFamiliar() {
    if (!state.edicaoId) {
      state.composicaoFamiliar = [];
      renderComposicaoFamiliar();
      return;
    }

    try {
      const payload = await api(endpoint(ENDPOINTS.composicao, state.edicaoId), "GET");
      state.composicaoFamiliar = Array.isArray(payload?.items) ? payload.items : [];
      renderComposicaoFamiliar();
    } catch (erro) {
      renderComposicaoFamiliar();
      mostrarMensagem("error", mensagemErro(erro, "Nao foi possivel carregar a composicao familiar."));
    }
  }

