  function renderList(items) {
    if (!items.length) {
      el.lista.innerHTML = `<article class="tl-imoveis-empty"><strong>Nenhum imovel encontrado</strong><p>Refine os filtros para continuar.</p></article>`;
      renderCompareDock();
