      { label: "Posicao", value: text(d.posicao) || "-" },
      possuiSuite ? { label: "Suite", value: "Sim" } : null,
      vistaInfo ? { label: "Vista", value: vistaInfo } : null,
      condicaoInfo ? { label: "Condicao", value: condicaoInfo } : null,
    ].filter(Boolean);
    return {
      left: `
      <div class="tl-imoveis-showroom__actions-wrap">
        <div class="tl-imoveis-showroom__actions-head">
          <span class="tl-imoveis-eyebrow mono-font">ACOES</span>
