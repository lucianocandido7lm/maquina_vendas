      produto: String(data.get("produto") || "").trim(),
      corretor: String(data.get("corretor") || "").trim(),
      cca_vinculado: String(data.get("cca_vinculado") || "").trim(),
      empreendimento: String(data.get("empreendimento") || "").trim(),
