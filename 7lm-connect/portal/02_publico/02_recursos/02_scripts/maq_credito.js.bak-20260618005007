          return `
            <a class="tl-mc-doc-file" href="${escapeHtml(item.url)}" target="_blank" rel="noreferrer">
              <span class="tl-mc-doc-file__name">${fileName}</span>
              <span class="tl-mc-doc-file__meta">Abrir</span>
