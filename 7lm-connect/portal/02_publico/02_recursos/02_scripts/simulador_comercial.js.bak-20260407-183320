      : '<div class="tl-sim-empty">Este cliente ainda nao possui reservas ativas de imoveis.</div>';

    el.clienteSelecionado.innerHTML = `
      <div class="tl-sim-seat">
        <div class="tl-sim-seat__card tl-sim-seat__card--summary">
          <div class="tl-sim-seat__identity">
            <div class="tl-sim-seat__avatar">${escapeHtml(initialsFromName(cliente.nome_completo))}</div>
            <div class="tl-sim-seat__identity-copy">
              <span class="tl-sim-seat__eyebrow">Perfil do cliente</span>
