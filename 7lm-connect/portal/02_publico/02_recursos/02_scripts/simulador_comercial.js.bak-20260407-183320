      showFeedback("warning", "Selecione um imovel antes de abrir o mapa.");
      return;
    }

    const mapData = buildPropertyMapData(imovel);
    if (!mapData.embedUrl && !mapData.searchUrl) {
      showFeedback("warning", "Esse imovel ainda nao tem localizacao suficiente para abrir o mapa.");
      return;
    }

    if (el.mapaTitulo) {
      el.mapaTitulo.textContent = imovel.titulo || "Ver no mapa";
