    el.statusBadge.classList.remove("tl-sim-status--ideal", "tl-sim-status--atencao", "tl-sim-status--invalida", "tl-sim-status--neutro");
    if (value === "ideal") {
      el.statusBadge.classList.add("tl-sim-status--ideal");
      el.statusBadge.textContent = "Operacao ideal";
