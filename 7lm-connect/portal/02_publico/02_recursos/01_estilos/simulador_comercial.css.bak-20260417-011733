  width: 10px;
  height: 10px;
  border-radius: 999px;
  background: #0f7bff;
}

.tl-sim-chart__legend i.is-prosoluto {
  background: #0f7bff;
}

.tl-sim-chart__legend i.is-parcela {
  background: #f59e0b;
}

.tl-sim-chart__legend i.is-7lm {
  background: #10b981;
}

.tl-sim-chart__legend i.is-banco {
  background: #f59e0b;
}

.tl-sim-chart__legend i.is-renda {
  background: #7c3aed;
}

.tl-sim-chart__legend i.is-recebimento {
  background: linear-gradient(135deg, #0ea5e9, #14b8a6);
}

.tl-sim-chart__legend i.is-obra {
  background: #06b6d4;
}

.tl-sim-chart__svg {
  display: block;
  width: 100%;
  min-height: 360px;
}

.tl-sim-chart__bg {
  fill: rgba(255, 255, 255, 0.68);
}

.tl-sim-chart__focus-band {
  fill: rgba(15, 123, 255, 0.06);
  transition: x 0.18s ease, width 0.18s ease;
}

.tl-sim-chart__grid-line {
  stroke: rgba(18, 24, 38, 0.055);
  stroke-width: 1;
}

.tl-sim-chart__axis-label {
  fill: rgba(42, 50, 66, 0.58);
  font-size: 12px;
  font-weight: 800;
}

.tl-sim-chart__axis-label.is-bottom {
