}

.tl-sim-chart__axis-label.is-right {
  fill: rgba(124, 58, 237, 0.68);
}

.tl-sim-chart__axis-label.is-limit {
  fill: rgba(180, 35, 24, 0.72);
}

.tl-sim-chart__axis-title {
  fill: rgba(42, 50, 66, 0.6);
  font-size: 13px;
  font-weight: 900;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.tl-sim-chart__axis-title.is-right {
  fill: rgba(124, 58, 237, 0.72);
}

.tl-sim-chart__line {
  fill: none;
  stroke-linecap: round;
  stroke-linejoin: round;
  vector-effect: non-scaling-stroke;
  transition: opacity 0.18s ease;
}

.tl-sim-chart__line.is-total {
  stroke: #0f7bff;
  stroke-width: 4.5;
  filter: drop-shadow(0 8px 12px rgba(15, 123, 255, 0.16));
}

.tl-sim-chart__line.is-prosoluto {
  stroke: #0f7bff;
  stroke-width: 3.7;
  filter: drop-shadow(0 10px 18px rgba(15, 123, 255, 0.12));
}

.tl-sim-chart__line.is-parcela {
  stroke: #f59e0b;
  stroke-width: 3.5;
  filter: drop-shadow(0 10px 18px rgba(245, 158, 11, 0.14));
}

.tl-sim-chart__line.is-7lm {
  stroke: #10b981;
  stroke-width: 4.2;
  filter: drop-shadow(0 8px 12px rgba(16, 185, 129, 0.15));
}

.tl-sim-chart__line.is-banco {
  stroke: #f59e0b;
  stroke-width: 4.2;
  filter: drop-shadow(0 8px 12px rgba(245, 158, 11, 0.14));
}

.tl-sim-chart__line.is-recebimento {
  stroke: url(#simChartReceived);
  stroke-width: 3.2;
  stroke-dasharray: 7 9;
  opacity: 0.9;
  filter: drop-shadow(0 8px 12px rgba(14, 165, 233, 0.14));
}

.tl-sim-chart__dot {
  fill: #0f7bff;
  stroke: #fff;
  stroke-width: 3;
}

.tl-sim-chart__focus-line {
  stroke: rgba(15, 123, 255, 0.18);
  stroke-width: 1.5;
  stroke-dasharray: 4 8;
}

.tl-sim-chart__focus-point {
  stroke-width: 4;
}

.tl-sim-chart__focus-point.is-total {
  fill: #0f7bff;
  stroke: rgba(255, 255, 255, 0.98);
}

.tl-sim-chart__focus-point.is-prosoluto {
  fill: #0f7bff;
  stroke: rgba(255, 255, 255, 0.98);
}

.tl-sim-chart__focus-point.is-parcela {
  fill: #f59e0b;
  stroke: rgba(255, 255, 255, 0.98);
}

.tl-sim-chart__focus-point.is-banco {
  fill: #f59e0b;
  stroke: rgba(255, 255, 255, 0.98);
}

.tl-sim-chart__focus-point.is-7lm {
  fill: #10b981;
  stroke: rgba(255, 255, 255, 0.98);
}

.tl-sim-chart__focus-point.is-recebimento {
  fill: #14b8a6;
  stroke: rgba(255, 255, 255, 0.98);
}

.tl-sim-chart__hotspot {
  fill: transparent;
  cursor: crosshair;
  pointer-events: all;
  transition: fill 0.18s ease;
}

.tl-sim-chart__hotspot.is-active,
.tl-sim-chart__hotspot:hover,
.tl-sim-chart__hotspot:focus {
  fill: rgba(15, 123, 255, 0.045);
  outline: none;
}

.tl-sim-chart__marker circle {
  fill: #0f7bff;
  stroke: #fff;
  stroke-width: 3;
}

.tl-sim-chart__marker text {
  fill: rgba(18, 24, 38, 0.8);
  font-size: 12px;
  font-weight: 900;
}

.tl-sim-chart__marker.is-banco circle {
  fill: #f59e0b;
}

.tl-sim-chart__marker.is-7lm circle {
  fill: #10b981;
}

.tl-sim-chart__marker.is-recebimento circle {
  fill: #14b8a6;
}

.tl-sim-chart__note {
