@media (max-width: 1540px) {
  .tl-mc-workspace {
    grid-template-columns: 1fr;
  }

  .tl-mc-detail-panel {
    position: static;
  }
}

@media (max-width: 1180px) {
  .tl-mc-flow-summary {
    grid-template-columns: 1fr;
  }

  .tl-mc-kit-profiles,
  .tl-mc-kit-summary,
  .tl-mc-role-grid,
  .tl-mc-role-grid--compact {
    grid-template-columns: 1fr 1fr;
  }

  .tl-mc-kit-grid,
  .tl-mc-stage-tracks {
    grid-template-columns: 1fr;
  }

  .tl-mc-doc-section .tl-mc-doc-list,
  .tl-mc-doc-list--journey {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 820px) {
  .tl-mc-shell {
    padding: 14px 12px 24px;
  }

  .tl-mc-header,
  .tl-mc-panel-head,
  .tl-mc-flow-head,
  .tl-mc-role-panel__head,
  .tl-mc-gestor-client-card__head,
  .tl-mc-stage-section__head,
  .tl-mc-modal__head--client {
    flex-direction: column;
  }

  .tl-mc-header__actions,
  .tl-mc-search,
  .tl-mc-flow-actions {
    width: 100%;
    justify-content: stretch;
  }

  .tl-mc-btn,
  .tl-mc-user,
  .tl-mc-search input,
  .tl-mc-search select {
    width: 100%;
    min-width: 0;
  }

  .tl-mc-kpis {
    grid-template-columns: 1fr 1fr;
  }

  .tl-mc-field-grid,
  .tl-mc-modal__body {
    grid-template-columns: 1fr;
  }

  .tl-mc-journey-strip {
    grid-template-columns: 1fr;
  }

  .tl-mc-kit-profiles,
  .tl-mc-kit-summary,
  .tl-mc-flow-metrics,
  .tl-mc-flow-guide,
  .tl-mc-data-grid,
  .tl-mc-role-grid,
  .tl-mc-role-grid--compact,
  .tl-mc-timeline,
  .tl-mc-gestor-client-card__meta {
    grid-template-columns: 1fr 1fr;
  }

  .tl-mc-kit-grid {
    grid-template-columns: 1fr;
  }

  .tl-mc-timeline::before,
  .tl-mc-mini-timeline::before {
    display: none;
  }

  .tl-mc-section-head,
  .tl-mc-missing-strip {
    flex-direction: column;
    align-items: flex-start;
  }

  .tl-mc-role-actions,
  .tl-mc-role-actions__group,
  .tl-mc-role-actions__group--stage,
  .tl-mc-stage-buttons {
    width: 100%;
    justify-content: flex-start;
  }

  .tl-mc-section-counters {
    justify-content: flex-start;
  }

  .tl-mc-doc-controls {
    grid-template-columns: 1fr;
  }

  .tl-mc-action-stack {
    min-width: 0;
  }

  .tl-mc-table .tl-mc-action-btn {
    width: 100%;
  }

  .tl-mc-column-filter__menu {
    left: 0;
    right: auto;
    min-width: 240px;
  }

  .tl-mc-doc-upload__head,
  .tl-mc-doc-picker {
    grid-template-columns: 1fr;
  }

  .tl-mc-doc-picker {
    grid-template-areas:
      "button"
      "summary"
      "hint";
  }

  .tl-mc-doc-upload__head {
    flex-direction: column;
    align-items: flex-start;
  }

  .tl-mc-doc-upload__actions {
    flex-direction: column;
    align-items: stretch;
  }

  .tl-mc-doc-upload__submit {
    width: 100%;
    justify-self: stretch;
  }

  .tl-mc-mini-timeline {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
}

@media (max-width: 540px) {
  .tl-mc-kpis {
    grid-template-columns: 1fr;
  }

  .tl-mc-flow-guide,
  .tl-mc-kit-profiles,
  .tl-mc-kit-summary,
  .tl-mc-flow-metrics,
  .tl-mc-data-grid,
  .tl-mc-role-grid,
  .tl-mc-role-grid--compact,
  .tl-mc-timeline,
  .tl-mc-gestor-client-card__meta,
  .tl-mc-mini-timeline {
    grid-template-columns: 1fr;
  }
}
