  display: grid;
  gap: 8px;
}

.tl-mc-inline-actions {
  display: flex;
  gap: 8px;
  align-items: center;
  flex-wrap: wrap;
  min-width: 0;
}

.tl-mc-detail-panel .tl-mc-inline-actions > .tl-mc-select,
