:root {
  --mc-bg: #f4f8fb;
  --mc-surface: rgba(255, 255, 255, 0.9);
  --mc-surface-strong: #ffffff;
  --mc-border: rgba(15, 23, 42, 0.1);
  --mc-text: #0f172a;
  --mc-muted: #64748b;
  --mc-blue: #0f6fbf;
  --mc-teal: #0f9f8f;
  --mc-green: #22c55e;
  --mc-amber: #f59e0b;
  --mc-red: #ef4444;
  --mc-shadow: 0 24px 80px rgba(15, 23, 42, 0.12);
}

.tl-maq-credito-page {
  background:
    linear-gradient(180deg, rgba(236, 246, 255, 0.86), rgba(246, 250, 252, 0.98) 44%, #f8fafc);
  color: var(--mc-text);
  font-family: "Inter", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.tl-maq-credito-page .tl-main {
  min-width: 0;
  min-height: 0;
  overflow: hidden;
}

.tl-mc-shell {
  flex: 1 1 auto;
  width: min(100%, 1740px);
  height: 100%;
  max-height: 100%;
  min-height: 0;
  margin: 0 auto;
  padding: 22px clamp(16px, 2vw, 24px) 30px clamp(16px, 2vw, 32px);
  overflow-y: auto;
  overflow-x: hidden;
  scrollbar-gutter: stable;
  scrollbar-width: thin;
  scrollbar-color: rgba(15, 111, 191, 0.48) transparent;
}

.tl-mc-shell::-webkit-scrollbar,
.tl-mc-tabs::-webkit-scrollbar,
.tl-mc-table-wrap::-webkit-scrollbar,
.tl-mc-detail-scroll::-webkit-scrollbar {
  width: 10px;
  height: 10px;
}

.tl-mc-shell::-webkit-scrollbar-track,
.tl-mc-tabs::-webkit-scrollbar-track,
.tl-mc-table-wrap::-webkit-scrollbar-track,
.tl-mc-detail-scroll::-webkit-scrollbar-track {
  background: transparent;
  border-radius: 999px;
}

.tl-mc-shell::-webkit-scrollbar-thumb,
.tl-mc-tabs::-webkit-scrollbar-thumb,
.tl-mc-table-wrap::-webkit-scrollbar-thumb,
.tl-mc-detail-scroll::-webkit-scrollbar-thumb {
  border: 2px solid transparent;
  border-radius: 999px;
  background:
    linear-gradient(180deg, rgba(15, 111, 191, 0.72), rgba(15, 159, 143, 0.66)) padding-box;
  box-shadow:
    inset 0 0 0 1px rgba(255, 255, 255, 0.14),
    0 8px 18px rgba(15, 111, 191, 0.12);
}

.tl-mc-shell::-webkit-scrollbar-thumb:hover,
.tl-mc-tabs::-webkit-scrollbar-thumb:hover,
.tl-mc-table-wrap::-webkit-scrollbar-thumb:hover,
.tl-mc-detail-scroll::-webkit-scrollbar-thumb:hover {
  background:
    linear-gradient(180deg, rgba(6, 55, 99, 0.9), rgba(15, 111, 191, 0.82)) padding-box;
}

.tl-mc-shell,
.tl-mc-tabs,
.tl-mc-table-wrap,
.tl-mc-detail-scroll {
  scrollbar-width: thin;
  scrollbar-color: rgba(15, 111, 191, 0.48) transparent;
}

.tl-mc-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 22px;
  padding: 18px 20px;
  border: 1px solid var(--mc-border);
  border-radius: 8px;
  background: var(--mc-surface);
  box-shadow: 0 16px 44px rgba(15, 23, 42, 0.08);
  backdrop-filter: blur(18px);
}

.tl-mc-kicker,
.tl-mc-panel-head span,
.tl-mc-detail-kicker {
  display: block;
  color: var(--mc-blue);
  font-size: 0.74rem;
  font-weight: 900;
  letter-spacing: 0;
  text-transform: none;
}

.tl-mc-header h1 {
  margin: 4px 0 5px;
  color: #101828;
  font-size: clamp(1.45rem, 2.2vw, 2.2rem);
  line-height: 1.05;
  font-weight: 900;
  letter-spacing: 0;
}

.tl-mc-header p {
  margin: 0;
  max-width: 760px;
  color: var(--mc-muted);
  font-size: 0.98rem;
  line-height: 1.45;
}

.tl-mc-header__actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10px;
  flex-wrap: wrap;
}

.tl-mc-user {
  max-width: 240px;
  padding: 10px 12px;
  border: 1px solid var(--mc-border);
  border-radius: 8px;
  background: rgba(248, 250, 252, 0.92);
  color: #334155;
  font-size: 0.84rem;
  font-weight: 800;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.tl-mc-btn,
.tl-mc-tab,
.tl-mc-icon-btn {
  appearance: none;
  border: 0;
  font-family: inherit;
  cursor: pointer;
}

.tl-mc-btn {
  min-height: 42px;
  padding: 0 15px;
  border-radius: 8px;
  font-size: 0.9rem;
  font-weight: 900;
  transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
}

.tl-mc-btn:hover,
.tl-mc-tab:hover,
.tl-mc-icon-btn:hover {
  transform: translateY(-1px);
}

.tl-mc-btn--primary {
  background: linear-gradient(135deg, #0f6fbf, #0f9f8f);
  color: #ffffff;
  box-shadow: 0 14px 30px rgba(15, 111, 191, 0.22);
}

.tl-mc-btn--soft {
  border: 1px solid rgba(15, 111, 191, 0.18);
  background: rgba(239, 246, 255, 0.94);
  color: #0f4f88;
}

.tl-mc-btn--danger {
  border: 1px solid rgba(239, 68, 68, 0.22);
  background: rgba(254, 242, 242, 0.94);
  color: #b91c1c;
}

.tl-mc-tabs {
  display: flex;
  gap: 8px;
  margin: 16px 0;
  padding: 6px;
  border: 1px solid var(--mc-border);
  border-radius: 8px;
  background: rgba(255, 255, 255, 0.72);
  overflow-x: auto;
  scrollbar-width: thin;
}

.tl-mc-tab {
  display: inline-flex;
  align-items: center;
  gap: 9px;
  min-height: 42px;
  padding: 0 14px;
  border-radius: 8px;
  color: #475569;
  background: transparent;
  font-size: 0.9rem;
  font-weight: 900;
  white-space: nowrap;
  text-decoration: none;
}

.tl-mc-tab svg {
  width: 18px;
  height: 18px;
  flex: 0 0 18px;
}

.tl-mc-tab.is-active {
  color: #ffffff;
  background: linear-gradient(135deg, #063763, #0f6fbf);
  box-shadow: 0 12px 26px rgba(15, 111, 191, 0.22);
}

.tl-mc-status {
  margin-bottom: 16px;
  padding: 13px 14px;
  border-radius: 8px;
  border: 1px solid rgba(15, 111, 191, 0.16);
  background: rgba(239, 246, 255, 0.95);
  color: #0f4f88;
  font-size: 0.9rem;
  font-weight: 800;
}

.tl-mc-status.is-error {
  border-color: rgba(239, 68, 68, 0.2);
  background: rgba(254, 242, 242, 0.95);
  color: #b91c1c;
}

.tl-mc-workspace {
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  gap: 16px;
  align-items: start;
}

.tl-mc-shell[data-detail-visible="true"] .tl-mc-workspace {
  grid-template-columns: minmax(0, 1fr) minmax(360px, min(440px, 32vw));
}

.tl-mc-shell:not([data-detail-visible="true"]) .tl-mc-detail-panel {
  display: none;
}

.tl-mc-main-panel,
.tl-mc-detail-panel {
  border: 1px solid var(--mc-border);
  border-radius: 8px;
  background: var(--mc-surface);
  box-shadow: var(--mc-shadow);
}

.tl-mc-main-panel {
  min-width: 0;
  overflow: hidden;
}

.tl-mc-detail-panel {
  position: sticky;
  top: 18px;
  min-width: 0;
  min-height: 520px;
  overflow: hidden;
}

.tl-mc-panel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
  padding: 18px;
  border-bottom: 1px solid var(--mc-border);
}

.tl-mc-panel-head h2 {
  margin: 3px 0 0;
  font-size: 1.25rem;
  line-height: 1.2;
  font-weight: 900;
}

.tl-mc-search {
  display: flex;
  gap: 8px;
  align-items: center;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.tl-mc-search[hidden],
.tl-mc-kpis[hidden] {
  display: none !important;
}

.tl-mc-search input,
.tl-mc-search select,
.tl-mc-input,
.tl-mc-select,
.tl-mc-textarea {
  width: 100%;
  min-width: 0;
  max-width: 100%;
  min-height: 40px;
  box-sizing: border-box;
  border: 1px solid rgba(15, 23, 42, 0.12);
  border-radius: 8px;
  background: #ffffff;
  color: #172033;
  font: 700 0.88rem/1.2 "Inter", sans-serif;
  outline: none;
}

.tl-mc-search input {
  width: min(38vw, 420px);
  min-width: 260px;
  padding: 0 13px;
}

.tl-mc-search select,
.tl-mc-select {
  padding: 0 12px;
}

.tl-mc-input,
.tl-mc-textarea {
  padding: 0 12px;
}

.tl-mc-textarea {
  min-height: 82px;
  padding: 10px 12px;
  resize: vertical;
}

.tl-mc-kpis {
  display: grid;
  grid-template-columns: repeat(4, minmax(160px, 1fr));
  gap: 10px;
  padding: 14px 18px;
  border-bottom: 1px solid var(--mc-border);
}

.tl-mc-kpi {
  min-height: 92px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 8px;
  padding: 13px;
  border: 1px solid rgba(15, 23, 42, 0.08);
  border-radius: 8px;
  background: #ffffff;
}

.tl-mc-kpi span {
  color: var(--mc-muted);
  font-size: 0.78rem;
  font-weight: 900;
  text-transform: none;
}

.tl-mc-kpi strong {
  color: #101828;
  font-size: 1.55rem;
  line-height: 1;
  font-weight: 900;
}

.tl-mc-kpi small {
  color: #64748b;
  font-size: 0.78rem;
  font-weight: 800;
}

.tl-mc-content {
  min-height: 500px;
}

.tl-mc-table-wrap {
  width: 100%;
  overflow-x: auto;
}

.tl-mc-table {
  width: 100%;
  border-collapse: collapse;
  min-width: 1220px;
}

.tl-mc-table th,
.tl-mc-table td {
  padding: 12px 14px;
  border-bottom: 1px solid rgba(15, 23, 42, 0.08);
  text-align: center;
  vertical-align: middle;
}

.tl-mc-table th {
  color: #64748b;
  background: rgba(248, 250, 252, 0.9);
  font-size: 0.72rem;
  font-weight: 900;
  text-transform: none;
  position: relative;
}

.tl-mc-table td {
  color: #172033;
  font-size: 0.88rem;
  font-weight: 500;
}

.tl-mc-table tr {
  transition: background 0.16s ease;
}

.tl-mc-table tbody tr:hover,
.tl-mc-table tbody tr.is-selected {
  background: rgba(239, 246, 255, 0.9);
}

.tl-mc-table button {
  color: #0f6fbf;
  background: transparent;
  border: 0;
  font: 600 0.88rem/1.15 "Inter", sans-serif;
  cursor: pointer;
  text-align: center;
}

.tl-mc-th-filter {
  display: grid;
  gap: 8px;
  min-width: 0;
  text-align: center;
}

.tl-mc-th-filter__label {
  color: #64748b;
  font-size: 0.72rem;
  font-weight: 900;
  line-height: 1.1;
}

.tl-mc-th-filter__hint {
  color: #94a3b8;
  font-size: 0.68rem;
  font-weight: 800;
  line-height: 1.2;
}

.tl-mc-th-filter__input,
.tl-mc-column-filter__toggle,
.tl-mc-column-filter__search-input {
  width: 100%;
  min-width: 0;
  min-height: 38px;
  border: 1px solid rgba(15, 111, 191, 0.16);
  border-radius: 14px;
  background: #ffffff;
  color: #172033;
  font: 800 0.78rem/1.2 "Inter", sans-serif;
  transition: border-color 0.16s ease, box-shadow 0.16s ease, background 0.16s ease;
}

.tl-mc-th-filter__input,
.tl-mc-column-filter__search-input {
  padding: 0 14px;
}

.tl-mc-th-filter__input:focus,
.tl-mc-column-filter__search-input:focus {
  outline: none;
  border-color: rgba(15, 111, 191, 0.32);
  box-shadow: 0 0 0 4px rgba(15, 111, 191, 0.1);
}

.tl-mc-column-filter {
  position: relative;
  min-width: 0;
}

.tl-mc-column-filter__toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  padding: 0 12px;
  cursor: pointer;
  text-align: left;
}

.tl-mc-column-filter__toggle span {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tl-mc-column-filter__toggle::after {
  content: "";
  width: 9px;
  height: 9px;
  flex: 0 0 auto;
  border-right: 2px solid #0f6fbf;
  border-bottom: 2px solid #0f6fbf;
  transform: rotate(45deg) translateY(-1px);
  transition: transform 0.16s ease;
}

.tl-mc-column-filter.is-open .tl-mc-column-filter__toggle::after {
  transform: rotate(-135deg) translateY(-1px);
}

.tl-mc-column-filter__toggle strong {
  min-width: 18px;
  min-height: 18px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999px;
  background: rgba(15, 111, 191, 0.12);
  color: #0f4f88;
  font-size: 0.68rem;
  font-weight: 900;
}

.tl-mc-column-filter__toggle strong:empty {
  display: none;
}

.tl-mc-column-filter__menu {
  position: absolute;
  top: calc(100% + 10px);
  left: 0;
  width: min(320px, calc(100vw - 64px));
  min-width: 260px;
  display: none;
  gap: 10px;
  padding: 12px;
  border: 1px solid rgba(15, 111, 191, 0.18);
  border-radius: 18px;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 24px 44px rgba(15, 23, 42, 0.16);
  backdrop-filter: blur(14px);
  z-index: 30;
}

.tl-mc-column-filter.is-open .tl-mc-column-filter__menu {
  display: grid;
}

.tl-mc-column-filter__actions {
  display: flex;
  justify-content: flex-end;
}

.tl-mc-column-filter__actions button {
  min-height: 28px;
  padding: 0 10px;
  border-radius: 999px;
  background: rgba(241, 245, 249, 0.92);
  color: #8aa8c9;
  font: 900 0.66rem/1 "Inter", sans-serif;
  text-transform: uppercase;
}

.tl-mc-column-filter__list {
  max-height: 240px;
  display: grid;
  gap: 8px;
  padding-right: 4px;
  overflow-y: auto;
}

.tl-mc-column-filter__option {
  display: grid;
  grid-template-columns: 18px minmax(0, 1fr);
  align-items: center;
  gap: 10px;
  min-height: 40px;
  padding: 0 12px;
  border: 1px solid rgba(148, 163, 184, 0.18);
  border-radius: 12px;
  background: rgba(248, 250, 252, 0.88);
  color: #172033;
  font-size: 0.78rem;
  font-weight: 800;
  cursor: pointer;
}

.tl-mc-column-filter__option input {
  width: 16px;
  height: 16px;
  margin: 0;
  accent-color: #0f6fbf;
}

.tl-mc-column-filter__option.is-selected {
  border-color: rgba(15, 111, 191, 0.26);
  background: rgba(219, 234, 254, 0.72);
  color: #0f4f88;
}

.tl-mc-column-filter__empty {
  min-height: 42px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 12px;
  border: 1px dashed rgba(148, 163, 184, 0.22);
  border-radius: 12px;
  color: #94a3b8;
  font-size: 0.74rem;
  font-weight: 800;
}

.tl-mc-table .tl-mc-action-btn {
  justify-content: center;
  min-width: 88px;
  border: 1px solid rgba(15, 111, 191, 0.16);
  background: rgba(239, 246, 255, 0.92);
  color: #0f4f88;
  font: 900 0.78rem/1 "Inter", sans-serif;
  text-align: center;
  white-space: nowrap;
}

.tl-mc-table .tl-mc-action-btn.is-primary {
  border-color: rgba(15, 111, 191, 0.28);
  background: linear-gradient(135deg, #0f6fbf, #0f9f8f);
  color: #ffffff;
  box-shadow: 0 12px 24px rgba(15, 111, 191, 0.16);
}

.tl-mc-action-stack {
  display: grid;
  gap: 6px;
  min-width: 120px;
  justify-items: center;
}

.tl-mc-table-progress,
.tl-mc-table-pending {
  display: grid;
  gap: 6px;
  min-width: 110px;
  justify-items: center;
  text-align: center;
}

.tl-mc-table-progress strong,
.tl-mc-table-pending strong {
  color: #101828;
  font-size: 0.9rem;
  line-height: 1;
  font-weight: 700;
}

.tl-mc-table-progress small,
.tl-mc-table-pending small {
  color: #64748b;
  font-size: 0.72rem;
  line-height: 1.2;
  font-weight: 600;
}

.tl-mc-table-pending strong {
  color: #0f4f88;
}

.tl-mc-muted {
  color: var(--mc-muted);
  font-weight: 600;
}

.tl-mc-chip-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 7px;
  flex-wrap: wrap;
}

.tl-mc-chip {
  display: inline-flex;
  align-items: center;
  min-height: 26px;
  padding: 0 9px;
  border-radius: 999px;
  background: rgba(226, 232, 240, 0.78);
  color: #334155;
  font-size: 0.74rem;
  font-weight: 900;
  white-space: nowrap;
}

.tl-mc-chip--ok {
  background: rgba(220, 252, 231, 0.95);
  color: #15803d;
}

.tl-mc-chip--warn {
  background: rgba(254, 243, 199, 0.96);
  color: #a16207;
}

.tl-mc-chip--danger {
  background: rgba(254, 226, 226, 0.96);
  color: #b91c1c;
}

.tl-mc-chip--info {
  background: rgba(219, 234, 254, 0.96);
  color: #1d4ed8;
}

.tl-mc-empty,
.tl-mc-empty-detail {
  min-height: 260px;
  display: grid;
  place-items: center;
  align-content: center;
  gap: 8px;
  padding: 28px;
  color: #64748b;
  text-align: center;
}

.tl-mc-empty strong,
.tl-mc-empty-detail strong {
  color: #101828;
  font-size: 1rem;
  font-weight: 900;
}

.tl-mc-detail-body {
  display: flex;
  flex-direction: column;
  min-width: 0;
  min-height: 520px;
}

.tl-mc-detail-head {
  padding: 18px;
  border-bottom: 1px solid var(--mc-border);
}

.tl-mc-detail-head h3 {
  margin: 5px 0 4px;
  color: #101828;
  font-size: 1.25rem;
  line-height: 1.1;
  font-weight: 900;
}

.tl-mc-detail-head p {
  margin: 0;
  color: var(--mc-muted);
  font-size: 0.86rem;
  font-weight: 750;
}

.tl-mc-detail-scroll {
  display: grid;
  gap: 14px;
  padding: 16px 18px 20px;
  min-width: 0;
  overflow-y: auto;
  overflow-x: hidden;
}

.tl-mc-client-workflow {
  display: grid;
  gap: 16px;
  min-width: 0;
  padding: 16px 18px 22px;
}

.tl-mc-shell[data-client-view="journey"] .tl-mc-main-panel {
  overflow: visible;
}

.tl-mc-shell[data-client-view="journey"] .tl-mc-content {
  min-height: 0;
}

.tl-mc-client-workflow--page {
  padding-top: 0;
}

.tl-mc-client-workflow--page > .tl-mc-client-workflow--modal {
  padding: 0;
  gap: 16px;
}

.tl-mc-flow-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
  padding-bottom: 14px;
  border-bottom: 1px solid rgba(15, 23, 42, 0.08);
}

.tl-mc-flow-head h3 {
  margin: 5px 0 4px;
  color: #101828;
  font-size: 1.35rem;
  line-height: 1.1;
  font-weight: 900;
}

.tl-mc-flow-head p {
  margin: 0;
  color: var(--mc-muted);
  font-size: 0.86rem;
  font-weight: 750;
}

.tl-mc-flow-head__meta {
  display: grid;
  gap: 4px;
  min-width: 0;
}

.tl-mc-flow-actions {
  display: flex;
  align-items: center;
  gap: 8px;
  flex: 0 0 auto;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.tl-mc-flow-actions .tl-mc-btn--soft,
.tl-mc-flow-actions .tl-mc-role-chip,
.tl-mc-flow-actions .tl-mc-current-stage {
  min-height: 38px;
  padding: 0 15px;
  border-radius: 999px;
  font-size: 0.82rem;
}

.tl-mc-current-stage {
  display: inline-flex;
  align-items: center;
  background: rgba(15, 111, 191, 0.1);
  color: #0f4f88;
  font-weight: 900;
  white-space: nowrap;
}

.tl-mc-flow-guide {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10px;
}

.tl-mc-flow-guide article {
  min-width: 0;
  display: grid;
  gap: 6px;
  padding: 14px;
  border: 1px solid rgba(15, 23, 42, 0.08);
  border-radius: 8px;
  background: rgba(248, 250, 252, 0.82);
}

.tl-mc-flow-guide article strong {
  width: 28px;
  height: 28px;
  display: inline-grid;
  place-items: center;
  border-radius: 999px;
