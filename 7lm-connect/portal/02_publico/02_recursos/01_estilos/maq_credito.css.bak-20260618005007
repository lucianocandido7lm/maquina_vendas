  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
  min-width: 0;
}

.tl-mc-stage-section__head p {
  margin: 4px 0 0;
  color: var(--mc-muted);
  font-size: 0.82rem;
  line-height: 1.45;
  font-weight: 750;
}

.tl-mc-doc-list--journey {
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
}

.tl-mc-empty-inline {
  min-height: 120px;
  display: grid;
  place-items: center;
  align-content: center;
  gap: 8px;
  padding: 18px;
  border: 1px dashed rgba(148, 163, 184, 0.28);
  border-radius: 8px;
  background: rgba(248, 250, 252, 0.92);
  color: var(--mc-muted);
  text-align: center;
}

.tl-mc-empty-inline strong {
  color: #101828;
  font-size: 0.94rem;
  font-weight: 900;
}

.tl-mc-role-grid--compact {
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

.tl-mc-icon-btn {
  min-height: 32px;
  padding: 0 10px;
  border-radius: 8px;
  background: rgba(239, 246, 255, 0.92);
  color: #0f4f88;
  font: 900 0.78rem/1 "Inter", sans-serif;
}

.tl-mc-icon-btn.is-disabled {
  opacity: 0.56;
  cursor: default;
  pointer-events: none;
  text-decoration: none;
}

.tl-mc-modal {
  position: fixed;
  inset: 0;
  z-index: 9200;
  display: grid;
  place-items: center;
  padding: 20px;
  background: rgba(15, 23, 42, 0.42);
}

.tl-mc-modal[hidden] {
  display: none !important;
}

.tl-mc-modal__box {
  width: min(96vw, 760px);
  max-height: min(88vh, 780px);
  overflow: auto;
  border-radius: 8px;
  background: #ffffff;
  box-shadow: 0 24px 80px rgba(15, 23, 42, 0.28);
}

.tl-mc-modal__box--client {
  width: min(96vw, 1420px);
  max-height: min(92vh, 960px);
}

.tl-mc-modal__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 18px;
  border-bottom: 1px solid var(--mc-border);
}

.tl-mc-modal__head h3 {
  margin: 0;
  font-size: 1.1rem;
  font-weight: 900;
}

.tl-mc-modal__meta {
  display: grid;
  gap: 4px;
  min-width: 0;
}

.tl-mc-modal__meta p {
  margin: 0;
  color: var(--mc-muted);
  font-size: 0.84rem;
  font-weight: 750;
}

.tl-mc-modal__body {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  padding: 18px;
}

.tl-mc-modal__body--client {
  display: block;
  padding: 0;
}

