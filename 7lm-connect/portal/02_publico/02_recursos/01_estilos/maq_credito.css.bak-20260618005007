.tl-mc-detail-panel .tl-mc-inline-actions > .tl-mc-icon-btn {
  flex: 0 1 auto;
}

.tl-mc-upload-drop {
  display: grid;
  gap: 8px;
  min-width: 0;
  padding: 12px;
  border: 1px dashed rgba(15, 111, 191, 0.36);
  border-radius: 8px;
  background: rgba(239, 246, 255, 0.58);
}

.tl-mc-upload-drop input {
  width: 100%;
  min-width: 0;
  max-width: 100%;
}

.tl-mc-stage-section {
  gap: 12px;
  padding: 16px;
  border: 1px solid rgba(15, 23, 42, 0.08);
  border-radius: 8px;
  background: rgba(255, 255, 255, 0.82);
}

.tl-mc-stage-section.is-locked {
  border-color: rgba(245, 158, 11, 0.18);
  background: rgba(255, 251, 235, 0.7);
}

