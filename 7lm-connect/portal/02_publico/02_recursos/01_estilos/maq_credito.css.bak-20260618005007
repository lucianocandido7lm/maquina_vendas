  font-weight: 750;
}

.tl-mc-doc-upload__count {
  min-height: 24px;
  display: inline-flex;
  align-items: center;
  padding: 0 8px;
  border-radius: 999px;
  background: rgba(15, 111, 191, 0.1);
  color: #0f4f88;
  font-size: 0.72rem;
  font-weight: 900;
  white-space: nowrap;
}

.tl-mc-doc-upload__steps {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.tl-mc-doc-upload__steps span {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  min-height: 30px;
  padding: 0 12px 0 8px;
  border-radius: 999px;
  background: rgba(15, 111, 191, 0.08);
  color: #0f4f88;
  font-size: 0.72rem;
  font-weight: 850;
  white-space: nowrap;
}

.tl-mc-doc-upload__steps strong {
  width: 20px;
  height: 20px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999px;
  background: rgba(15, 111, 191, 0.14);
  color: #0f4f88;
  font-size: 0.68rem;
  font-weight: 900;
  flex: 0 0 auto;
}

.tl-mc-doc-picker {
  position: relative;
  display: grid;
  grid-template-columns: auto minmax(0, 1fr);
  grid-template-areas:
    "button summary"
    "button hint";
  gap: 10px;
  align-items: start;
  min-width: 0;
  padding: 12px;
  border: 1px dashed rgba(15, 111, 191, 0.28);
  border-radius: 8px;
  background: #ffffff;
  cursor: pointer;
  transition: border-color 0.16s ease, background 0.16s ease, box-shadow 0.16s ease;
}

.tl-mc-doc-picker:hover {
  border-color: rgba(15, 111, 191, 0.42);
  background: rgba(248, 250, 252, 0.96);
  box-shadow: 0 10px 24px rgba(15, 111, 191, 0.08);
}

.tl-mc-doc-picker input {
  position: absolute;
  inset: 0;
  opacity: 0;
  min-width: 0;
  cursor: pointer;
}

.tl-mc-doc-picker__button {
  grid-area: button;
  align-self: center;
  min-height: 32px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 12px;
  border-radius: 999px;
  background: rgba(15, 111, 191, 0.12);
  color: #0f4f88;
  font-size: 0.74rem;
  font-weight: 900;
  white-space: nowrap;
}

.tl-mc-doc-picker__summary {
  grid-area: summary;
  align-self: center;
  min-width: 0;
  color: var(--mc-muted);
  font-size: 0.76rem;
  font-weight: 750;
  line-height: 1.35;
  overflow-wrap: anywhere;
}

.tl-mc-doc-picker__summary[data-has-files="true"] {
  color: #172033;
  font-weight: 800;
}

.tl-mc-doc-picker__hint {
  grid-area: hint;
  min-width: 0;
  color: #64809f;
  font-size: 0.72rem;
  font-weight: 750;
}

.tl-mc-doc-upload__actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
}

.tl-mc-doc-upload__next {
