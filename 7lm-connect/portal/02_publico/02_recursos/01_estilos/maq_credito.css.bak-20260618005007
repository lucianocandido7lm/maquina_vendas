  color: #ffffff;
}

.tl-mc-doc-item.is-missing .tl-mc-doc-marker {
  background: #f59e0b;
  color: #ffffff;
}

.tl-mc-doc-item strong,
.tl-mc-message-item strong,
.tl-mc-upload-item strong {
