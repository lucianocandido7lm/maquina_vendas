  font-size: 0.75rem;
  font-weight: 750;
}

.tl-mc-doc-badge {
  flex: 0 0 auto;
  min-height: 24px;
  display: inline-flex;
  align-items: center;
  padding: 0 8px;
  border-radius: 999px;
  font-size: 0.7rem;
  font-weight: 900;
  white-space: nowrap;
}

.tl-mc-doc-badge.is-done {
  background: rgba(220, 252, 231, 0.95);
  color: #15803d;
}

.tl-mc-doc-badge.is-pending {
  background: rgba(254, 226, 226, 0.96);
  color: #b91c1c;
}

.tl-mc-doc-badge.is-missing {
  background: rgba(254, 243, 199, 0.96);
  color: #a16207;
}

.tl-mc-doc-controls {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto auto;
  gap: 8px;
  align-items: center;
  min-width: 0;
}

.tl-mc-doc-intro {
  display: grid;
  gap: 8px;
}

.tl-mc-doc-intro__hint {
  margin: 0;
  color: #55708f;
  font-size: 0.74rem;
  font-weight: 750;
}

.tl-mc-doc-upload {
  display: grid;
  gap: 10px;
  min-width: 0;
  padding: 12px;
  border: 1px solid rgba(15, 111, 191, 0.16);
