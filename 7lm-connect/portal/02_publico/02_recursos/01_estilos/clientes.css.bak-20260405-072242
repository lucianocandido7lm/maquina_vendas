}

html[data-theme="dark"] .tl-clientes-select-option.is-selected {
  background: linear-gradient(135deg, rgba(0, 179, 222, 0.85), rgba(15, 123, 255, 0.88));
  color: #fff;
}

.tl-clientes-datepicker {
  position: absolute;
  z-index: 120;
  min-width: 280px;
  border-radius: 16px;
  padding: 12px;
  border: 1px solid rgba(255, 255, 255, 0.5);
  background:
    linear-gradient(145deg, rgba(255, 255, 255, 0.9), rgba(255, 255, 255, 0.6)),
    radial-gradient(circle at top left, rgba(0, 179, 222, 0.2), transparent 50%);
  box-shadow: 0 18px 36px rgba(18, 28, 44, 0.2);
  backdrop-filter: blur(14px);
}

.tl-clientes-datepicker__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  margin-bottom: 8px;
}

.tl-clientes-datepicker__title {
  font-weight: 700;
  color: rgba(24, 35, 52, 0.9);
}

.tl-clientes-datepicker__nav {
  border: 0;
  width: 30px;
  height: 30px;
  border-radius: 999px;
  background: rgba(12, 22, 38, 0.08);
  color: rgba(24, 35, 52, 0.9);
  cursor: pointer;
}

.tl-clientes-datepicker__grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 6px;
}

.tl-clientes-datepicker__day {
  text-align: center;
  font-size: 0.82rem;
  color: rgba(80, 92, 110, 0.8);
  padding: 4px 0;
}

.tl-clientes-datepicker__cell {
  border: 0;
  border-radius: 10px;
  padding: 8px 0;
  font-weight: 600;
  color: rgba(24, 35, 52, 0.9);
  background: rgba(255, 255, 255, 0.7);
  cursor: pointer;
}

.tl-clientes-datepicker__cell.is-today {
  border: 1px solid rgba(0, 179, 222, 0.5);
}

.tl-clientes-datepicker__cell.is-selected {
  background: linear-gradient(135deg, #00b3de, #0f7bff);
  color: #fff;
}

html[data-theme="dark"] .tl-clientes-datepicker {
  border-color: rgba(255, 255, 255, 0.12);
  background:
    linear-gradient(145deg, rgba(18, 22, 32, 0.92), rgba(9, 12, 18, 0.82)),
    radial-gradient(circle at top left, rgba(0, 179, 222, 0.18), transparent 50%);
}

html[data-theme="dark"] .tl-clientes-datepicker__title {
  color: rgba(233, 240, 250, 0.9);
}

html[data-theme="dark"] .tl-clientes-datepicker__nav {
  background: rgba(255, 255, 255, 0.08);
  color: rgba(233, 240, 250, 0.9);
}

html[data-theme="dark"] .tl-clientes-datepicker__day {
  color: rgba(210, 220, 235, 0.7);
}

html[data-theme="dark"] .tl-clientes-datepicker__cell {
  background: rgba(255, 255, 255, 0.08);
  color: rgba(233, 240, 250, 0.9);
}

html[data-theme="dark"] .tl-clientes-shell {
  background:
    linear-gradient(145deg, rgba(18, 22, 32, 0.88), rgba(9, 12, 18, 0.78)),
    radial-gradient(circle at top right, rgba(0, 179, 222, 0.16), transparent 42%);
}

html[data-theme="dark"] .tl-clientes-card {
  background: rgba(12, 18, 28, 0.92);
  border-color: rgba(255, 255, 255, 0.08);
}

html[data-theme="dark"] .tl-clientes-lista {
  background:
    linear-gradient(145deg, rgba(12, 18, 28, 0.92), rgba(12, 18, 28, 0.72)),
    radial-gradient(circle at top left, rgba(0, 179, 222, 0.14), transparent 48%);
  border-color: rgba(255, 255, 255, 0.08);
}

html[data-theme="dark"] .tl-clientes-lista__summary {
  color: rgba(220, 230, 245, 0.72);
}

html[data-theme="dark"] .tl-clientes-composicao__summary {
  color: rgba(220, 230, 245, 0.72);
}

html[data-theme="dark"] .tl-clientes-busca input {
  background: rgba(12, 18, 28, 0.92);
  border-color: rgba(255, 255, 255, 0.1);
  color: rgba(233, 240, 250, 0.92);
}

html[data-theme="dark"] .tl-clientes-busca__icon {
  border-color: rgba(233, 240, 250, 0.5);
}

html[data-theme="dark"] .tl-clientes-busca__icon::after {
  background: rgba(233, 240, 250, 0.5);
}

html[data-theme="dark"] .tl-clientes-shell__head p,
html[data-theme="dark"] .tl-clientes-overview__content p,
html[data-theme="dark"] .tl-clientes-overview__stat span {
  color: rgba(220, 230, 245, 0.72);
}

html[data-theme="dark"] .tl-clientes-overview,
html[data-theme="dark"] .tl-clientes-form-topbar {
  border-color: rgba(255, 255, 255, 0.08);
  background:
    linear-gradient(145deg, rgba(12, 18, 28, 0.9), rgba(12, 18, 28, 0.62)),
    radial-gradient(circle at top left, rgba(0, 179, 222, 0.14), transparent 48%);
}

html[data-theme="dark"] .tl-clientes-overview__stat strong {
  color: #7bc4ff;
}

html[data-theme="dark"] .tl-clientes-lista__empty {
  border-color: rgba(255, 255, 255, 0.12);
  color: rgba(220, 230, 245, 0.7);
  background: rgba(12, 18, 28, 0.7);
}

html[data-theme="dark"] .tl-clientes-item {
  background:
    linear-gradient(150deg, rgba(14, 20, 32, 0.94), rgba(14, 20, 32, 0.78)),
    radial-gradient(circle at top right, rgba(0, 179, 222, 0.14), transparent 48%);
  border-color: rgba(255, 255, 255, 0.08);
}

html[data-theme="dark"] .tl-clientes-lista__grid > .tl-clientes-item:hover {
  border-color: rgba(0, 179, 222, 0.34);
  box-shadow: 0 26px 44px -30px rgba(2, 9, 20, 0.72);
}

html[data-theme="dark"] .tl-clientes-item__sub,
html[data-theme="dark"] .tl-clientes-item__meta,
html[data-theme="dark"] .tl-clientes-item__date {
  color: rgba(220, 230, 245, 0.65);
}

html[data-theme="dark"] .tl-clientes-item__chip {
  background: rgba(255, 255, 255, 0.08);
  color: rgba(233, 240, 250, 0.86);
}

@media (max-width: 900px) {
  .tl-clientes-lista__grid {
    grid-template-columns: 1fr;
  }
  .tl-clientes-shell {
    padding: 18px;
  }
  .tl-clientes-overview {
    grid-template-columns: 1fr;
  }
  .tl-clientes-overview__stats {
    align-items: stretch;
  }
  .tl-clientes-form-topbar {
    flex-direction: column;
    align-items: flex-start;
  }
  .tl-clientes-lista__head {
    flex-direction: column;
    align-items: stretch;
  }
  .tl-clientes-lista__actions {
    width: 100%;
  }
  .tl-clientes-lista__actions .tl-imoveis-btn {
    width: 100%;
  }
  .tl-clientes-composicao__head {
    flex-direction: column;
    align-items: stretch;
  }
  .tl-clientes-composicao__head .tl-imoveis-btn {
    width: 100%;
  }
  .tl-clientes-actions {
    justify-content: flex-start;
  }
  .tl-clientes-item {
    grid-template-columns: 1fr;
    align-items: flex-start;
  }
  .tl-clientes-item__profile {
    width: 100%;
  }
  .tl-clientes-item__aside {
    width: 100%;
    justify-content: flex-start;
  }
  .tl-clientes-item__actions {
    flex-wrap: wrap;
    justify-content: flex-start;
  }
  .tl-clientes-item__actions .tl-imoveis-btn {
    width: 100%;
  }
}

