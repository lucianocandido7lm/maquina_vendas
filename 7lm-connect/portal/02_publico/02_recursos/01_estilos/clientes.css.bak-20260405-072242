}

html[data-theme="dark"] .tl-clientes-time-panel {
  border-color: rgba(255, 255, 255, 0.12);
  background:
    linear-gradient(150deg, rgba(12, 18, 28, 0.96), rgba(12, 18, 28, 0.7)),
