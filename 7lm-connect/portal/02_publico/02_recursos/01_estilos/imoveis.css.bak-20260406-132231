  border-radius: 16px;
  border: 1px solid rgba(18, 24, 38, 0.08);
  background: rgba(255, 255, 255, 0.72);
  padding: 10px 12px;
  gap: 10px;
  align-content: start;
}

.tl-imoveis-showroom__section-head,
.tl-imoveis-showroom__actions-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 10px;
  margin-bottom: 0;
}

.tl-imoveis-showroom__section-head small,
.tl-imoveis-showroom__actions-head small {
  margin: 0;
  font-size: 0.76rem;
  line-height: 1.25;
  color: rgba(61, 71, 90, 0.72);
  text-align: right;
}

.tl-imoveis-showroom__meta-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 8px;
  grid-auto-rows: minmax(60px, auto);
}

.tl-imoveis-showroom__meta-grid article {
  border-radius: 12px;
  background: rgba(12, 22, 38, 0.06);
  padding: 7px 10px;
  display: grid;
  gap: 1px;
  min-width: 0;
  min-height: 60px;
  align-content: start;
}

.tl-imoveis-showroom__meta-grid span {
  font-size: 0.71rem;
  text-transform: uppercase;
  letter-spacing: 0.03em;
  color: rgba(61, 71, 90, 0.72);
  line-height: 1.05;
}

.tl-imoveis-showroom__meta-grid strong {
  font-size: 0.88rem;
  line-height: 1.1;
  color: rgba(29, 39, 56, 0.9);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  overflow-wrap: anywhere;
}

.tl-imoveis-showroom__meta-inline {
  display: grid;
  gap: 8px;
  padding-top: 10px;
  border-top: 1px solid rgba(18, 24, 38, 0.08);
}

.tl-imoveis-showroom__meta-inline small {
  margin: 0;
  font-size: 0.76rem;
  line-height: 1.2;
  color: rgba(61, 71, 90, 0.72);
}

.tl-imoveis-showroom__footer-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 12px;
  align-items: start;
}

.tl-imoveis-showroom__location {
  display: grid;
  grid-template-columns: 1fr;
  gap: 10px;
  align-self: start;
}

.tl-imoveis-showroom__location-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
}

.tl-imoveis-showroom__location-head .tl-imoveis-eyebrow {
  margin-top: 2px;
}

.tl-imoveis-showroom__location-text {
  min-width: 0;
  display: grid;
  gap: 6px;
}

.tl-imoveis-showroom__location strong,
.tl-imoveis-showroom__location small {
  display: block;
  overflow-wrap: anywhere;
}

.tl-imoveis-showroom__location-text .tl-imoveis-eyebrow {
  display: none;
}

.tl-imoveis-showroom__location strong {
  line-height: 1.22;
  font-size: 1rem;
  font-weight: 700;
  overflow: visible;
}

.tl-imoveis-showroom__location small {
  line-height: 1.3;
  overflow: visible;
  color: rgba(61, 71, 90, 0.82);
}

.tl-imoveis-showroom__location-head .tl-imoveis-btn {
  flex: 0 0 auto;
  min-width: 136px;
  min-height: 40px;
}

.tl-imoveis-showroom__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.tl-imoveis-showroom__description p {
  margin: 0;
  line-height: 1.48;
  display: block;
  white-space: pre-line;
  overflow: visible;
  overflow-wrap: anywhere;
}

.tl-imoveis-showroom__support-grid {
  display: grid;
  grid-template-columns: minmax(0, 1.2fr) minmax(260px, 0.8fr);
  gap: 12px;
}

.tl-imoveis-showroom__timeline ul {
  margin: 0;
  padding-left: 0;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 8px;
  list-style: none;
}

.tl-imoveis-showroom__timeline {
  align-self: start;
}

.tl-imoveis-showroom__timeline li {
  border-radius: 12px;
  background: rgba(12, 22, 38, 0.05);
  padding: 8px 10px;
  display: grid;
  gap: 2px;
  min-width: 0;
  overflow-wrap: anywhere;
}

.tl-imoveis-showroom__timeline li span {
  font-size: 0.72rem;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  color: rgba(61, 71, 90, 0.72);
}

.tl-imoveis-showroom__timeline li strong {
  font-size: 0.9rem;
  line-height: 1.24;
  color: rgba(29, 39, 56, 0.9);
}

.tl-imoveis-showroom__actions-wrap {
  display: grid;
  gap: 10px;
  background: rgba(255, 255, 255, 0.86);
}

.tl-imoveis-showroom__actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 8px;
}

.tl-imoveis-showroom__actions .tl-imoveis-btn {
  width: 100%;
  min-width: 0;
  flex: none;
}

.tl-imoveis-showroom__action-btn--wide {
  grid-column: 1 / -1;
}

html[data-theme="dark"] .tl-imoveis-showroom__gallery,
html[data-theme="dark"] .tl-imoveis-showroom__support,
html[data-theme="dark"] .tl-imoveis-showroom__details {
  border-color: rgba(255, 255, 255, 0.08);
  background: linear-gradient(160deg, rgba(16, 21, 32, 0.94), rgba(10, 14, 22, 0.88));
}

html[data-theme="dark"] .tl-imoveis-showroom.glass-panel.hyper-glass {
  background:
    linear-gradient(180deg, rgba(8, 12, 20, 0.98), rgba(6, 10, 16, 0.94)),
    radial-gradient(circle at top right, rgba(0, 179, 222, 0.1), transparent 38%);
  box-shadow: 0 42px 90px -36px rgba(0, 0, 0, 0.82);
}

html[data-theme="dark"] .tl-imoveis-showroom.glass-panel.hyper-glass::after {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.03));
}

html[data-theme="dark"] .tl-imoveis-showroom__hero-card {
  border-color: rgba(105, 174, 255, 0.18);
  background: linear-gradient(180deg, rgba(18, 62, 116, 0.38), rgba(12, 18, 28, 0.92) 72%);
}

html[data-theme="dark"] .tl-imoveis-showroom__section-block,
html[data-theme="dark"] .tl-imoveis-showroom__meta-grid article,
html[data-theme="dark"] .tl-imoveis-showroom__location,
html[data-theme="dark"] .tl-imoveis-showroom__highlights,
html[data-theme="dark"] .tl-imoveis-showroom__description,
html[data-theme="dark"] .tl-imoveis-showroom__timeline,
html[data-theme="dark"] .tl-imoveis-showroom__actions-wrap,
html[data-theme="dark"] .tl-imoveis-showroom__quick-strip article,
html[data-theme="dark"] .tl-imoveis-showroom__timeline li {
  border-color: rgba(255, 255, 255, 0.08);
  background: rgba(255, 255, 255, 0.05);
}

html[data-theme="dark"] .tl-imoveis-showroom__summary h3,
html[data-theme="dark"] .tl-imoveis-showroom__quick-strip strong,
html[data-theme="dark"] .tl-imoveis-showroom__meta-grid strong,
html[data-theme="dark"] .tl-imoveis-showroom__location strong,
html[data-theme="dark"] .tl-imoveis-showroom__timeline li strong,
html[data-theme="dark"] .tl-imoveis-showroom__highlights p {
  color: rgba(245, 248, 255, 0.94);
}

html[data-theme="dark"] .tl-imoveis-showroom__gallery-head strong,
html[data-theme="dark"] .tl-imoveis-showroom__summary p,
html[data-theme="dark"] .tl-imoveis-showroom__summary small,
html[data-theme="dark"] .tl-imoveis-showroom__section-head small,
html[data-theme="dark"] .tl-imoveis-showroom__actions-head small,
html[data-theme="dark"] .tl-imoveis-showroom__location small,
html[data-theme="dark"] .tl-imoveis-showroom__description p,
html[data-theme="dark"] .tl-imoveis-showroom__meta-inline small,
html[data-theme="dark"] .tl-imoveis-shell__head p {
  color: rgba(219, 229, 244, 0.8);
}

html[data-theme="dark"] .tl-imoveis-showroom__quick-strip span,
html[data-theme="dark"] .tl-imoveis-showroom__meta-grid span,
html[data-theme="dark"] .tl-imoveis-showroom__timeline li span {
  color: rgba(167, 182, 205, 0.76);
}

html[data-theme="dark"] .tl-imoveis-showroom__price-row strong {
  color: #69aeff;
}

html[data-theme="dark"] .tl-imoveis-showroom__highlights .tl-imoveis-chip {
  background: rgba(255, 255, 255, 0.08);
  color: rgba(241, 246, 255, 0.9);
  border: 1px solid rgba(255, 255, 255, 0.08);
}

html[data-theme="dark"] .tl-imoveis-showroom__location .tl-imoveis-btn--secondary,
html[data-theme="dark"] .tl-imoveis-showroom__actions .tl-imoveis-btn--secondary,
html[data-theme="dark"] .tl-imoveis-showroom__actions .tl-imoveis-btn--ghost {
  background: rgba(255, 255, 255, 0.06);
  color: rgba(244, 247, 255, 0.96);
  border-color: rgba(255, 255, 255, 0.12);
}

html[data-theme="dark"] .tl-imoveis-showroom__location .tl-imoveis-btn--secondary:hover,
html[data-theme="dark"] .tl-imoveis-showroom__actions .tl-imoveis-btn--secondary:hover,
html[data-theme="dark"] .tl-imoveis-showroom__actions .tl-imoveis-btn--ghost:hover {
  background: rgba(255, 255, 255, 0.1);
}

html[data-theme="dark"] .tl-imoveis-showroom__actions-wrap {
  background: rgba(255, 255, 255, 0.08);
}

html[data-theme="dark"] .tl-imoveis-showroom__meta-inline {
  border-top-color: rgba(255, 255, 255, 0.08);
}

html[data-theme="dark"] .tl-imoveis-showroom__thumb {
  border-color: rgba(255, 255, 255, 0.08);
  background: rgba(255, 255, 255, 0.06);
}

.tl-imoveis-map-modal {
  width: min(1160px, calc(100vw - 18px));
  max-height: calc(100vh - 8px);
  padding: 16px 16px 18px;
  overflow: hidden;
}

.tl-imoveis-modal--mapa .tl-imoveis-modal__dialog {
  overflow: hidden;
}

.tl-imoveis-map-modal .tl-imoveis-shell__head,
.tl-imoveis-map-modal .tl-imoveis-shell__head h2,
.tl-imoveis-map-modal .tl-imoveis-shell__head p {
  min-width: 0;
  overflow-wrap: anywhere;
}

.tl-imoveis-map-modal .tl-imoveis-modal__header {
  margin-bottom: 16px;
}

.tl-imoveis-map-modal__body {
  display: grid;
  grid-template-columns: minmax(0, 1.18fr) minmax(280px, 320px);
  gap: 12px;
  align-items: stretch;
  overflow: hidden;
  min-height: min(620px, calc(100vh - 150px));
}

.tl-imoveis-map-modal__body > * {
  min-width: 0;
}

.tl-imoveis-map-modal__canvas {
  min-height: min(620px, calc(100vh - 150px));
  box-sizing: border-box;
  border-radius: 16px;
  overflow: hidden;
  border: 1px solid rgba(18, 24, 38, 0.08);
  background: rgba(240, 245, 250, 0.92);
}

.tl-imoveis-map-modal__canvas iframe {
  width: 100%;
  height: 100%;
  min-height: min(620px, calc(100vh - 150px));
  border: 0;
  display: block;
}

.tl-imoveis-map-modal__info {
  border: 1px solid rgba(18, 24, 38, 0.08);
  border-radius: 16px;
  background: rgba(255, 255, 255, 0.74);
  padding: 14px;
  box-sizing: border-box;
  display: grid;
  gap: 10px;
  align-content: start;
  min-width: 0;
  min-height: min(620px, calc(100vh - 150px));
  max-height: none;
  overflow: hidden;
}

.tl-imoveis-map-modal__address {
  display: grid;
  gap: 6px;
  min-width: 0;
  max-height: 170px;
  overflow: hidden;
}

.tl-imoveis-map-modal__address strong,
.tl-imoveis-map-modal__address p {
  margin: 0;
  overflow-wrap: anywhere;
  word-break: break-word;
}

.tl-imoveis-map-modal__address strong {
  font-size: 1.06rem;
  line-height: 1.16;
  color: rgba(18, 24, 38, 0.94);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 4;
  overflow: hidden;
}

.tl-imoveis-map-modal__address p {
  font-size: 0.96rem;
  line-height: 1.22;
  color: rgba(42, 50, 66, 0.7);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.tl-imoveis-map-modal__actions {
  display: grid;
  gap: 8px;
  margin-top: auto;
}

.tl-imoveis-map-modal__actions .tl-imoveis-btn {
  min-height: 46px;
  justify-content: center;
}

html[data-theme="dark"] .tl-imoveis-map-modal__canvas,
html[data-theme="dark"] .tl-imoveis-map-modal__info {
  border-color: rgba(255, 255, 255, 0.08);
  background: rgba(255, 255, 255, 0.05);
}

html[data-theme="dark"] .tl-imoveis-map-modal__address strong {
  color: rgba(245, 248, 255, 0.94);
}

html[data-theme="dark"] .tl-imoveis-map-modal__address p {
  color: rgba(219, 229, 244, 0.78);
}

.tl-imoveis-comparacao {
  width: min(1200px, calc(100vw - 40px));
}

.tl-imoveis-compare-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 12px;
}

.tl-imoveis-compare-card {
  border-radius: 16px;
  border: 1px solid rgba(18, 24, 38, 0.08);
  background: rgba(255, 255, 255, 0.86);
  overflow: hidden;
}

.tl-imoveis-compare-card__media {
  position: relative;
  height: 160px;
}

.tl-imoveis-compare-card__media img,
.tl-imoveis-compare-card__media .tl-imoveis-showcase-card__hero {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.tl-imoveis-compare-card__media .tl-imoveis-commercial-badge {
  position: absolute;
  left: 10px;
  top: 10px;
}

.tl-imoveis-compare-card__body {
  padding: 12px;
  display: grid;
  gap: 8px;
}

.tl-imoveis-compare-card__body p,
.tl-imoveis-compare-card__body ul {
  margin: 0;
}

.tl-imoveis-compare-card__body ul {
  padding-left: 18px;
  display: grid;
  gap: 2px;
}

.tl-imoveis-compare-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

@media (max-width: 1080px) {
  .tl-imoveis-showroom__layout,
  .tl-imoveis-map-modal__body {
    grid-template-columns: 1fr;
  }

  .tl-imoveis-showroom__content {
    overflow-y: auto;
    padding-right: 4px;
  }

  .tl-imoveis-showroom__layout {
    height: auto;
  }

  .tl-imoveis-showroom__details {
    overflow: visible;
  }

  .tl-imoveis-showroom__details-scroll {
    height: auto;
    overflow: visible;
    padding-right: 0;
  }

  .tl-imoveis-map-modal {
    max-height: calc(100vh - 12px);
    padding: 12px;
  }

  .tl-imoveis-map-modal__info {
    max-height: none;
  }

}

@media (max-width: 900px) {
  .tl-imoveis-showroom__footer-grid {
    grid-template-columns: 1fr;
  }

  .tl-imoveis-showroom__meta-grid,
  .tl-imoveis-showroom__timeline ul {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .tl-imoveis-showroom__actions {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 640px) {
  .tl-imoveis-showroom__quick-strip,
  .tl-imoveis-showroom__meta-grid,
  .tl-imoveis-showroom__actions,
  .tl-imoveis-showroom__timeline ul {
    grid-template-columns: 1fr;
  }

  .tl-imoveis-showroom__location {
    grid-template-columns: 1fr;
  }

  .tl-imoveis-showroom__location-head {
    flex-direction: column;
  }

  .tl-imoveis-showroom__location-head .tl-imoveis-btn {
    width: 100%;
  }

  .tl-imoveis-compare-dock {
    flex-direction: column;
    align-items: stretch;
  }
}
