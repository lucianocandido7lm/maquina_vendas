html.tl-imoveis-form-gated body {
  visibility: hidden !important;
}

.tl-imoveis-page .tl-main {
  gap: 24px;
  padding-bottom: 72px;
}

.tl-imoveis-page .tl-main > * {
  flex-shrink: 0;
}

.tl-imoveis-page .tl-topbar {
  margin-bottom: 8px;
}

.tl-imoveis-page .tl-topbar__titles {
  max-width: 860px;
}

.tl-imoveis-page .tl-overline {
  color: rgba(0, 179, 222, 0.92);
}

.tl-imoveis-feedback {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.tl-imoveis-feedback:empty {
  display: none;
}

.tl-imoveis-feedback__item {
  border-radius: 22px;
  padding: 16px 20px;
  border: 1px solid rgba(16, 24, 40, 0.08);
  background: rgba(255, 255, 255, 0.82);
  box-shadow: 0 24px 60px -44px rgba(18, 25, 42, 0.36);
  font-size: 0.98rem;
  line-height: 1.5;
}

.tl-imoveis-feedback__item[data-variant="success"] {
  color: #0d7f5f;
  border-color: rgba(13, 127, 95, 0.16);
}

.tl-imoveis-feedback__item[data-variant="error"] {
  color: #b42318;
  border-color: rgba(180, 35, 24, 0.18);
}

.tl-imoveis-feedback__item[data-variant="warning"] {
  color: #9a6400;
  border-color: rgba(154, 100, 0, 0.2);
}

html[data-theme="dark"] .tl-imoveis-feedback__item {
  background: rgba(8, 11, 18, 0.78);
  border-color: rgba(255, 255, 255, 0.08);
  box-shadow: 0 28px 66px -42px rgba(0, 0, 0, 0.72);
}

.tl-imoveis-summary {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 18px;
}

.tl-imoveis-top-tabs {
  display: grid;
  gap: 14px;
}

.tl-imoveis-hero-shell {
  gap: 0;
  min-height: 96px;
  padding-top: 14px;
  padding-bottom: 14px;
  overflow: visible;
}

.tl-imoveis-hero-compact {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  min-width: 0;
  width: 100%;
  padding: 10px 12px 10px 18px;
  border-radius: 999px;
  border: 1px solid rgba(255, 255, 255, 0.34);
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.58), rgba(255, 255, 255, 0.22)),
    radial-gradient(circle at top left, rgba(0, 179, 222, 0.18), transparent 46%);
  box-shadow: 0 24px 44px -32px rgba(19, 29, 46, 0.32);
  backdrop-filter: blur(18px);
}

.tl-imoveis-hero-compact__rail {
  display: flex;
  flex: 1 1 auto;
  align-items: center;
  gap: 10px;
  min-width: 0;
  overflow-x: auto;
  scrollbar-width: none;
}

.tl-imoveis-hero-compact__rail::-webkit-scrollbar {
  display: none;
}

.tl-imoveis-hero-compact__actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12px;
  flex-shrink: 0;
}

.tl-imoveis-hero-compact__user {
  display: inline-flex;
  align-items: center;
  min-width: 0;
  max-width: min(34vw, 280px);
  min-height: 46px;
  padding: 0 18px;
  border-radius: 999px;
  border: 1px solid rgba(255, 255, 255, 0.34);
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.82), rgba(255, 255, 255, 0.44)),
    radial-gradient(circle at top left, rgba(0, 179, 222, 0.12), transparent 46%);
  box-shadow: 0 18px 28px -24px rgba(19, 29, 46, 0.28);
}

.tl-imoveis-hero-compact__user-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 0.96rem;
  font-weight: 700;
  letter-spacing: -0.01em;
  color: rgba(24, 35, 52, 0.92);
}

.tl-imoveis-hero-compact__brand,
.tl-imoveis-hero-compact__module,
.tl-imoveis-hero-compact__tab,
.tl-imoveis-hero-compact__view {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 38px;
  padding: 0 16px;
  border-radius: 999px;
  white-space: nowrap;
}

.tl-imoveis-hero-compact__brand {
  padding-inline: 14px;
  background: rgba(11, 21, 36, 0.86);
  color: rgba(248, 252, 255, 0.96);
  letter-spacing: 2px;
}

.tl-imoveis-hero-compact__module {
  background: rgba(255, 255, 255, 0.68);
  color: rgba(31, 43, 62, 0.84);
  border: 1px solid rgba(18, 24, 38, 0.08);
  font-weight: 600;
}

.tl-imoveis-hero-compact__tab {
  background: rgba(255, 255, 255, 0.7);
  color: rgba(36, 46, 64, 0.75);
  border: 1px solid rgba(18, 24, 38, 0.08);
  font-weight: 600;
  box-shadow: 0 10px 20px -18px rgba(19, 29, 46, 0.28);
  transition: all 0.2s ease;
}

.tl-imoveis-hero-compact__tab:hover {
  color: rgba(24, 35, 52, 0.92);
  transform: translateY(-1px);
  box-shadow: 0 14px 24px -18px rgba(19, 29, 46, 0.35);
}

.tl-imoveis-hero-compact__tab.is-active {
  background: linear-gradient(135deg, rgba(0, 179, 222, 0.96), rgba(15, 123, 255, 0.86));
  color: #ffffff;
  font-weight: 700;
  border-color: transparent;
  box-shadow: 0 18px 30px -22px rgba(0, 103, 179, 0.72);
}

.tl-imoveis-hero-compact__view {
  background: rgba(12, 22, 38, 0.08);
  color: rgba(44, 56, 76, 0.78);
  font-weight: 600;
}

.tl-imoveis-hero-compact .tl-btn-icon {
  flex-shrink: 0;
  width: 46px;
  height: 46px;
}

html[data-theme="dark"] .tl-imoveis-hero-compact {
  border-color: rgba(255, 255, 255, 0.12);
  background:
    linear-gradient(135deg, rgba(13, 18, 28, 0.88), rgba(8, 11, 18, 0.78)),
    radial-gradient(circle at top left, rgba(0, 179, 222, 0.2), transparent 48%);
  box-shadow: 0 30px 48px -34px rgba(0, 0, 0, 0.54);
}

html[data-theme="dark"] .tl-imoveis-hero-compact__brand {
  background: rgba(247, 250, 255, 0.12);
  color: rgba(248, 252, 255, 0.96);
}

html[data-theme="dark"] .tl-imoveis-hero-compact__module {
  background: rgba(255, 255, 255, 0.08);
  border-color: rgba(255, 255, 255, 0.1);
  color: rgba(235, 242, 252, 0.88);
}

html[data-theme="dark"] .tl-imoveis-hero-compact__user {
  border-color: rgba(255, 255, 255, 0.1);
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.04)),
    radial-gradient(circle at top left, rgba(0, 179, 222, 0.14), transparent 48%);
}

html[data-theme="dark"] .tl-imoveis-hero-compact__user-name {
  color: rgba(243, 247, 255, 0.94);
}

html[data-theme="dark"] .tl-imoveis-hero-compact__view {
  background: rgba(255, 255, 255, 0.06);
  color: rgba(219, 230, 244, 0.82);
}

html[data-theme="dark"] .tl-imoveis-hero-compact__tab {
  background: rgba(255, 255, 255, 0.08);
  border-color: rgba(255, 255, 255, 0.12);
  color: rgba(230, 238, 250, 0.7);
  box-shadow: 0 12px 22px -18px rgba(0, 0, 0, 0.5);
}

html[data-theme="dark"] .tl-imoveis-hero-compact__tab:hover {
  color: rgba(243, 247, 255, 0.95);
  box-shadow: 0 16px 26px -18px rgba(0, 0, 0, 0.58);
}

html[data-theme="dark"] .tl-imoveis-hero-compact__tab.is-active {
  background: linear-gradient(135deg, rgba(56, 182, 255, 0.96), rgba(24, 116, 255, 0.9));
  color: #ffffff;
  border-color: transparent;
  box-shadow: 0 18px 30px -22px rgba(0, 103, 179, 0.78);
}

.tl-imoveis-hero-shell::after {
  content: "";
  position: absolute;
  inset: auto -120px -150px auto;
  width: 380px;
  height: 380px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(0, 179, 222, 0.18), transparent 68%);
  filter: blur(20px);
  pointer-events: none;
  opacity: 0.88;
}

html[data-theme="dark"] .tl-imoveis-hero-shell::after {
  background: radial-gradient(circle, rgba(0, 179, 222, 0.22), transparent 68%);
}

.tl-imoveis-top-tabs__head {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 18px;
}

.tl-imoveis-top-tabs .tl-ops-toolbar__tabs {
  margin-top: 0;
}

.tl-imoveis-top-tabs__text {
  margin: 10px 0 0;
  color: rgba(42, 50, 66, 0.72);
}

html[data-theme="dark"] .tl-imoveis-top-tabs__text {
  color: rgba(237, 243, 252, 0.78);
}

html.tl-modal-open,
body.tl-modal-open {
  overflow: hidden;
}

.tl-imoveis-import-shell,
.tl-imoveis-toolbar,
.tl-imoveis-shell,
.tl-imoveis-form-shell,
.tl-imoveis-media-shell {
  position: relative;
  border-radius: 30px;
  padding: 26px 28px;
  background:
    linear-gradient(140deg, rgba(255, 255, 255, 0.54), rgba(255, 255, 255, 0.16)),
    radial-gradient(circle at top right, rgba(0, 179, 222, 0.12), transparent 38%);
  box-shadow: var(--ops-shadow-soft);
}

html[data-theme="dark"] .tl-imoveis-import-shell,
html[data-theme="dark"] .tl-imoveis-toolbar,
html[data-theme="dark"] .tl-imoveis-shell,
html[data-theme="dark"] .tl-imoveis-form-shell,
html[data-theme="dark"] .tl-imoveis-media-shell {
  background:
    linear-gradient(145deg, rgba(18, 22, 32, 0.84), rgba(9, 12, 18, 0.72)),
    radial-gradient(circle at top right, rgba(0, 179, 222, 0.16), transparent 42%);
}

.tl-imoveis-kpi-action {
  width: 100%;
  border: 0;
  text-align: left;
  cursor: pointer;
}

.tl-imoveis-kpi-action .tl-kpi__note {
  display: block;
  margin-top: 12px;
  color: rgba(61, 71, 90, 0.7);
  font-size: 0.86rem;
  line-height: 1.45;
}

html[data-theme="dark"] .tl-imoveis-kpi-action .tl-kpi__note {
  color: rgba(228, 236, 248, 0.62);
}

.tl-ops-page .icon-amber {
  background:
    radial-gradient(circle at top left, rgba(255, 255, 255, 0.34), transparent 48%),
    linear-gradient(135deg, rgba(245, 158, 11, 0.98), rgba(249, 115, 22, 0.84));
}

.tl-imoveis-modal {
  position: fixed;
  inset: 0;
  z-index: 80;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24px;
}

.tl-imoveis-modal[hidden] {
  display: none !important;
}

.tl-imoveis-modal__backdrop {
  position: absolute;
  inset: 0;
  background: rgba(9, 14, 24, 0.36);
  backdrop-filter: blur(12px);
}

html[data-theme="dark"] .tl-imoveis-modal__backdrop {
  background: rgba(4, 8, 14, 0.62);
}

html.tl-lite-effects .tl-imoveis-hero-shell::after {
  display: none;
}

html.tl-lite-effects .tl-imoveis-hero-compact,
html.tl-lite-effects .tl-imoveis-modal__backdrop {
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

html.tl-lite-effects .tl-imoveis-hero-compact__tab:hover,
html.tl-lite-effects .tl-imoveis-modal__close:hover {
  transform: none;
}

.tl-imoveis-modal__dialog {
  position: relative;
  z-index: 1;
  width: min(1120px, calc(100vw - 48px));
  max-height: calc(100vh - 48px);
  box-sizing: border-box;
  border-radius: 28px;
  overflow-x: hidden;
  overflow-y: auto;
  box-shadow: 0 38px 90px -42px rgba(12, 20, 40, 0.48);
  scrollbar-width: thin;
  scrollbar-color: rgba(15, 123, 255, 0.34) transparent;
  scrollbar-gutter: stable;
}

.tl-imoveis-modal__dialog::-webkit-scrollbar {
  width: 7px;
}

.tl-imoveis-modal__dialog::-webkit-scrollbar-track {
  background: transparent;
  border-radius: 999px;
}

.tl-imoveis-modal__dialog::-webkit-scrollbar-thumb {
  border-radius: 999px;
  border: 1px solid rgba(255, 255, 255, 0.44);
  background: linear-gradient(180deg, rgba(0, 179, 222, 0.42), rgba(15, 123, 255, 0.56));
}

html[data-theme="dark"] .tl-imoveis-modal__dialog {
  box-shadow: 0 38px 90px -38px rgba(0, 0, 0, 0.82);
  scrollbar-color: rgba(64, 177, 255, 0.44) transparent;
}

html[data-theme="dark"] .tl-imoveis-modal__dialog::-webkit-scrollbar-track,
html[data-theme="dark"] .tl-imoveis-showroom__content::-webkit-scrollbar-track {
  background: transparent;
}

html[data-theme="dark"] .tl-imoveis-modal__dialog::-webkit-scrollbar-thumb,
html[data-theme="dark"] .tl-imoveis-showroom__content::-webkit-scrollbar-thumb {
  border-color: rgba(10, 14, 22, 0.88);
  background: linear-gradient(180deg, rgba(64, 177, 255, 0.42), rgba(19, 109, 233, 0.54));
}

.tl-imoveis-modal__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
  margin-bottom: 22px;
}

.tl-imoveis-modal__header .tl-imoveis-shell__head {
  flex: 1;
  margin-bottom: 0;
}

.tl-imoveis-modal__close {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 48px;
  height: 48px;
  min-width: 48px;
  border: 1px solid rgba(18, 24, 38, 0.08);
  border-radius: 16px;
  background: rgba(255, 255, 255, 0.86);
  color: rgba(28, 36, 52, 0.84);
  cursor: pointer;
  transition: transform 0.22s ease, box-shadow 0.22s ease, background 0.22s ease;
}

.tl-imoveis-modal__close:hover {
  transform: translateY(-2px);
  box-shadow: 0 18px 34px -24px rgba(15, 23, 42, 0.34);
}

html[data-theme="dark"] .tl-imoveis-modal__close {
  border-color: rgba(255, 255, 255, 0.1);
  background: rgba(10, 14, 22, 0.9);
  color: rgba(242, 246, 255, 0.94);
}

.tl-imoveis-import-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16px;
}

.tl-imoveis-form__actions--full {
