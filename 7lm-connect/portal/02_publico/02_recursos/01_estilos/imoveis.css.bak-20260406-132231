  background: rgba(8, 12, 20, 0.42);
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
}

.tl-imoveis-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  align-items: center;
}

.tl-imoveis-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  min-height: 48px;
  padding: 0 18px;
  border-radius: 16px;
  border: 1px solid transparent;
  background: linear-gradient(135deg, #0f7bff, #0059d8);
