/* Midia strip & lightbox */
.tl-imoveis-media-strip {
  display: grid;
  grid-auto-flow: column;
  grid-auto-columns: 80px;
  gap: 8px;
  overflow-x: auto;
  padding: 6px 2px;
}

.tl-imoveis-media-strip img {
  width: 80px;
  height: 64px;
  object-fit: cover;
  border-radius: 10px;
  border: 1px solid rgba(18, 24, 38, 0.06);
  background: #d9e2f1;
}

.tl-imoveis-media-more {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 80px;
  height: 64px;
  border-radius: 10px;
  border: 1px dashed rgba(18, 24, 38, 0.18);
  color: rgba(42, 50, 66, 0.7);
  font-weight: 700;
  background: rgba(255, 255, 255, 0.7);
}

#tl-imoveis-lightbox {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: none;
}

#tl-imoveis-lightbox.is-open {
  display: block;
}

.tl-imoveis-lightbox__backdrop {
  position: absolute;
  inset: 0;
  background: rgba(3, 8, 16, 0.78);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

.tl-imoveis-lightbox__content {
  position: absolute;
  inset: 0;
  display: grid;
  place-items: center;
  padding: 24px;
}

.tl-imoveis-lightbox__panel {
  position: relative;
  width: min(1260px, calc(100vw - 52px));
  max-height: calc(100vh - 52px);
  border-radius: 24px;
  border: 1px solid rgba(255, 255, 255, 0.14);
  background: linear-gradient(170deg, rgba(10, 16, 28, 0.92), rgba(8, 14, 24, 0.86));
  box-shadow: 0 34px 90px -26px rgba(0, 0, 0, 0.65);
  padding: 14px;
  display: grid;
  grid-template-rows: auto 1fr auto;
  gap: 10px;
}

.tl-imoveis-lightbox__toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding-right: 56px;
}

.tl-imoveis-lightbox__counter {
  color: rgba(235, 242, 252, 0.9);
  font-size: 0.86rem;
  font-weight: 700;
  letter-spacing: 0.03em;
}

.tl-imoveis-lightbox__zoom-actions {
  display: inline-flex;
  align-items: center;
  gap: 8px;
}

.tl-imoveis-lightbox__zoom-btn {
  min-width: 40px;
  height: 34px;
  border-radius: 10px;
  border: 1px solid rgba(255, 255, 255, 0.2);
  background: rgba(255, 255, 255, 0.1);
  color: rgba(244, 248, 255, 0.96);
  font-weight: 700;
  cursor: pointer;
}

.tl-imoveis-lightbox__stage {
  position: relative;
  border-radius: 16px;
  background: rgba(4, 10, 18, 0.92);
  border: 1px solid rgba(255, 255, 255, 0.06);
  min-height: 320px;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tl-imoveis-lightbox__img {
  max-width: 100%;
  max-height: min(68vh, 760px);
  object-fit: contain;
  border-radius: 10px;
  box-shadow: 0 24px 70px rgba(0, 0, 0, 0.55);
  transition: transform 0.2s ease;
  transform-origin: center center;
  user-select: none;
  -webkit-user-drag: none;
}

.tl-imoveis-lightbox__thumbs {
  display: grid;
  grid-auto-flow: column;
  grid-auto-columns: 96px;
  gap: 8px;
  overflow-x: auto;
  padding-bottom: 2px;
}

.tl-imoveis-lightbox__thumb {
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 10px;
  height: 68px;
  padding: 0;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.08);
  cursor: pointer;
}

.tl-imoveis-lightbox__thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.tl-imoveis-lightbox__thumb.is-active {
  border-color: rgba(0, 179, 222, 0.95);
  box-shadow: 0 0 0 2px rgba(0, 179, 222, 0.28);
}

.tl-imoveis-lightbox__nav,
.tl-imoveis-lightbox__close {
  position: absolute;
  background: rgba(255, 255, 255, 0.14);
  border: 1px solid rgba(255, 255, 255, 0.22);
  color: rgba(245, 249, 255, 0.96);
  width: 44px;
  height: 44px;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 21px;
  cursor: pointer;
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
}

.tl-imoveis-lightbox__close { top: 14px; right: 14px; z-index: 3; }
.tl-imoveis-lightbox__prev { left: 12px; top: 50%; transform: translateY(-50%); }
.tl-imoveis-lightbox__next { right: 12px; top: 50%; transform: translateY(-50%); }

@media (max-width: 900px) {
  .tl-imoveis-lightbox__content {
    padding: 12px;
  }

  .tl-imoveis-lightbox__panel {
    width: calc(100vw - 24px);
    max-height: calc(100vh - 24px);
    border-radius: 18px;
    padding: 10px;
  }

  .tl-imoveis-lightbox__toolbar {
    padding-right: 44px;
  }

  .tl-imoveis-lightbox__counter {
    font-size: 0.8rem;
  }

  .tl-imoveis-lightbox__stage {
    min-height: 220px;
  }

  .tl-imoveis-lightbox__img {
    max-height: min(56vh, 520px);
  }

  .tl-imoveis-lightbox__thumbs {
    grid-auto-columns: 78px;
  }

  .tl-imoveis-lightbox__thumb {
    height: 56px;
  }

  .tl-imoveis-lightbox__nav,
  .tl-imoveis-lightbox__close {
    width: 38px;
    height: 38px;
    font-size: 18px;
  }

  .tl-imoveis-local__summary,
  .tl-imoveis-bloco__summary {
    flex-direction: column;
    align-items: flex-start;
  }
  .tl-imoveis-local__chips { justify-content: flex-start; }
  .tl-imoveis-local__body { grid-template-columns: 1fr; }
  .tl-imoveis-unit__head { flex-direction: column; }
  .tl-imoveis-unit__actions { justify-content: flex-start; }
}

