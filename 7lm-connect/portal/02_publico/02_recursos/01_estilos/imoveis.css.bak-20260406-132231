.tl-imoveis-toolbar__head p,
.tl-imoveis-shell__head p,
.tl-imoveis-form-shell__head p,
.tl-imoveis-media-shell__head p {
  margin: 10px 0 0;
  max-width: 760px;
  color: rgba(42, 50, 66, 0.72);
}

html[data-theme="dark"] .tl-imoveis-toolbar__head p,
html[data-theme="dark"] .tl-imoveis-shell__head p,
html[data-theme="dark"] .tl-imoveis-form-shell__head p,
html[data-theme="dark"] .tl-imoveis-media-shell__head p {
  color: rgba(237, 243, 252, 0.84);
}

.tl-imoveis-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 0.72rem;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: rgba(0, 179, 222, 0.95);
}

.tl-imoveis-toolbar__filters {
  display: grid;
  grid-template-columns: 1.4fr repeat(3, minmax(0, 1fr)) auto auto;
  gap: 14px;
  align-items: end;
}

.tl-imoveis-toolbar__filters--merged {
  margin-bottom: 20px;
