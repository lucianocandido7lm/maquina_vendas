            helperText("Gerando seu QR Code de configuração...");
            var result = await req(
              "/api/mfa/iniciar",
              {
                method: "POST",
                headers: { Accept: "application/json", "Content-Type": "application/json" },
                body: JSON.stringify({ mfa_desafio: state.challenge })
              }
            );

            if (!result.response.ok) {
              throw new Error(msg(result.payload, "Não foi possível iniciar a configuração do Microsoft Authenticator."));
            }

            els.mfaTitle.textContent = "Configure seu Microsoft Authenticator";
            els.mfaText.textContent = message || "Escaneie o QR Code ou copie a chave manual. Depois informe o código de 6 dígitos para ativar o acesso.";
            els.qrWrap.classList.remove("hide");
            els.manualWrap.classList.remove("hide");
            els.qrImg.src = "data:image/png;base64," + (result.payload.qr_png_base64 || "");
            els.manualKey.textContent = result.payload.chave_manual || "-";
            els.codigo.value = "";
            toggle("mfa");
            helperText("Escaneie o QR Code e valide o código gerado no app.");
            note("Seu autenticador ainda não estava configurado. Faça a vinculação abaixo.", "info");
            window.setTimeout(function () {
              els.codigo.focus();
            }, 40);
          }

          async function finish(payload, provider) {
            var access = payload.token_de_acesso || payload.access_token || payload.token || "";
            if (!access) {
              throw new Error("O portal não recebeu um token válido da autenticação.");
            }

            save(KEYS.access, access);
            if (payload.token_de_renovacao || payload.refresh_token) {
              save(KEYS.refresh, payload.token_de_renovacao || payload.refresh_token);
            }
            if (payload.usuario || payload.user) {
              save(KEYS.user, JSON.stringify(payload.usuario || payload.user));
            }
            save(KEYS.at, new Date().toISOString());
            save(KEYS.provider, provider || "credencial_interna");
            helperText("Concluindo sua autenticação...");
            window.location.replace(await resolveDestinoPosLogin(access));
          }

          function handleCodigoInput() {
            this.value = cleanCode(this.value);
          }

          function handleCloseRequest() {
            closeModal({ returnHome: true, force: true });
          }

          async function handleLoginSubmit(event) {
            if (!sincronizarModal()) {
              return;
            }

            event.preventDefault();
            clearNote();
            var correioEletronico = String(els.correioEletronico.value || "").trim();
            var senha = String(els.senha.value || "");

            if (!correioEletronico || !senha) {
              return note("Informe o e-mail e a senha para continuar.", "error");
            }

            busy(true);
            helperText("Validando suas credenciais...");

            try {
              var timezone = "";
              try {
                timezone = Intl.DateTimeFormat().resolvedOptions().timeZone || "";
              } catch (_) {}

              var result = await req(
                "/api/entrada",
                {
                  method: "POST",
                  headers: { Accept: "application/json", "Content-Type": "application/json" },
                  body: JSON.stringify({
                    correio_eletronico: correioEletronico,
                    senha: senha,
                    fuso_horario_informado: timezone
                  })
                }
              );

              if (!result.response.ok) {
                throw new Error(msg(result.payload, "Não foi possível iniciar o acesso ao portal."));
              }

              if (result.payload && (result.payload.token_de_acesso || result.payload.access_token || result.payload.token)) {
                return await finish(result.payload, "credencial_interna");
              }

              state.challenge = (result.payload && result.payload.mfa_desafio) || "";

              if (result.payload && result.payload.mfa_setup_required && state.challenge) {
                return await showMfaSetup(msg(result.payload, ""));
              }

              if (result.payload && result.payload.mfa_required && state.challenge) {
                return showMfaLogin(msg(result.payload, ""));
              }

              throw new Error(msg(result.payload, "O portal não informou a próxima etapa da autenticação."));
            } catch (error) {
              note(error.message || "Não foi possível concluir a autenticação.", "error");
              helperText("Confira se a API local esta em execucao e tente novamente.");
            } finally {
              busy(false);
            }
          }

          async function handleMfaSubmit(event) {
            if (!sincronizarModal()) {
              return;
            }

            event.preventDefault();
            clearNote();
            var codigo = cleanCode(els.codigo.value);
            els.codigo.value = codigo;

            if (codigo.length !== 6) {
              return note("Informe um código válido de 6 dígitos.", "error");
            }

            if (!state.mode || !state.challenge) {
              return note("A etapa de autenticação expirou. Volte e tente novamente.", "error");
            }

            busy(true);
            helperText("Validando o código do Microsoft Authenticator...");

            try {
              var endpoint = state.mode === "setup" ? "/api/mfa/confirmar" : "/api/mfa/verificar";
              var result = await req(
                endpoint,
                {
                  method: "POST",
                  headers: { Accept: "application/json", "Content-Type": "application/json" },
                  body: JSON.stringify({ mfa_desafio: state.challenge, codigo: codigo })
                }
              );

              if (!result.response.ok) {
                throw new Error(msg(result.payload, "Não foi possível validar o código informado."));
              }

              await finish(result.payload, "credencial_interna");
            } catch (error) {
              note(error.message || "Não foi possível validar o código.", "error");
              helperText("Confira o código no app e tente novamente.");
            } finally {
              busy(false);
            }
          }

          function registrarEventosDaModal() {
            if (!els || !els.modal || els.modal.__sevenlmBound) {
              return;
            }

            if (els.codigo) {
              els.codigo.addEventListener("input", handleCodigoInput);
            }
            if (els.btnBack) {
              els.btnBack.addEventListener("click", back);
            }
            if (els.close) {
              els.close.addEventListener("click", handleCloseRequest);
            }
            if (els.backdrop) {
              els.backdrop.addEventListener("click", handleCloseRequest);
            }
            if (els.modal) {
              els.modal.addEventListener("click", function (event) {
                var closeTrigger = event.target && event.target.closest ? event.target.closest("#portalLoginClose") : null;
                if (!closeTrigger) {
                  return;
                }
                event.preventDefault();
                event.stopPropagation();
                handleCloseRequest();
              });
            }
            if (els.loginForm) {
              els.loginForm.addEventListener("submit", handleLoginSubmit);
            }
            if (els.mfaForm) {
              els.mfaForm.addEventListener("submit", handleMfaSubmit);
            }

            els.modal.__sevenlmBound = true;
          }

          sincronizarModal();
          window.__sevenlmOpenLoginNow = function () {
            openModal();
          };

          document.addEventListener(
            "click",
            function (event) {
              var target = event.target;
              var modalAtual = (els && els.modal) || $("portalLoginModal");
              var candidato = target && target.closest ? target.closest("a, button") : null;
              var trigger = null;
              if (candidato && eGatilhoDeLoginPortal(candidato)) {
                trigger = candidato;
              }
              if (!trigger || (modalAtual && modalAtual.contains(trigger))) {
                return;
              }

              navegarParaLoginPortal(event);
            },
            true
          );

          document.addEventListener("sevenlm:open-login", function () {
            openModal();
          });

          new MutationObserver(function () {
            recuperarModalSeNecessario();
          }).observe(document.documentElement, {
            childList: true,
            subtree: true
          });

          try {
            var urlAtual = new URL(window.location.href);
            var deveAbrirModal =
              window.__sevenlmPendingOpenLogin === true ||
              abrirLogin === "1" ||
              abrirLogin === "true" ||
              urlAtual.hash === "#portal-login" ||
              !!mensagem;

            if (deveAbrirModal) {
              window.requestAnimationFrame(function () {
                openModal({
                  message: mensagem || "",
                  kind: mensagem ? "error" : "info"
                });
              });
            } else if (mensagem && feedback) {
              feedback.textContent = mensagem;
              feedback.hidden = false;
              feedback.setAttribute("data-state", "visible");
            }

          } catch (erro) {}
        });
      })();
    </script>
