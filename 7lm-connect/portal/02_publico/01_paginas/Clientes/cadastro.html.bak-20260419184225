                <select id="clienteEscolaridade" class="tl-clientes-select">
                  <option value="">Selecione</option>
                  <option>Fundamental</option>
                  <option>Medio</option>
                  <option>Tecnico</option>
                  <option>Superior</option>
                  <option>Pos-graduacao</option>
                  <option>Outro</option>
                </select>
              </div>
            </div>
          </section>

          <section class="tl-clientes-card">
            <h3>Patrimonio e obrigacoes</h3>
            <div class="tl-clientes-grid">
              <div class="tl-imoveis-field">
                <label for="clienteImovelProprio">Possui imovel proprio?</label>
                <select id="clienteImovelProprio" class="tl-clientes-select">
                  <option value="">Selecione</option>
                  <option>Sim</option>
                  <option>Nao</option>
                </select>
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteVeiculo">Possui veiculo?</label>
                <select id="clienteVeiculo" class="tl-clientes-select">
                  <option value="">Selecione</option>
                  <option>Sim</option>
                  <option>Nao</option>
                </select>
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteFinanciamentos">Financiamentos em andamento</label>
                <input id="clienteFinanciamentos" type="text" placeholder="Descreva" />
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteCartaoCredito">Cartao de credito</label>
                <input id="clienteCartaoCredito" type="text" placeholder="Limite total" />
              </div>
            </div>
          </section>

