                </svg>
              </div>
            </button>
          </div>
        </div>
      </section>

      <section class="tl-clientes-shell anim-stagger-2">
        <div class="tl-clientes-shell__head">
          <div>
            <span class="tl-imoveis-eyebrow mono-font">BASE DE CLIENTES</span>
            <h2>Gestao de clientes aprovados</h2>
            <p>Consulte a base cadastrada e abra um novo atendimento apenas quando precisar registrar um cliente.</p>
          </div>
        </div>

        <section class="tl-clientes-lista" aria-label="Clientes cadastrados">
          <div class="tl-clientes-lista__head">
            <div>
              <h3>Clientes cadastrados</h3>
              <p id="clientesResumo" class="tl-clientes-lista__summary">Carregando base de clientes...</p>
            </div>
            <div class="tl-clientes-lista__actions">
              <button id="btnMostrarCadastro" class="tl-imoveis-btn tl-imoveis-btn--secondary" type="button">Novo cliente</button>
            </div>
          </div>
          <div class="tl-clientes-lista__toolbar">
            <label class="tl-clientes-busca" for="clientesBusca">
              <span class="tl-clientes-busca__icon" aria-hidden="true"></span>
              <input id="clientesBusca" type="search" placeholder="Buscar por nome, CPF, cidade ou contato..." autocomplete="off" />
            </label>
          </div>
          <div id="clientesLista" class="tl-clientes-lista__grid"></div>
        </section>

        <div id="clientesViewModal" class="tl-clientes-modal tl-clientes-view-modal" hidden aria-hidden="true">
          <div class="tl-clientes-modal__backdrop" data-action="fechar-view"></div>
          <section class="tl-clientes-view" role="dialog" aria-modal="true" aria-labelledby="clientesViewTitulo">
            <button id="btnFecharClienteView" class="tl-clientes-view__close" type="button" aria-label="Fechar visualizacao">&times;</button>
            <div id="clientesViewConteudo" class="tl-clientes-view__content">
              <div class="tl-clientes-lista__empty">Carregando cadastro do cliente...</div>
            </div>
          </section>
        </div>

        <div id="clientesModal" class="tl-clientes-modal" hidden aria-hidden="true">
          <div class="tl-clientes-modal__backdrop" data-action="fechar-modal"></div>
          <div class="tl-clientes-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="clientesModalTitulo">
            <form class="tl-clientes-form" novalidate>
          <section class="tl-clientes-form-topbar">
            <div>
              <span class="tl-imoveis-eyebrow mono-font">NOVO CADASTRO</span>
              <h3 id="clientesModalTitulo">Cadastro completo do cliente</h3>
            </div>
            <button id="btnVoltarLista" class="tl-imoveis-btn tl-imoveis-btn--secondary" type="button">Fechar</button>
          </section>

          <section class="tl-clientes-card">
            <h3>Dados pessoais</h3>
            <div class="tl-clientes-grid">
              <div class="tl-imoveis-field">
                <label for="clienteNome">Nome completo</label>
                <input id="clienteNome" type="text" placeholder="Nome do cliente" />
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteNascimento">Data de nascimento</label>
                <input id="clienteNascimento" type="text" class="tl-clientes-date" placeholder="dd/mm/aaaa" inputmode="numeric" autocomplete="off" />
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteSexo">Sexo</label>
                <select id="clienteSexo" class="tl-clientes-select">
                  <option value="">Selecione</option>
                  <option>Feminino</option>
                  <option>Masculino</option>
                  <option>Nao informado</option>
                </select>
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteCpf">CPF</label>
                <input id="clienteCpf" type="text" placeholder="000.000.000-00" />
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteRg">RG</label>
                <input id="clienteRg" type="text" placeholder="Documento de identidade" />
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteEstadoCivil">Estado civil</label>
                <select id="clienteEstadoCivil" class="tl-clientes-select">
                  <option value="">Selecione</option>
                  <option>Solteiro</option>
                  <option>Casado</option>
                  <option>Uniao estavel</option>
                  <option>Divorciado</option>
                  <option>Viuvo</option>
                </select>
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteRegimeCasamento">Regime de casamento</label>
                <select id="clienteRegimeCasamento" class="tl-clientes-select">
                  <option value="">Selecione</option>
                  <option>Comunhao parcial</option>
                  <option>Comunhao universal</option>
                  <option>Separacao total</option>
                  <option>Participacao final</option>
                  <option>Nao se aplica</option>
                </select>
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteNacionalidade">Nacionalidade</label>
                <select id="clienteNacionalidade" class="tl-clientes-select">
                  <option value="">Selecione</option>
                  <option selected>Brasileiro</option>
                  <option>Argentino</option>
                  <option>Boliviano</option>
                  <option>Chileno</option>
                  <option>Colombiano</option>
                  <option>Paraguaio</option>
                  <option>Peruano</option>
                  <option>Uruguaio</option>
                  <option>Venezuelano</option>
                  <option>Portugues</option>
                  <option>Italiano</option>
                  <option>Espanhol</option>
                  <option>Alemao</option>
                  <option>Frances</option>
                  <option>Outro</option>
                </select>
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteNomeMae">Nome da mae</label>
                <input id="clienteNomeMae" type="text" placeholder="Nome completo da mae" />
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteNomePai">Nome do pai</label>
                <input id="clienteNomePai" type="text" placeholder="Nome completo do pai" />
              </div>
            </div>
          </section>

          <section class="tl-clientes-card">
            <h3>Contato</h3>
            <div class="tl-clientes-grid">
              <div class="tl-imoveis-field">
                <label for="clienteEmail">E-mail</label>
                <input id="clienteEmail" type="email" placeholder="email@dominio.com" />
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteTelefone">Telefone</label>
                <input id="clienteTelefone" type="text" placeholder="(00) 0000-0000" />
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteCelular">Celular</label>
                <input id="clienteCelular" type="text" placeholder="(00) 00000-0000" />
              </div>
            </div>
          </section>

          <section class="tl-clientes-card tl-clientes-card--midias" id="clienteMidiasSection">
            <div class="tl-clientes-midias__head">
              <div>
                <h3>Foto e documentacao</h3>
                <p>Centralize a foto do cliente e todos os arquivos importantes no mesmo cadastro.</p>
              </div>
              <span id="clienteMidiasResumo" class="tl-clientes-midias__status">Salve o cliente para habilitar uploads permanentes.</span>
            </div>
            <div class="tl-clientes-midias-grid">
              <article class="tl-clientes-media-card">
                <div class="tl-clientes-media-card__head">
                  <span class="tl-imoveis-eyebrow mono-font">FOTO</span>
                  <strong>Avatar comercial</strong>
                </div>
                <div class="tl-clientes-photo-preview" id="clienteFotoPreview">
                  <img id="clienteFotoAtual" alt="Foto do cliente" hidden />
                  <span id="clienteFotoFallback">CL</span>
                </div>
                <div id="clienteFotoMeta" class="tl-clientes-media-meta">Nenhuma foto cadastrada.</div>
                <input id="clienteFotoInput" class="tl-clientes-file" type="file" accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp" />
                <div class="tl-clientes-media-actions">
                  <button id="btnEnviarFotoCliente" class="tl-imoveis-btn" type="button">Enviar foto</button>
                  <button id="btnRemoverFotoCliente" class="tl-imoveis-btn tl-imoveis-btn--secondary" type="button">Remover foto</button>
                </div>
                <p id="clienteFotoHint" class="tl-clientes-media-hint">Use JPG, PNG ou WEBP com ate 10 MB.</p>
              </article>

              <article class="tl-clientes-media-card">
                <div class="tl-clientes-media-card__head">
                  <span class="tl-imoveis-eyebrow mono-font">DOCUMENTOS</span>
                  <strong>Arquivos do cliente</strong>
                </div>
                <input id="clienteDocumentosInput" class="tl-clientes-file" type="file" accept=".pdf,.doc,.docx,.jpg,.jpeg,.png,.webp,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,image/jpeg,image/png,image/webp" multiple />
                <div class="tl-clientes-media-actions">
                  <button id="btnEnviarDocumentosCliente" class="tl-imoveis-btn" type="button">Enviar documentos</button>
                </div>
                <div id="clienteDocumentosSelecionados" class="tl-clientes-docs-pending"></div>
                <div id="clienteDocumentosLista" class="tl-clientes-docs-list">
                  <div class="tl-clientes-docs-empty">Nenhum documento anexado ainda.</div>
                </div>
                <p id="clienteDocumentosHint" class="tl-clientes-media-hint">Aceita PDF, DOC, DOCX, JPG, PNG e WEBP. Ate 12 arquivos por envio e 20 MB por documento.</p>
              </article>
            </div>
          </section>

          <section class="tl-clientes-card">
            <h3>Endereco</h3>
            <div class="tl-clientes-grid">
              <div class="tl-imoveis-field">
                <label for="clienteCep">CEP</label>
                <input id="clienteCep" type="text" placeholder="00000-000" />
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteEndereco">Logradouro</label>
                <input id="clienteEndereco" type="text" placeholder="Rua, avenida, etc." readonly />
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteNumero">Numero</label>
                <input id="clienteNumero" type="text" placeholder="Numero" />
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteComplemento">Complemento</label>
                <input id="clienteComplemento" type="text" placeholder="Apartamento, bloco, etc." />
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteBairro">Bairro</label>
                <input id="clienteBairro" type="text" readonly />
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteCidade">Cidade</label>
                <input id="clienteCidade" type="text" readonly />
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteEstado">Estado</label>
                <input id="clienteEstado" type="text" readonly />
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteTempoResidencia">Tempo de residencia</label>
                <input id="clienteTempoResidencia" type="text" placeholder="Anos de residencia" />
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteSituacaoMoradia">Situacao de moradia</label>
                <select id="clienteSituacaoMoradia" class="tl-clientes-select">
                  <option value="">Selecione</option>
                  <option>Proprio</option>
                  <option>Alugado</option>
                  <option>Financiado</option>
                  <option>Cedido</option>
                  <option>Outro</option>
                </select>
              </div>
            </div>
          </section>

          <section class="tl-clientes-card">
            <h3>Renda familiar</h3>
            <div class="tl-clientes-grid">
              <div class="tl-imoveis-field">
                <label for="clienteRendaPrincipal">Renda principal</label>
                <input id="clienteRendaPrincipal" type="text" placeholder="R$ 0,00" />
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteRendaInformal">Renda informal</label>
                <input id="clienteRendaInformal" type="text" placeholder="R$ 0,00" />
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteRendaTotal">Renda familiar total</label>
                <input id="clienteRendaTotal" type="text" placeholder="R$ 0,00" readonly aria-readonly="true" />
              </div>
            </div>
          </section>

          <section class="tl-clientes-card">
            <h3>Parametros padrao da simulacao</h3>
            <div class="tl-clientes-grid">
              <div class="tl-imoveis-field">
                <label for="clienteSimFinanciamento">Valor aprovado / financiamento</label>
                <input id="clienteSimFinanciamento" type="text" placeholder="R$ 0,00" />
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteSimParcelaBanco">Parcela banco cheia</label>
                <input id="clienteSimParcelaBanco" type="text" placeholder="R$ 0,00" />
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteSimFgts">FGTS</label>
                <input id="clienteSimFgts" type="text" placeholder="R$ 0,00" />
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteSimSubsidio">Subsidio</label>
                <input id="clienteSimSubsidio" type="text" placeholder="R$ 0,00" />
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteSimChequeMoradia">Cheque moradia</label>
                <input id="clienteSimChequeMoradia" type="text" placeholder="R$ 0,00" />
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteSimIntermediariaValor">Parcela intermediaria</label>
                <input id="clienteSimIntermediariaValor" type="text" placeholder="R$ 0,00" />
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteSimIntermediariaQtd">Intermediarias (qtd)</label>
                <input id="clienteSimIntermediariaQtd" type="text" inputmode="numeric" placeholder="0" />
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteSimAnualValor">Parcela anual</label>
                <input id="clienteSimAnualValor" type="text" placeholder="R$ 0,00" />
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteSimAnualQtd">Anuais (qtd)</label>
                <input id="clienteSimAnualQtd" type="text" inputmode="numeric" placeholder="0" />
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteSimSemestralValor">Parcela semestral</label>
                <input id="clienteSimSemestralValor" type="text" placeholder="R$ 0,00" />
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteSimSemestralQtd">Semestrais (qtd)</label>
                <input id="clienteSimSemestralQtd" type="text" inputmode="numeric" placeholder="0" />
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteSimReforcoValor">Reforco</label>
                <input id="clienteSimReforcoValor" type="text" placeholder="R$ 0,00" />
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteSimReforcoQtd">Reforcos (qtd)</label>
                <input id="clienteSimReforcoQtd" type="text" inputmode="numeric" placeholder="0" />
              </div>
              <div class="tl-imoveis-field tl-clientes-field--full">
                <label for="clienteSimObservacoes">Observacoes comerciais para simulacao</label>
                <textarea id="clienteSimObservacoes" rows="3" placeholder="Observacoes internas que devem iniciar no simulador."></textarea>
              </div>
            </div>
          </section>

          <section class="tl-clientes-card">
            <h3>Perfil familiar</h3>
            <div class="tl-clientes-grid">
              <div class="tl-imoveis-field">
                <label for="clienteMoradores">Numero de moradores</label>
                <input id="clienteMoradores" type="text" inputmode="numeric" placeholder="0" />
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteDependentes">Dependentes</label>
                <input id="clienteDependentes" type="text" inputmode="numeric" placeholder="0" />
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteFilhos">Numero de filhos</label>
                <input id="clienteFilhos" type="text" inputmode="numeric" placeholder="0" />
              </div>
            </div>
          </section>

          <section class="tl-clientes-card">
            <h3>Profissao e ocupacao</h3>
            <div class="tl-clientes-grid">
              <div class="tl-imoveis-field">
                <label for="clienteProfissao">Profissao</label>
                <input id="clienteProfissao" type="text" />
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteEmpresa">Empresa atual</label>
                <input id="clienteEmpresa" type="text" />
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteCargo">Cargo</label>
                <input id="clienteCargo" type="text" />
