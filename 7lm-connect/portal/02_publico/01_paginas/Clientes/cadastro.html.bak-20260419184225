                <input id="clienteTempoEmprego" type="text" placeholder="Anos de emprego" />
              </div>
              <div class="tl-imoveis-field">
                <label for="clienteTipoContrato">Tipo de contrato</label>
                <select id="clienteTipoContrato" class="tl-clientes-select">
                  <option value="">Selecione</option>
                  <option>CLT</option>
                  <option>PJ</option>
                  <option>Autonomo</option>
                  <option>Empresario</option>
                  <option>Aposentado</option>
                  <option>Pensionista</option>
