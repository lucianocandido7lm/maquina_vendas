                <div class="tl-empty-state__icon">ID</div>
                <div>
                  <h3>Carregando Pessoas</h3>
                  <p style="font-size: 0.85rem; color: var(--txt-soft);">A lista de pessoas aparecerá aqui.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="tl-admin-tab-panel" id="funcionariosTabEquipes" data-funcionarios-tab-panel="equipes" hidden>
