            </div>

            <div id="resumoEquipesFuncionarios" class="tl-access-summary" aria-live="polite"></div>
            <div id="listaEquipesFuncionarios" class="tl-table-surface tl-scroll" aria-live="polite">
              <div class="tl-empty-state tl-empty-state--compact">
                <div class="tl-empty-state__icon">EQ</div>
                <div>
                  <h3>Carregando Equipes</h3>
                  <p style="font-size: 0.85rem; color: var(--txt-soft);">As vigências das equipes aparecerão aqui.</p>
                </div>
              </div>
            </div>
          </div>
        </article>

        <article class="tl-panel tl-panel--half tl-panel--acoes glass-panel hyper-glass">
          <div class="tl-panel__header">
            <div>
              <div class="tl-panel__eyebrow mono-font">Segurança da Conta</div>
              <h2 class="tl-panel__title">Ações Rápidas</h2>
            </div>
          </div>

          <div id="painelSegurancaUsuario" class="tl-permission-list tl-inner-surface tl-scroll">
            <div class="tl-security-empty">
              <div class="tl-security-empty__icon">🔐</div>
              <div>
                <h3>Aguardando seleção</h3>
                <p>Selecione um usuário para visualizar o estado da conta e executar ações administrativas.</p>
              </div>
            </div>
          </div>
        </article>

        <article class="tl-panel tl-panel--half tl-panel--perfis glass-panel hyper-glass" hidden>
