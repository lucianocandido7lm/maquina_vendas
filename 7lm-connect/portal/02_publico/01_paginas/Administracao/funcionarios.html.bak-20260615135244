              <button class="tl-btn-secondary tl-access-toolbar__button" id="btnFiltrarEquipes" type="button">Aplicar Filtros</button>
              <button class="tl-btn-secondary tl-access-toolbar__button" id="btnLimparFiltrosEquipes" type="button">Limpar</button>
