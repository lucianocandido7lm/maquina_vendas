                <line x1="1" y1="12" x2="3" y2="12"></line>
                <line x1="21" y1="12" x2="23" y2="12"></line>
                <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
                <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
              </svg>
              <svg class="icon-moon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
              </svg>
            </div>
          </button>

          <div class="tl-userbox glass-panel hyper-glass">
            <div class="tl-userbox__avatar">
              <span id="userInitials">TL</span>
            </div>
            <div class="tl-userbox__info">
              <div class="tl-userbox__name" id="nomeUsuario">Carregando...</div>
              <div class="tl-userbox__meta mono-font" id="metaUsuario">Conectando...</div>
            </div>
          </div>
        </div>
      </header>

      <section class="tl-admin-grid anim-stagger-3">

        <div class="tl-admin-top-row">
          <article class="tl-panel tl-panel--pesquisa glass-panel hyper-glass">
            <div class="tl-panel__header">
              <div>
                <div class="tl-panel__eyebrow mono-font">Busca • Usuários</div>
                <h2 class="tl-panel__title">Pesquisar Usuário</h2>
              </div>
              <div class="tl-badge">7LM</div>
            </div>

            <div class="tl-search-box">
              <div class="tl-search-input">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <circle cx="11" cy="11" r="7"></circle>
                  <line x1="20" y1="20" x2="16.65" y2="16.65"></line>
                </svg>
                <input id="inputBuscaUsuario" type="text" placeholder="Buscar por nome, e-mail ou matrícula..." autocomplete="off" />
              </div>
              <button class="tl-btn-primary pulse-btn" id="btnBuscarUsuario" type="button">Buscar</button>
              <button class="tl-btn-secondary" id="btnNovoUsuarioExterno" type="button">Novo Usuário</button>
            </div>

            <div class="tl-search-hint mono-font">
              Busca por: <span>nome</span> • <span>e-mail</span> • <span>matrícula</span> • <span>identificador</span>
            </div>

            <div class="tl-search-results-section mt-4 tl-panel-fill">
              <div id="caixaResultadosBusca" class="tl-directory-list tl-inner-surface tl-scroll" aria-live="polite">
                <div class="tl-empty-state tl-empty-state--compact">
                  <div class="tl-empty-state__icon">🔎</div>
                  <div>
                    <h3>Aguardando busca</h3>
                    <p style="font-size: 0.85rem; color: var(--txt-soft);">
                      Os resultados aparecerão aqui.
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </article>

          <article class="tl-panel tl-panel--colaborador glass-panel hyper-glass">
            <div class="tl-panel__header">
              <div>
                <div class="tl-panel__eyebrow mono-font">Alvo Selecionado</div>
                <h2 class="tl-panel__title">Resumo do Perfil</h2>
              </div>
              <div class="tl-panel__header-actions">
                <div class="tl-badge tl-badge--soft" id="badgeStatusUsuario">Sem seleção</div>
                <button class="tl-btn-secondary" id="btnProvisionarQuadro" type="button">Editar</button>
              </div>
            </div>

            <div class="tl-colab-shell tl-panel-fill">
              <div id="painelResumoUsuario" class="tl-user-summary tl-inner-surface">
                <div class="tl-profile-empty">
                  <div class="tl-profile-empty__icon">👤</div>
                    <div>
                      <h3>Selecione um usuário</h3>
                      <p>Busque ao lado para carregar o resumo executivo do usuário selecionado.</p>
                    </div>
                  </div>
              </div>

              <div class="tl-status-strip" id="painelIndicadoresAlvo">
                <div class="tl-status-pill">
                  <span class="tl-status-dot"></span>
                  <span>Origem: <strong>—</strong></span>
                </div>
                <div class="tl-status-pill">
                  <span class="tl-status-dot"></span>
                  <span>Status: <strong>—</strong></span>
                </div>
                <div class="tl-status-pill">
                  <span class="tl-status-dot"></span>
                  <span>Cadastro: <strong>—</strong></span>
                </div>
                <div class="tl-status-pill">
                  <span class="tl-status-dot"></span>
                  <span>MFA: <strong>—</strong></span>
                </div>
                <div class="tl-status-pill">
                  <span class="tl-status-dot"></span>
                  <span>Troca de senha: <strong>—</strong></span>
                </div>
              </div>
            </div>

            <div class="tl-colab-shell__quadro mt-4">
              <div class="tl-panel__eyebrow mono-font">Detalhes Complementares</div>
              <div id="painelQuadroAtual" class="tl-quadro-layout tl-inner-surface tl-scroll">
                <div class="tl-info-grid">
                  <div class="tl-info-item">
                    <span class="tl-info-label">Identificação</span>
                    <span class="tl-info-value">—</span>
                  </div>

                  <div class="tl-info-item">
                    <span class="tl-info-label">Data do quadro</span>
                    <span class="tl-info-value">—</span>
                  </div>

                  <div class="tl-info-item tl-info-item--full">
                    <span class="tl-info-label">Nome</span>
                    <span class="tl-info-value">Nenhum quadro carregado</span>
                  </div>

                  <div class="tl-info-item">
                    <span class="tl-info-label">Status</span>
                    <span class="tl-info-value">—</span>
                  </div>

                  <div class="tl-info-item">
                    <span class="tl-info-label">Status GIP</span>
                    <span class="tl-info-value">—</span>
                  </div>

                  <div class="tl-info-item">
                    <span class="tl-info-label">Status operacional</span>
                    <span class="tl-info-value">—</span>
                  </div>

                  <div class="tl-info-item">
                    <span class="tl-info-label">GH ativo</span>
                    <span class="tl-info-value">—</span>
                  </div>
                </div>
              </div>
            </div>
          </article>
        </div>

        <article class="tl-panel tl-panel--full tl-panel--funcionarios glass-panel hyper-glass">
          <div class="tl-panel__header">
            <div class="tl-panel__header-actions tl-panel__header-actions--wrap">
              <button class="tl-btn-primary pulse-btn" id="btnNovoFuncionario" type="button">Nova Pessoa</button>
            </div>
          </div>

          <div class="tl-admin-subtabs" role="tablist" aria-label="Cadastro de Pessoas">
            <button class="tl-admin-subtab is-active" type="button" data-funcionarios-tab="colaboradores">Pessoas</button>
            <button class="tl-admin-subtab" type="button" data-funcionarios-tab="equipes">Equipes</button>
          </div>

          <div class="tl-admin-tab-panel" id="funcionariosTabColaboradores" data-funcionarios-tab-panel="colaboradores">
            <div class="tl-access-toolbar">
              <div class="tl-form-group">
                <label>Busca</label>
                <input id="inputFuncionarioBusca" type="text" placeholder="Nome, e-mail, CPF ou liderança" />
              </div>
              <div class="tl-form-group">
                <label>Região</label>
                <select id="selectFuncionarioSetor">
                  <option value="">Todas</option>
                </select>
              </div>
              <div class="tl-form-group">
                <label>Vínculo</label>
                <select id="selectFuncionarioVinculo">
                  <option value="">Todos</option>
                  <option value="CLT">CLT</option>
                  <option value="PJ">PJ</option>
                </select>
              </div>
              <div class="tl-form-group">
                <label>Equipe</label>
                <select id="selectFuncionarioImobiliaria">
                  <option value="">Todas</option>
                </select>
              </div>
              <div class="tl-form-group">
                <label>Status</label>
                <select id="selectFuncionarioStatus">
                  <option value="">Todos</option>
                  <option value="ATIVO">Ativos</option>
                  <option value="INATIVO">Inativos</option>
                  <option value="AFASTADO">Afastados</option>
                </select>
              </div>
              <div class="tl-form-group">
                <label>Login</label>
                <select id="selectFuncionarioLogin">
                  <option value="">Todos</option>
                  <option value="LIBERADO">Liberado</option>
                  <option value="BLOQUEADO">Bloqueado</option>
                  <option value="SEM_EMAIL">Sem E-mail</option>
                  <option value="PENDENTE">Pendente</option>
                </select>
              </div>
              <button class="tl-btn-secondary tl-access-toolbar__button" id="btnFiltrarFuncionarios" type="button">Aplicar Filtros</button>
              <button class="tl-btn-secondary tl-access-toolbar__button" id="btnLimparFiltrosFuncionarios" type="button">Limpar</button>
            </div>

            <div id="resumoFuncionarios" class="tl-access-summary" aria-live="polite"></div>
            <div id="listaFuncionarios" class="tl-table-surface tl-scroll" aria-live="polite">
