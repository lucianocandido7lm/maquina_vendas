            <div>
              <div class="tl-panel__eyebrow mono-font">Acesso Base</div>
              <h2 class="tl-panel__title">Perfis Vinculados</h2>
            </div>
            <button class="tl-btn-secondary" id="btnAdicionarPerfil" type="button">Adicionar</button>
          </div>

          <div id="listaPerfisUsuario" class="tl-permission-list tl-inner-surface tl-scroll">
