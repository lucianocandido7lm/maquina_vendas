  <title>7LM | Abertura e Objetivos</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="../../02_recursos/01_estilos/inicio.css?v=20260425-modulos-qa1" />
  <link rel="stylesheet" href="../../02_recursos/01_estilos/metas_resultados.css?v=20260520-api-indicadores-1" />

  <meta name="sevenlm-connect-api-base-url" content="" />
