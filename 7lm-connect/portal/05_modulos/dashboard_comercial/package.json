    "test:periods": "node scripts/test-period-regression.mjs",
    "test": "vitest run --exclude tests/e2e/**/* --passWithNoTests",
    "test:e2e": "playwright test",
    "test:ci": "npm run lint && npm run test && npm run test:e2e"
  },
  "dependencies": {
    "@databricks/sql": "^1.13.0",
