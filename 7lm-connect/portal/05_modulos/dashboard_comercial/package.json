    "helmet": "^8.1.0",
    "lucide-react": "^1.7.0",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.1",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.1",
